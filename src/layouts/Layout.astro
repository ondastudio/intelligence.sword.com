---
/**
 * Base page layout.
 *
 * Design-agnostic shell: it loads the global stylesheet (design tokens +
 * Tailwind) and renders page content via <slot />. Header / footer / nav are
 * components extracted from the design — compose them inside pages on top of
 * this layout.
 */
import '../styles/global.css';
import MobileHeader from '../components/layout/MobileHeader.astro';
import organization from '../data/organization.json';

interface Props {
  title: string;
  description?: string;
  /** Render the global mobile nav pill. Off for non-site pages (e.g. styleguide). */
  mobileNav?: boolean;
  /** Social-share card, root-relative path in /public. Defaults to the brand card. */
  ogImage?: string;
  /** Keep this page out of search results (e.g. the internal /styleguide catalog). */
  noindex?: boolean;
}

const {
  title,
  description = '',
  mobileNav = true,
  ogImage: ogImagePath = '/og-image.png',
  noindex = false,
} = Astro.props;

// Absolute URLs for social sharing. Astro.site is the canonical origin set in
// astro.config.mjs; both fall back gracefully if a page is viewed standalone.
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(ogImagePath, Astro.site);

// Sitewide Organization + WebSite structured data (JSON-LD). Org identity
// (name, logo, social profiles) lives in src/data/organization.json.
const siteUrl = new URL(Astro.site ?? '/');
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${siteUrl}#organization`,
      name: organization.name,
      legalName: organization.legalName,
      url: siteUrl.toString(),
      logo: new URL(organization.logo, Astro.site).toString(),
      sameAs: organization.sameAs,
    },
    {
      '@type': 'WebSite',
      '@id': `${siteUrl}#website`,
      name: organization.name,
      url: siteUrl.toString(),
      publisher: { '@id': `${siteUrl}#organization` },
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <!-- Flag JS as available so the scroll-reveal start-states only hide
         content when the observer can actually reveal it (see global.css). -->
    <script is:inline>
      document.documentElement.classList.add("js");
    </script>
    <!-- Brand favicon: purple-on-white in light mode, white-on-purple in dark.
         Browsers pick the matching media query; favicon.ico is the legacy
         fallback for clients that ignore `media`. -->
    <link rel="icon" type="image/png" href="/favicon-light.png" media="(prefers-color-scheme: light)" />
    <link rel="icon" type="image/png" href="/favicon-dark.png" media="(prefers-color-scheme: dark)" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph / social sharing card. Image is a fixed brand card in
         /public; absolute URL is required by crawlers (Facebook, LinkedIn, …). -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Sword Intelligence" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="639" />
    <meta property="og:image:alt" content="Sword Intelligence" />

    <!-- Twitter / X large-image card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <!-- Fonts from the design: Figtree (UI/body), Lora (headlines), DM Mono (mono labels) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Figtree:wght@400;500;600;700&family=Lora:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>

    <!-- Sitewide Organization + WebSite structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    {/* Global mobile nav — rendered at the body root so it always stays above
        every page section (see MobileHeader). Desktop nav lives in Navbar. */}
    {mobileNav && <MobileHeader />}

    <slot />

    <!-- Site-wide scroll reveal: one observer toggles `.in-view` on every
         [data-reveal] element the first time it enters the viewport. Variants
         (title / line / default) and prefers-reduced-motion handling live in
         global.css. -->
    <script>
      const items = Array.from(
        document.querySelectorAll<HTMLElement>("[data-reveal]"),
      );
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      if (reduce || !("IntersectionObserver" in window)) {
        items.forEach((el) => el.classList.add("in-view"));
      } else {
        const obs = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add("in-view");
                obs.unobserve(e.target);
              }
            });
          },
          { threshold: 0.2 },
        );
        items.forEach((el) => obs.observe(el));
      }
    </script>
  </body>
</html>
