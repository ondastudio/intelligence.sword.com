---
/**
 * Living style guide — a visual catalog of design tokens and every component
 * in the library. Add each new component here (with its variants) so anyone can
 * see what already exists before building something new.
 */
import Layout from "../layouts/Layout.astro";
import Button from "../components/ui/Button.astro";
import Eyebrow from "../components/ui/Eyebrow.astro";
import LabelPill from "../components/ui/LabelPill.astro";
import PlusChip from "../components/ui/PlusChip.astro";
import ClinicalStepPill from "../components/ui/ClinicalStepPill.astro";
import CircleButton from "../components/ui/CircleButton.astro";
import ArrowCircle from "../components/ui/ArrowCircle.astro";
import FeatureCard from "../components/ui/FeatureCard.astro";
import MediaFrame from "../components/ui/MediaFrame.astro";
import ScrollLetterReveal from "../components/ui/ScrollLetterReveal.astro";
import SolutionCard from "../components/ui/SolutionCard.astro";
import TriageMedia from "../components/ui/TriageMedia.astro";
import StoryCard from "../components/ui/StoryCard.astro";
import TeamCard from "../components/ui/TeamCard.astro";
import FormField from "../components/ui/FormField.astro";
import Logo from "../components/layout/Logo.astro";
import LogoStrip from "../components/layout/LogoStrip.astro";
import LogoMarquee from "../components/layout/LogoMarquee.astro";
import intro from "../data/intro.json";
import about from "../data/about.json";
import triage from "../data/triage.json";

// The five Triage media-panel variants (lime call card + 4 orchestration cards).
const triageMedias = [
  triage.card.media,
  ...triage.orchestration.cards.map((c) => c.media),
];

// Self-contained demo content for the purple SolutionCard variant.
const demoCard = {
  title: "No-Show & Waiting List Reduction",
  headline: "Fill every no-show and move your waiting list.",
  points: [
    { before: "Behavioral risk model ", strong: "predicts DNAs", rest: "." },
    { strong: "Adapts AI actions", rest: " to risk scores." },
    { rest: "Handles outreach, callbacks, and scheduling." },
    { before: "Integrates with your ", strong: "EHR in real-time", rest: "." },
  ],
  logo: "/triage/ministry-logo.png",
  logoAlt: "Hellenic Republic Ministry of Health",
  stat: "$150B",
  statLabel: "Lost yearly to no-shows in the US",
  glow: "/triage/card-glow-purple.svg",
  cta: { label: "Learn More", href: "#" },
};

const swatches = [
  { name: "brand", cls: "bg-brand", hex: "#7700ee" },
  { name: "purple-500", cls: "bg-purple-500", hex: "#4d0099" },
  { name: "coral", cls: "bg-coral", hex: "#ffedee" },
  { name: "purple-300", cls: "bg-purple-300", hex: "#8c4aff" },
  { name: "purple-200", cls: "bg-purple-200", hex: "#a684ff" },
  { name: "purple-150", cls: "bg-purple-150", hex: "#d3c2ff" },
  { name: "purple-100", cls: "bg-purple-100", hex: "#e1d6ff" },
  { name: "purple-tint", cls: "bg-purple-tint border border-black/10", hex: "#eee8ff" },
  { name: "lavender", cls: "bg-lavender border border-black/10", hex: "#ede7fe" },
  { name: "glow-blue", cls: "bg-glow-blue", hex: "#4a89e8" },
  { name: "accent (lime)", cls: "bg-accent", hex: "#ccff33" },
  { name: "lime-400", cls: "bg-lime-400", hex: "#d9ff66" },
  { name: "lime-tint", cls: "bg-lime-tint border border-black/10", hex: "#f7ffe8" },
  { name: "surface", cls: "bg-surface border border-black/10", hex: "#f9f9f9" },
  { name: "ink", cls: "bg-ink", hex: "#1f1f1f" },
  { name: "ink-muted", cls: "bg-ink-muted", hex: "#bfc0cc" },
  { name: "ink-soft", cls: "bg-ink-soft", hex: "#525252" },
  { name: "gray-200", cls: "bg-gray-200 border border-black/10", hex: "#dcdde4" },
  { name: "black", cls: "bg-black", hex: "#000000" },
  { name: "white", cls: "bg-white border border-black/10", hex: "#ffffff" },
];
---

<Layout title="Style Guide · Sword Intelligence" mobileNav={false}>
  <main class="mx-auto max-w-5xl px-6 py-16">
    <h1 class="font-serif text-5xl">Style Guide</h1>
    <p class="mt-3 text-black/60">
      Design tokens and components extracted from the Figma design. Check here
      before building something new.
    </p>

    <!-- Colors -->
    <section class="mt-14">
      <h2 class="text-sm font-semibold uppercase">Colors</h2>
      <div class="mt-4 grid grid-cols-2 gap-4 sm:grid-cols-4">
        {
          swatches.map((s) => (
            <div>
              <div class={`h-20 rounded-2xl ${s.cls}`} />
              <p class="mt-2 text-sm font-semibold">{s.name}</p>
              <p class="text-sm text-black/50">{s.hex}</p>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Typography -->
    <section class="mt-14">
      <h2 class="text-sm font-semibold uppercase">
        Typography
      </h2>
      <div class="mt-4 space-y-3">
        <p class="font-serif text-h5">
          Lora — display headline (56px)
        </p>
        <p class="font-serif text-h6">
          Lora — title / stat (48px)
        </p>
        <p class="font-serif text-5xl">
          Lora — editorial headline
        </p>
        <p class="font-sans text-2xl">Figtree — supporting paragraph</p>
        <p class="font-sans text-sm font-semibold uppercase">
          Figtree — uppercase label
        </p>
      </div>
    </section>

    <!-- Buttons -->
    <section class="mt-14">
      <h2 class="text-sm font-semibold uppercase">Button</h2>
      <div class="mt-4 flex flex-wrap items-center gap-4">
        <Button variant="solid" href="#">Book a meeting</Button>
        <Button variant="glass" href="#">About</Button>
        <Button variant="glass" href="#" caret>Solution</Button>
      </div>
    </section>

    <!-- Eyebrow -->
    <section class="mt-14">
      <h2 class="text-sm font-semibold uppercase">Eyebrow</h2>
      <div class="mt-4 flex flex-col gap-3">
        <Eyebrow>Built by the #1 AI Care company.</Eyebrow>
        <Eyebrow dotClass="bg-purple-500">Scale capacity without scaling costs</Eyebrow>
      </div>
    </section>

    <!-- LabelPill -->
    <section class="mt-14">
      <h2 class="text-sm font-semibold uppercase">
        LabelPill
      </h2>
      <div class="mt-4 flex flex-wrap items-center gap-4">
        <LabelPill>Always on</LabelPill>
        <LabelPill>Humans in the loop</LabelPill>
      </div>
    </section>

    <!-- PlusChip -->
    <section class="mt-14">
      <h2 class="text-sm font-semibold uppercase">PlusChip</h2>
      <div class="mt-4 flex flex-wrap items-center gap-4">
        <PlusChip />
        <PlusChip class="size-5" iconClass="size-3.5" />
      </div>
    </section>

    <!-- ClinicalStepPill -->
    <section class="mt-14">
      <h2 class="text-sm font-semibold uppercase">
        ClinicalStepPill
      </h2>
      <div class="mt-4 flex flex-wrap items-center gap-4">
        <ClinicalStepPill num="01" label="Channels" />
        <ClinicalStepPill num="02" label="Clinical intelligence" />
      </div>
    </section>

    <!-- FeatureCard -->
    <section class="mt-14">
      <h2 class="text-sm font-semibold uppercase">
        FeatureCard
      </h2>
      <div class="mt-4 grid max-w-md grid-cols-1 sm:grid-cols-2">
        <FeatureCard
          label="Always on"
          description="Work 24/7, answering every call and monitoring your population."
        />
      </div>
    </section>

    <!-- CircleButton -->
    <section class="mt-14">
      <h2 class="text-sm font-semibold uppercase">
        CircleButton
      </h2>
      <div class="mt-4">
        <CircleButton href="#" />
      </div>
    </section>

    <!-- ArrowCircle -->
    <section class="mt-14">
      <h2 class="text-sm font-semibold uppercase">
        ArrowCircle
      </h2>
      <div class="mt-4 flex items-center gap-4 rounded-card bg-surface p-6">
        <ArrowCircle href="#" variant="dotted" label="Dotted" />
        <ArrowCircle href="#" variant="filled" rotate={45} label="Filled" />
      </div>
    </section>

    <!-- Logo -->
    <section class="mt-14">
      <h2 class="text-sm font-semibold uppercase">Logo</h2>
      <div class="mt-4">
        <Logo />
      </div>
    </section>

    <!-- LogoStrip -->
    <section class="mt-14">
      <h2 class="text-sm font-semibold uppercase">
        LogoStrip
      </h2>
      <div class="mt-4">
        <LogoStrip logos={intro.logos} />
      </div>
    </section>

    <!-- LogoMarquee -->
    <section class="mt-14">
      <h2 class="text-sm font-semibold uppercase">
        LogoMarquee
      </h2>
      <div class="mt-4">
        <LogoMarquee logos={intro.logos} />
      </div>
    </section>

    <!-- SolutionCard -->
    <section class="mt-14">
      <h2 class="text-sm font-semibold uppercase">
        SolutionCard
      </h2>
      <p class="mt-1 text-sm text-black/50">
        Theme <code>purple</code> (Care Orchestration). The <code>lime</code> theme
        (with an MDR badge) powers the Triage card.
      </p>
      <div class="mt-4">
        <SolutionCard
          theme="purple"
          title={demoCard.title}
          headline={demoCard.headline}
          points={demoCard.points}
          glow={demoCard.glow}
          logo={demoCard.logo}
          logoAlt={demoCard.logoAlt}
          stat={demoCard.stat}
          statLabel={demoCard.statLabel}
          cta={demoCard.cta}
        />
      </div>
    </section>

    <!-- TriageMedia -->
    <section class="mt-14">
      <h2 class="text-sm font-semibold uppercase">TriageMedia</h2>
      <p class="mt-1 text-sm text-black/50">
        The illustrative "app screen" for each Triage <code>SolutionCard</code>'s
        media panel (rendered at its native 376×470). Variants: <code>call</code>,
        <code>noshow</code>, <code>campaign</code>, <code>surgery</code>,
        <code>discharge</code>. Fed from <code>data/triage.json</code>.
      </p>
      <div class="mt-4 flex flex-wrap gap-6">
        {
          triageMedias.map((m) => (
            <div class="relative h-[470px] w-[376px] shrink-0 overflow-hidden rounded-[40px] bg-white ring-1 ring-inset ring-black/10">
              <TriageMedia media={m} />
            </div>
          ))
        }
      </div>
    </section>

    <!-- MediaFrame -->
    <section class="mt-14">
      <h2 class="text-sm font-semibold uppercase">
        MediaFrame
      </h2>
      <div class="mt-4">
        <MediaFrame
          src={intro.media.src}
          poster={intro.media.poster}
          alt={intro.media.alt}
        />
      </div>
    </section>

    <!-- ScrollLetterReveal -->
    <section class="mt-14">
      <h2 class="text-sm font-semibold uppercase">
        ScrollLetterReveal
      </h2>
      <p class="mt-1 text-sm text-black/50">
        Letters start muted gray and light up to black as the block scrolls
        through the viewport (scroll the page to see it). No-JS / reduced-motion
        renders solid black. Used by AboutStory and the home Intro statement.
      </p>
      <div class="mt-4">
        <ScrollLetterReveal
          paragraphs={[
            [
              { text: "Letters light up " },
              { text: "one by one", bold: true },
              { text: " as you scroll past this paragraph." },
            ],
          ]}
          class="max-w-[640px] font-sans text-h6 leading-[1.15]"
        />
      </div>
    </section>

    <!-- StoryCard -->
    <section class="mt-14">
      <h2 class="text-sm font-semibold uppercase">
        StoryCard
      </h2>
      <p class="mt-1 text-sm text-black/50">
        Customer-story tile from the "Our Customers" grid. Variants: <code>story</code>
        (logo + title + stat + CTA, <code>tone</code> white/lavender/outline), <code>quote</code>,
        <code>logo</code>, and <code>highlighted</code> (full-width hero). Pass <code>photo</code> to
        a story/quote for the composite text+photo layout.
      </p>
      <div class="mt-4 grid gap-4 md:grid-cols-3">
        <StoryCard
          type="story"
          tone="white"
          logo="/logos/nhs.svg"
          logoAlt="NHS"
          title="Cutting Hospital Stays with AI-driven Prehabilitation"
          stat={{ value: "£405K", label: "saved for one NHS Trust in 3 months" }}
          cta={{ label: "Read more", href: "#" }}
        />
        <StoryCard
          type="story"
          tone="outline"
          logo="/logos/ne-london.png"
          logoAlt="North East London"
          title="Intelligence Helps the NHS Prevent Surgical Complications"
          stat={{ value: "72%", label: "reduction in surgical complications" }}
          cta={{ label: "Read more", href: "#" }}
        />
        <StoryCard
          type="quote"
          tone="lavender"
          logo="/logos/hellenic-health.png"
          logoAlt="Hellenic Ministry of Health"
          quote="This partnership will rebuild how care flows through our system, making it faster, clearer, and more centered on people."
          author="Adonis Georgiadis"
          role="Minister of Health (Greece)"
        />
      </div>
    </section>

    <!-- TeamCard -->
    <section class="mt-14">
      <h2 class="text-sm font-semibold uppercase">TeamCard</h2>
      <p class="mt-1 text-sm text-black/50">
        Team-member card from the About "meet the team" grid: portrait over a
        white name/role panel with a dashed LinkedIn ring. Fully clickable —
        hover anywhere to fill the icon. Fed from <code>data/about.json</code>.
      </p>
      <div class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          about.team.members.slice(0, 3).map((m) => (
            <TeamCard
              name={m.name}
              role={m.role}
              photo={m.photo}
              linkedin={m.linkedin}
            />
          ))
        }
      </div>
    </section>

    <!-- FormField -->
    <section class="mt-14">
      <h2 class="text-sm font-semibold uppercase">FormField</h2>
      <p class="mt-1 text-sm text-black/50">
        Bordered, pill-rounded form control from the Book-an-intro page. One
        primitive covers <code>text</code>/<code>email</code> inputs, a
        <code>textarea</code>, and a styled <code>select</code> (with the
        design's drop-down chevron). Placeholders render uppercase; typed values
        keep their natural case. Fed from <code>data/book-intro.json</code>.
      </p>
      <div class="mt-4 flex max-w-[522px] flex-col gap-5">
        <FormField name="sg-name" placeholder="First name" />
        <FormField type="email" name="sg-email" placeholder="Email" />
        <FormField
          type="select"
          name="sg-country"
          placeholder="Country"
          options={["United States", "United Kingdom", "Portugal"]}
        />
        <FormField
          type="textarea"
          name="sg-message"
          placeholder="Tell us about your challenges"
        />
      </div>
    </section>
  </main>
</Layout>
