---
import Layout from "../layouts/Layout.astro";
import SwirlBackground from "../components/sections/SwirlBackground.astro";
import BookIntroForm from "../components/sections/BookIntroForm.astro";
import Footer from "../components/sections/Footer.astro";
---

<Layout
  title="Book a Meeting | Sword Intelligence"
  description="Start a conversation with our AI Care experts Intelligence. Let's solve your operational challenges, together."
  ogImage="/og-image-contact.png"
>
  {/* Same footer-reveal shell as the rest of the site. The swirl + hero share
      one `relative isolate` wrapper so the canvas (z-0) stays behind the form
      content (z-10), exactly like the home page. */}
  <div class="page-content">
    <div class="relative isolate bg-gradient-to-b from-purple-tint to-surface">
      <SwirlBackground contain />
      <BookIntroForm />
    </div>
  </div>
  <Footer variant="purple" />
</Layout>
