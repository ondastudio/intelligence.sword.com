---
/**
 * ClinicalDiagram04 — fifth state of the ClinicalLayer node diagram, the
 * "Integrations" beat that crossfades in from ClinicalDiagram31 as the pinned
 * section scrolls (Figma source 8711:880). Inlined SVG (native 837x810) so the
 * icon-disc backdrop-filter blur chips render — browsers do not run
 * backdrop-filter on SVGs loaded via <img>. Scales responsively to its wrapper.
 * The "04 / INTEGRATIONS" step chip is an HTML overlay rendered by ClinicalLayer
 * (see ClinicalStepPill), not baked into this artwork.
 */
import ClinicalLogoMarquee from "./ClinicalLogoMarquee.astro";
interface LogoItem {
  src: string;
  alt: string;
  h: number;
}
interface Props {
  class?: string;
  /** EHR / EMR logos for the card's scrolling wall, grouped into marquee rows. */
  logos?: LogoItem[][];
}
const { class: className = "", logos = [] } = Astro.props;
