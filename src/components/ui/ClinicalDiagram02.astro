<style>
  /* The middle (gradient) arc-ring of the clinical-intelligence orb — between
     the outer hairline ring and the inner disc — rotates slowly around the orb's
     centre. transform-box: fill-box pins the origin to the ring group's own
     bounding-box centre (≈827-space 415, 348 = the orb centre), so it spins in
     place at any responsive scale. Stilled for reduced-motion. */
  .orb-ring {
    transform-box: fill-box;
    transform-origin: center;
    animation: orb-spin 16s linear infinite;
  }
  @keyframes orb-spin {
    to {
      transform: rotate(360deg);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .orb-ring {
      animation: none;
    }
  }
</style>
