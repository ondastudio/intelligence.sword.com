---
/**
 * TeamCard — a single team-member card (Figma "image - text", node 8628:29).
 *
 * A `rounded-card` portrait photo (416×480, object-cover) stacked flush above a
 * white `rounded-card` panel holding the member's name (Figtree semibold 24) and
 * role (`ink-soft` 18) on the left, with a dashed-ring LinkedIn icon on the right.
 * The two rounded blocks touch (no gap), pinching a subtle waist — exactly the
 * design. Cards are fully clickable (per the site clickable-card rule): a single
 * stretched overlay `<a>` covers the card, the icon is decorative, and hovering
 * anywhere lights the icon (fills to brand, glyph inverts to white) and gently
 * zooms the photo.
 */
interface Props {
  name: string;
  role: string;
  photo: string;
  linkedin?: string;
  class?: string;
  [key: string]: unknown;
}
const {
  name,
  role,
  photo,
  linkedin = "#",
  class: className = "",
  ...rest
} = Astro.props;
---

<article class:list={["group relative flex flex-col", className]} {...rest}>
  <!-- Portrait -->
  <div class="aspect-[416/480] w-full overflow-hidden rounded-card">
    <img
      src={photo}
      alt={name}
      width="416"
      height="480"
      loading="lazy"
      class="size-full object-cover object-top transition-transform duration-700 ease-out group-hover:scale-[1.04]"
    />
  </div>

  <!-- Name / role + LinkedIn -->
  <div
    class="flex items-center justify-between gap-4 rounded-card bg-white p-6 lg:p-10"
  >
    <div class="flex min-w-0 flex-col gap-2">
      <p class="text-2xl font-semibold leading-[1.2] tracking-[-0.02em] text-black">
        {name}
      </p>
      <p class="text-lg leading-[1.2] text-ink-soft">{role}</p>
    </div>

    <span
      aria-hidden="true"
      class="grid size-10 shrink-0 place-items-center rounded-full border-[1.5px] border-dashed border-black transition-colors duration-300 group-hover:border-solid group-hover:border-brand group-hover:bg-brand"
    >
      <img
        src="/about/icons/linkedin.svg"
        alt=""
        class="size-[18px] transition duration-300 group-hover:brightness-0 group-hover:invert"
      />
    </span>
  </div>

  <!-- Whole-card link -->
  <a
    href={linkedin}
    target="_blank"
    rel="noopener noreferrer"
    aria-label={`${name} on LinkedIn`}
    class="absolute inset-0 z-20 rounded-card"></a>
</article>
