---
/**
 * TeamCard — a single team-member card (Figma "image - text", node 8628:29).
 *
 * A `rounded-card` portrait photo (416×480, object-cover) stacked flush above a
 * white `rounded-card` panel holding the member's name (Figtree semibold 24) and
 * role (`ink-soft` 18) on the left, with a decorative `ArrowCircle`
 * (`glyph="linkedin"`) on the right — same dotted ring + hover-to-solid morph as
 * every other circle button on the site. The two rounded blocks touch (no gap),
 * pinching a subtle waist — exactly the design. Cards are fully clickable (per the
 * site clickable-card rule): a single stretched overlay `<a>` covers the card, the
 * ring is decorative, and hovering anywhere morphs its dots into a solid ring and
 * gently zooms the photo.
 */
import ArrowCircle from "./ArrowCircle.astro";

interface Props {
  name: string;
  role: string;
  photo: string;
  linkedin?: string;
  class?: string;
  [key: string]: unknown;
}
const {
  name,
  role,
  photo,
  linkedin = "#",
  class: className = "",
  ...rest
} = Astro.props;
---

<article class:list={["group relative flex flex-col", className]} {...rest}>
  <!-- Portrait -->
  <div class="aspect-[416/480] w-full overflow-hidden rounded-card">
    <img
      src={photo}
      alt={name}
      width="416"
      height="480"
      loading="lazy"
      class="size-full object-cover object-top transition-transform duration-700 ease-out group-hover:scale-[1.04]"
    />
  </div>

  <!-- Name / role + LinkedIn -->
  <div
    class="flex items-center justify-between gap-4 rounded-card bg-white p-6 lg:p-10"
  >
    <div class="flex min-w-0 flex-col gap-2">
      <p class="text-2xl font-semibold leading-[1.2] tracking-[-0.02em] text-black">
        {name}
      </p>
      <p class="text-lg leading-[1.2] text-ink-soft">{role}</p>
    </div>

    <ArrowCircle glyph="linkedin" label={`${name} on LinkedIn`} decorative />
  </div>

  <!-- Whole-card link -->
  <a
    href={linkedin}
    target="_blank"
    rel="noopener noreferrer"
    aria-label={`${name} on LinkedIn`}
    class="absolute inset-0 z-20 rounded-card"></a>
</article>
