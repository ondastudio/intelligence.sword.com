---
/**
 * SolutionCard — a use-case capability card extracted from the design.
 * Two themes: "lime" (Triage / Clinical) and "purple" (Care Orchestration).
 * Composes a logo + title row (with an optional certification badge), a Lora
 * headline, a list of proof points, a white media panel, and a "case" bar with
 * a partner logo (image or text), a stat + highlight bar, and a Learn More CTA.
 * Content-free: everything comes through props (fed from data/*.json).
 */
interface Point {
  before?: string;
  strong?: string;
  rest?: string;
}
interface Props {
  theme?: "lime" | "purple";
  title: string;
  headline: string;
  points: Point[];
  glow: string;
  /** When true, `glow` is a full-card baked background (fills the card) rather
   *  than an oversized overlay bloom. Used by purple cards that ship their own
   *  base + wash + bloom in one SVG (e.g. Population Health). */
  glowFill?: boolean;
  badge?: { icon: string; text: string; alt: string };
  logo?: string;
  logoAlt?: string;
  logoText?: string;
  stat: string;
  statLabel: string;
  /** Append a frosted "+" chip after the stat (e.g. a "15% +" contractual floor). */
  statPlus?: boolean;
  /** Desktop case bar shows only the centered stat — no partner logo, no CTA.
   *  (Mobile is unaffected; it has its own layout.) */
  statOnly?: boolean;
  /** Per-breakpoint overrides for the mobile (below lg) case bar only — desktop
   *  always uses the base props. Lets a card show different case content on
   *  mobile (e.g. No-Show's contractual-floor stat) without touching desktop. */
  mobile?: {
    stat?: string;
    statLabel?: string;
    statPlus?: boolean;
    hideLogo?: boolean;
  };
  /** Optional CTA. Omit to render a case bar with no link (button + mobile arrow). */
  cta?: { label: string; href: string };
  class?: string;
}

const {
  theme = "lime",
  title,
  headline,
  points,
  glow,
  glowFill = false,
  badge,
  logo,
  logoAlt = "",
  logoText,
  stat,
  statLabel,
  statPlus = false,
  statOnly = false,
  mobile,
  cta,
  class: className = "",
} = Astro.props;

// Cards with a partner reference (image logo or text) get the two-row mobile
// case layout; a logo-less guarantee stat (e.g. No-Show) gets a centered row.
const hasLogo = Boolean(logo || logoText);

// Mobile (below lg) case content — falls back to the base props, so desktop is
// never affected by these overrides.
const mStat = mobile?.stat ?? stat;
const mStatLabel = mobile?.statLabel ?? statLabel;
const mStatPlus = mobile?.statPlus ?? statPlus;
const mHasLogo = hasLogo && !mobile?.hideLogo;

// Per-theme token lookups (semantic utilities defined in global.css)
const t = {
  lime: {
    // inset ring so the 1px stroke sits inside the card (matches the design's
    // inset stroke) without adding to the 1064×598 box.
    ring: "ring-accent",
    // lime background is a full-card SVG (base + lime wash + blurred bloom)
    cardBg: "",
    glowFit: "inset-0 h-full w-full",
    caseBg: "bg-lime-tint",
    statBar: "bg-accent",
    ctaBg: "bg-accent",
    ctaText: "text-black",
  },
  purple: {
    ring: "ring-purple-200",
    // purple base is a flat lavender wash; the glow is an oversized bloom
    // overlay anchored top-left on top of it (matches the design).
    cardBg: "bg-purple-150",
    glowFit: "left-[-4.7%] top-[-57%] h-[191%] w-[115%] max-w-none",
    caseBg: "bg-purple-tint",
    statBar: "bg-white",
    ctaBg: "bg-brand",
    ctaText: "text-white",
  },
}[theme];

// A baked full-card background supplies its own base + wash, so drop the solid
// card tint and let the SVG fill the whole card edge-to-edge.
const cardBg = glowFill ? "" : t.cardBg;
const glowFit = glowFill ? "inset-0 h-full w-full" : t.glowFit;
---

<div class={`relative flex w-full flex-col ${className}`}>
  <!-- Capability card -->
  <div
    class:list={[
      "relative overflow-hidden rounded-card p-6 ring-1 ring-inset md:p-16",
      cardBg,
      t.ring,
    ]}
  >
    <!-- Card background (per-theme): lime fills the card; purple is an overlay bloom -->
    <img
      src={glow}
      alt=""
      aria-hidden="true"
      class:list={["pointer-events-none absolute z-0", glowFit]}
    />

    <div
      class="relative z-10 flex flex-col gap-10 lg:h-[470px] lg:flex-row lg:items-stretch lg:justify-between"
    >
      <!-- Left: text content -->
      <div class="flex flex-1 flex-col justify-between gap-10 lg:max-w-[480px]">
        <!-- Header row: logo + title / optional certification badge -->
        <div class="flex items-start justify-between gap-4">
          <div class="flex items-center gap-4">
            <img
              src="/triage/logo-icon.svg"
              alt=""
              aria-hidden="true"
              class="h-[29px] w-[16px] shrink-0"
            />
            <span class="text-xl lg:text-[28px]">{title}</span>
          </div>
          {
            badge && (
              <div class="flex shrink-0 items-center gap-2">
                <img
                  src={badge.icon}
                  alt=""
                  aria-hidden="true"
                  class="h-9 w-9 shrink-0"
                />
                <img
                  src={badge.text}
                  alt={badge.alt}
                  class="h-[26px] w-[79px]"
                />
              </div>
            )
          }
        </div>

        <!-- Headline -->
        <p
          class="whitespace-pre-line font-serif font-normal text-h6 text-balance"
        >
          {headline}
        </p>

        <!-- Proof points -->
        <ul class="flex flex-col gap-3">
          {
            points.map((point, i) => (
              <li
                class:list={[
                  "pb-3 text-xmd",
                  i < points.length - 1 && "border-b border-black/24",
                ]}
              >
                <Fragment
                  set:html={`${point.before ?? ""}${point.strong ? `<span class="font-semibold">${point.strong}</span>` : ""}${point.rest ?? ""}`}
                />
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Right: media panel — hidden in the mobile/tablet carousel (below lg);
           the design's mobile card is text-only. Callers fill it via the
           `media` slot (absolute children clip to the rounded panel); with no
           slot content it stays an empty white panel, as the purple cards are. -->
      <div
        class="relative hidden h-[470px] w-full shrink-0 overflow-hidden rounded-[40px] bg-white lg:block lg:w-[376px]"
      >
        <slot name="media" />
      </div>
    </div>
  </div>

  <!-- Case bar. lg+ keeps the desktop row (logo · stat · Learn More). Below lg
       follows the Figma 390px spec: logo cards stack into two rows (logo + arrow,
       then stat + label); a logo-less guarantee stat is a single centered row. -->
  <div class:list={["overflow-hidden rounded-card", t.caseBg]}>
    <!-- Desktop (lg+) -->
    <div
      class:list={[
        "hidden h-[100px] items-center px-16 lg:flex",
        statOnly ? "justify-center" : "justify-between",
      ]}
    >
      {
        !statOnly &&
          hasLogo &&
          (logo ? (
            <img src={logo} alt={logoAlt} class="h-[54px] w-auto shrink-0" />
          ) : (
            <p class="max-w-[180px] shrink-0 text-sm font-semibold">
              {logoText}
            </p>
          ))
      }

      <div class="flex items-center gap-3">
        <span class="relative inline-block font-serif text-h6">
          <span
            class:list={["absolute inset-x-0 bottom-2.5 z-0 h-2", t.statBar]}
            aria-hidden="true"></span>
          <span class="relative z-10">{stat}</span>
        </span>
        {
          statPlus && (
            <span
              class="flex size-6 shrink-0 items-center justify-center rounded-full bg-ink-mid/10"
              aria-hidden="true"
            >
              <svg
                class="size-4"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
              >
                <path d="M12 5v14M5 12h14" />
              </svg>
            </span>
          )
        }
        <p class="max-w-[16rem] text-sm font-semibold uppercase">{statLabel}</p>
      </div>

      <!-- CTA — the only link on the card. -->
      {
        !statOnly && cta && (
          <a
            href={cta.href}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={cta.label}
            class="group/cta flex shrink-0 items-center rounded-full"
          >
        <span
          class:list={[
            "-mr-px rounded-[50px] px-6 py-3 text-sm font-semibold uppercase",
            t.ctaBg,
            t.ctaText,
          ]}>{cta.label}</span
        >
        <span
          class:list={[
            "flex size-10 items-center justify-center rounded-full",
            "transition-transform duration-300 ease-out group-hover/cta:translate-x-1",
            t.ctaBg,
            t.ctaText,
          ]}
        >
          <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            aria-hidden="true"
          >
            <path
              d="M5 12h14M13 6l6 6-6 6"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </span>
          </a>
        )
      }
    </div>

    <!-- Mobile (below lg) -->
    <div
      class:list={[
        "flex flex-col gap-6 px-10 py-6 lg:hidden",
        mHasLogo ? "" : "h-[152px] justify-center",
      ]}
    >
      {
        mHasLogo && (
          <div class="flex items-center justify-between gap-4">
            {logo ? (
              <img src={logo} alt={logoAlt} class="h-12 w-auto shrink-0" />
            ) : (
              <p class="max-w-[180px] shrink-0 text-sm font-semibold">
                {logoText}
              </p>
            )}
            {cta && (
              <a
                href={cta.href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={cta.label}
                class:list={[
                  "flex size-10 shrink-0 items-center justify-center rounded-full",
                  t.ctaBg,
                  t.ctaText,
                ]}
              >
                <svg
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  aria-hidden="true"
                >
                  <path
                    d="M5 12h14M13 6l6 6-6 6"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </a>
            )}
          </div>
        )
      }

      <div
        class:list={[
          "flex items-center gap-4",
          mHasLogo ? "" : "justify-center",
        ]}
      >
        <span class="relative inline-block font-serif text-[32px]">
          <span
            class:list={["absolute inset-x-0 bottom-2.5 z-0 h-2", t.statBar]}
            aria-hidden="true"></span>
          <span class="relative z-10">{mStat}</span>
        </span>
        {
          mStatPlus && (
            <span
              class="flex size-6 shrink-0 items-center justify-center rounded-full bg-ink-mid/10"
              aria-hidden="true"
            >
              <svg
                class="size-4"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
              >
                <path d="M12 5v14M5 12h14" />
              </svg>
            </span>
          )
        }
        <p
          class:list={[
            "text-sm font-semibold uppercase",
            mHasLogo ? "flex-1" : "max-w-[16rem]",
          ]}
        >
          {mStatLabel}
        </p>
      </div>
    </div>
  </div>
</div>
