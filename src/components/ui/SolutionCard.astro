---
/**
 * SolutionCard — a use-case capability card extracted from the design.
 * Two themes: "lime" (Triage / Clinical) and "purple" (Care Orchestration).
 * Composes a logo + title row (with an optional certification badge), a Lora
 * headline, a list of proof points, a white media panel, and a "case" bar with
 * a partner logo (image or text), a stat + highlight bar, and a Learn More CTA.
 * Content-free: everything comes through props (fed from data/*.json).
 */
interface Point {
  before?: string;
  strong?: string;
  rest?: string;
}
interface Props {
  theme?: "lime" | "purple";
  title: string;
  headline: string;
  points: Point[];
  glow: string;
  badge?: { icon: string; text: string; alt: string };
  logo?: string;
  logoAlt?: string;
  logoText?: string;
  stat: string;
  statLabel: string;
  cta: { label: string; href: string };
  class?: string;
}

const {
  theme = "lime",
  title,
  headline,
  points,
  glow,
  badge,
  logo,
  logoAlt = "",
  logoText,
  stat,
  statLabel,
  cta,
  class: className = "",
} = Astro.props;

// Per-theme token lookups (semantic utilities defined in global.css)
const t = {
  lime: {
    // inset ring so the 1px stroke sits inside the card (matches the design's
    // inset stroke) without adding to the 1064×598 box.
    ring: "ring-accent",
    // lime background is a full-card SVG (base + lime wash + blurred bloom)
    cardBg: "",
    glowFit: "inset-0 h-full w-full",
    caseBg: "bg-lime-tint",
    statBar: "bg-accent",
    ctaBg: "bg-accent",
    ctaText: "text-black",
  },
  purple: {
    ring: "ring-purple-200",
    // purple base is a flat lavender wash; the glow is an oversized bloom
    // overlay anchored top-left on top of it (matches the design).
    cardBg: "bg-purple-150",
    glowFit: "left-[-4.7%] top-[-57%] h-[191%] w-[115%] max-w-none",
    caseBg: "bg-purple-tint",
    statBar: "bg-white",
    ctaBg: "bg-brand",
    ctaText: "text-white",
  },
}[theme];
---

<div class={`group relative flex w-full flex-col ${className}`}>
  <!-- Capability card -->
  <div
    class:list={[
      "relative overflow-hidden rounded-card p-6 ring-1 ring-inset md:p-16",
      t.cardBg,
      t.ring,
    ]}
  >
    <!-- Card background (per-theme): lime fills the card; purple is an overlay bloom -->
    <img
      src={glow}
      alt=""
      aria-hidden="true"
      class:list={["pointer-events-none absolute z-0", t.glowFit]}
    />

    <div
      class="relative z-10 flex flex-col gap-10 md:h-[470px] md:flex-row md:items-stretch md:justify-between"
    >
      <!-- Left: text content -->
      <div class="flex flex-1 flex-col justify-between gap-10 md:max-w-[448px]">
        <!-- Header row: logo + title / optional certification badge -->
        <div class="flex items-start justify-between gap-4">
          <div class="flex items-center gap-4">
            <img
              src="/triage/logo-icon.svg"
              alt=""
              aria-hidden="true"
              class="h-[29px] w-[16px] shrink-0"
            />
            <span class="text-[28px]"
              >{title}</span
            >
          </div>
          {
            badge && (
              <div class="flex shrink-0 items-center gap-2">
                <img src={badge.icon} alt="" aria-hidden="true" class="h-9 w-9 shrink-0" />
                <img src={badge.text} alt={badge.alt} class="h-[26px] w-[79px]" />
              </div>
            )
          }
        </div>

        <!-- Headline -->
        <p
          class="font-serif font-normal text-3xl md:text-title"
        >
          {headline}
        </p>

        <!-- Proof points -->
        <ul class="flex flex-col gap-3">
          {
            points.map((point, i) => (
              <li
                class:list={[
                  "pb-3 text-lg",
                  i < points.length - 1 && "border-b border-black/24",
                ]}
              >
                <Fragment
                  set:html={`${point.before ?? ""}${point.strong ? `<span class="font-semibold">${point.strong}</span>` : ""}${point.rest ?? ""}`}
                />
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Right: media panel -->
      <div class="h-[470px] w-full shrink-0 rounded-[40px] bg-white md:w-[376px]">
      </div>
    </div>
  </div>

  <!-- Case bar -->
  <div
    class:list={[
      "flex flex-col items-center justify-between gap-8 overflow-hidden rounded-card px-6 py-8 md:h-[100px] md:flex-row md:px-16 md:py-0",
      t.caseBg,
    ]}
  >
    {
      logo ? (
        <img src={logo} alt={logoAlt} class="h-[54px] w-auto shrink-0" />
      ) : (
        <p class="max-w-[180px] shrink-0 text-sm font-semibold">
          {logoText}
        </p>
      )
    }

    <div class="flex items-center gap-4">
      <span
        class="relative inline-block font-serif text-title"
      >
        <span
          class:list={["absolute inset-x-0 bottom-2.5 z-0 h-2", t.statBar]}
          aria-hidden="true"></span>
        <span class="relative z-10">{stat}</span>
      </span>
      <p
        class="max-w-[16rem] text-sm font-semibold uppercase"
      >
        {statLabel}
      </p>
    </div>

    <!-- Visual CTA only — the whole card is the link (stretched <a> below). -->
    <div class="flex shrink-0 items-center rounded-full" aria-hidden="true">
      <span
        class:list={[
          "-mr-px rounded-[50px] px-6 py-3 text-sm font-semibold uppercase",
          t.ctaBg,
          t.ctaText,
        ]}
        >{cta.label}</span
      >
      <span
        class:list={[
          "flex size-10 items-center justify-center rounded-full",
          "transition-transform duration-300 ease-out group-hover:translate-x-1",
          t.ctaBg,
          t.ctaText,
        ]}
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path
            d="M5 12h14M13 6l6 6-6 6"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </span>
    </div>
  </div>

  <!-- Stretched link — makes the entire card clickable. -->
  <a href={cta.href} aria-label={cta.label} class="absolute inset-0 z-20 rounded-card"></a>
</div>
