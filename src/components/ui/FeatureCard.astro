---
/**
 * FeatureCard — a single capability card from the "AI Care Managers" grid.
 * A frosted white card holding a LabelPill at the top and a centered
 * description at the bottom, with the design's illustration filling the tall
 * body between them. Generic — content (including the illustration) comes from
 * props; pass no `image` to leave the body empty. Illustrations are decorative
 * (the description carries the meaning), so `imageAlt` defaults to "".
 *
 * `imageClass` sets the illustration's sizing/object-fit (it fully replaces the
 * default). `imageWrapperClass` fully replaces the body box's classes — the
 * default is an in-flow centered box; a card can instead pass an `absolute`
 * positioned box (e.g. an illustration that bleeds off one edge), which drops
 * it out of the flex flow so the label and description sit at top and bottom.
 *
 * `image` may also point at a video (`.webm`/`.mp4`), in which case it renders
 * as a muted, looping, autoplaying `<video>` instead of an `<img>` — the same
 * sizing/wrapper props apply. Videos are decorative, so they carry no caption.
 *
 * `image` may also point at a dotLottie animation (`.lottie`), rendered into a
 * looping, autoplaying `<canvas>` driven by @lottiefiles/dotlottie-web. The
 * canvas fills its wrapper; how the animation sits inside it is controlled by
 * `lottieFit` ("cover" trims to fill like the old videos, "contain" letterboxes
 * the whole frame). Lottie playback freezes while the card is offscreen.
 */
import LabelPill from "./LabelPill.astro";

interface Props {
  label: string;
  description: string;
  image?: string;
  imageAlt?: string;
  imageClass?: string;
  imageWrapperClass?: string;
  lottieFit?: "cover" | "contain" | "fill";
  class?: string;
}
const {
  label,
  description,
  image,
  imageAlt = "",
  imageClass = "max-h-full w-auto max-w-full object-contain",
  imageWrapperClass = "flex min-h-0 w-full flex-1 items-center justify-center",
  lottieFit = "cover",
  class: className = "",
} = Astro.props;

const isVideo = !!image && /\.(webm|mp4)$/i.test(image);
const isLottie = !!image && /\.lottie$/i.test(image);
---

<article
  class={`relative flex min-h-[340px] flex-col items-center justify-between gap-6 overflow-hidden rounded-[24px] bg-white p-8 backdrop-blur-[12px] md:h-[600px] md:gap-10 md:p-10 ${className}`}
>
  <LabelPill>{label}</LabelPill>
  {
    image && (
      <div class={imageWrapperClass}>
        {isLottie ? (
          <canvas
            class={imageClass}
            data-lottie={image}
            data-lottie-fit={lottieFit}
            aria-hidden="true"
          />
        ) : isVideo ? (
          <video
            src={image}
            class={imageClass}
            autoplay
            loop
            muted
            playsinline
            preload="auto"
            aria-hidden="true"
          />
        ) : (
          <img src={image} alt={imageAlt} class={imageClass} />
        )}
      </div>
    )
  }
  <p class="text-center text-md text-black">
    {description}
  </p>
</article>

<script>
  import { DotLottie } from "@lottiefiles/dotlottie-web";
  // Self-host the player wasm (bundled by Vite) instead of the default CDN, so
  // the cards animate without an external runtime fetch.
  import wasmUrl from "@lottiefiles/dotlottie-web/dotlottie-player.wasm?url";

  DotLottie.setWasmUrl(wasmUrl);

  // Build the player only once the card nears the viewport. The cards live well
  // below the fold, and a player constructed while its canvas is offscreen never
  // loads its animation — so we lazily init on first intersection (which also
  // saves decoding six animations the visitor may never scroll to). Cards in the
  // hidden breakpoint variant (display:none) have no box and simply never fire.
  const init = (canvas: HTMLCanvasElement) => {
    const src = canvas.dataset.lottie;
    if (!src || canvas.dataset.lottieReady) return;
    canvas.dataset.lottieReady = "1";
    const fit = (canvas.dataset.lottieFit || "contain") as
      | "cover"
      | "contain"
      | "fill";
    new DotLottie({
      canvas,
      src,
      loop: true,
      autoplay: true,
      layout: { fit, align: [0.5, 0.5] },
      // autoResize keeps the drawing buffer matched to the CSS box (and dpr);
      // freezeOnOffscreen pauses rendering while the card is scrolled away.
      renderConfig: { autoResize: true, freezeOnOffscreen: true },
    });
  };

  const canvases = document.querySelectorAll<HTMLCanvasElement>(
    "canvas[data-lottie]",
  );
  const io = new IntersectionObserver(
    (entries, obs) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        init(entry.target as HTMLCanvasElement);
        obs.unobserve(entry.target);
      });
    },
    { rootMargin: "200px" },
  );
  canvases.forEach((canvas) => io.observe(canvas));
</script>
