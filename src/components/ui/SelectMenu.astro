---
/**
 * SelectMenu — a custom dropdown matching the Figma "Menu" design (node
 * 9220:129): a field-styled trigger (identical to FormField's closed select)
 * that opens a white, `backdrop-blur`, `rounded-[16px]`, 32px-padded popup
 * listbox whose uppercase items are separated by faint hairlines. Native
 * `<select>` can't be styled this way, so this is a button + listbox pair
 * driven by a small script.
 *
 * `searchable` adds a search field pinned at the top of the menu that filters
 * the options as you type (used for the long country list); the option list
 * scrolls within `max-h`. Without it the menu is a plain list.
 *
 * It stays form-friendly: the chosen value lives in a hidden `<input>` (so it
 * appears in FormData / the mailto compose), and `required` is enforced by the
 * page's submit handler via the `data-required` flag on the wrapper. A
 * `required` field appends a ` *` marker to its placeholder, like FormField.
 *
 * Keyboard: Enter/Space/↓ open; ↑/↓ move the highlight; Enter select; Esc close.
 * When searchable, focus lands in the search box and the highlight is tracked
 * via `aria-activedescendant` so typing and arrowing work together.
 */
interface Props {
  name: string;
  placeholder: string;
  required?: boolean;
  options: string[];
  /** Show a filter field at the top of the menu (for long lists). */
  searchable?: boolean;
  /** Placeholder for the search field. */
  searchPlaceholder?: string;
  class?: string;
}
const {
  name,
  placeholder,
  required = false,
  options,
  searchable = false,
  searchPlaceholder = "Search",
  class: className = "",
} = Astro.props;

const label = required ? `${placeholder} *` : placeholder;
const listId = `${name}-listbox`;

// Mirrors FormField's control look so the closed state is indistinguishable.
const trigger =
  "flex w-full items-center justify-between gap-6 rounded-[16px] border border-black/50 bg-transparent px-6 py-3 text-left text-sm uppercase text-black/50 transition-colors focus:border-brand focus:outline-none aria-expanded:border-brand [[data-invalid]_&]:border-risk-high";

const optionClass =
  "flex w-full items-center py-3 text-left text-sm uppercase text-black transition-colors data-[active]:text-brand aria-selected:text-brand";
---

<div
  data-select-menu
  data-required={required ? "" : undefined}
  class={`relative ${className}`}
>
  <input type="hidden" name={name} value="" data-select-value />

  <button
    type="button"
    data-select-trigger
    aria-haspopup="listbox"
    aria-expanded="false"
    aria-controls={listId}
    class={trigger}
  >
    <span data-select-text>{label}</span>
    <svg
      data-select-chevron
      class="h-[6px] w-[10px] shrink-0 text-black/50 transition-transform duration-200"
      viewBox="0 0 10 6"
      fill="none"
      aria-hidden="true"
    >
      <path
        d="M5.295 5.29289C4.90447 5.68342 4.27131 5.68342 3.88078 5.29289L0.294998 1.70711C-0.334967 1.07714 0.111199 0 1.0021 0L8.17368 0C9.06458 0 9.51075 1.07714 8.88078 1.70711L5.295 5.29289Z"
        fill="currentColor"
      />
    </svg>
  </button>

  <div
    data-select-list
    class="pointer-events-none absolute left-0 top-full z-50 mt-2 flex max-h-[22rem] w-full origin-top -translate-y-2 scale-[0.98] flex-col rounded-[16px] bg-white/95 p-8 opacity-0 shadow-[0_24px_60px_-12px_rgba(31,31,31,0.22)] backdrop-blur-[20px] transition duration-200 ease-[cubic-bezier(0.33,1,0.68,1)] motion-reduce:transition-none data-[open]:pointer-events-auto data-[open]:translate-y-0 data-[open]:scale-100 data-[open]:opacity-100"
  >
    {
      searchable && (
        <div class="mb-4 flex shrink-0 items-center gap-3 border-b border-black/24 pb-3">
          <svg
            class="size-5 shrink-0 text-black/50"
            viewBox="0 0 24 24"
            fill="none"
            aria-hidden="true"
          >
            <path
              d="M17 17L21 21"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
            <path
              d="M19 11C19 6.58172 15.4183 3 11 3C6.58172 3 3 6.58172 3 11C3 15.4183 6.58172 19 11 19C15.4183 19 19 15.4183 19 11Z"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
          <input
            type="text"
            data-select-search
            placeholder={searchPlaceholder}
            aria-label={searchPlaceholder}
            autocomplete="off"
            aria-controls={listId}
            aria-expanded="true"
            class="w-full bg-transparent text-sm text-black placeholder:uppercase placeholder:text-black/50 focus:outline-none"
          />
        </div>
      )
    }

    <ul
      id={listId}
      role="listbox"
      aria-label={placeholder}
      data-select-listbox
      class="min-h-0 flex-1 overflow-y-auto overscroll-contain"
    >
      {
        options.map((opt, i) => (
          <li role="presentation" data-select-item>
            <button
              type="button"
              role="option"
              id={`${name}-opt-${i}`}
              aria-selected="false"
              tabindex="-1"
              data-select-option
              data-value={opt}
              class:list={[
                optionClass,
                searchable
                  ? "border-b border-black/24"
                  : i < options.length - 1
                    ? "border-b border-black/24"
                    : "pb-0",
              ]}
            >
              {opt}
            </button>
          </li>
        ))
      }
    </ul>

    {
      searchable && (
        <p
          data-select-empty
          hidden
          class="shrink-0 py-3 text-sm uppercase text-black/50"
        >
          No matches
        </p>
      )
    }
  </div>
</div>

<script>
  function initSelectMenu(root: HTMLElement) {
    const trigger = root.querySelector<HTMLButtonElement>("[data-select-trigger]");
    const list = root.querySelector<HTMLElement>("[data-select-list]");
    const valueInput = root.querySelector<HTMLInputElement>("[data-select-value]");
    const text = root.querySelector<HTMLElement>("[data-select-text]");
    const chevron = root.querySelector<SVGElement>("[data-select-chevron]");
    const search = root.querySelector<HTMLInputElement>("[data-select-search]");
    const empty = root.querySelector<HTMLElement>("[data-select-empty]");
    const options = Array.from(
      root.querySelectorAll<HTMLButtonElement>("[data-select-option]"),
    );
    const items = options.map((o) => o.closest("li") as HTMLElement);
    if (!trigger || !list || !valueInput || !text) return;

    const searchable = !!search;
    const placeholder = text.textContent ?? "";
    let active: HTMLButtonElement | null = null;

    const isOpen = () => list.hasAttribute("data-open");
    const visible = () => options.filter((_, i) => !items[i].hidden);

    const setActive = (opt: HTMLButtonElement | null) => {
      options.forEach((o) => o.removeAttribute("data-active"));
      active = opt;
      if (active) {
        active.setAttribute("data-active", "");
        active.scrollIntoView({ block: "nearest" });
        if (searchable) search!.setAttribute("aria-activedescendant", active.id);
        else active.focus();
      } else if (searchable) {
        search!.removeAttribute("aria-activedescendant");
      }
    };

    const move = (delta: number) => {
      const vis = visible();
      if (!vis.length) return setActive(null);
      const at = vis.indexOf(active as HTMLButtonElement);
      const next = at < 0 ? (delta > 0 ? 0 : vis.length - 1) : (at + delta + vis.length) % vis.length;
      setActive(vis[next]);
    };

    const filter = (q: string) => {
      const query = q.trim().toLowerCase();
      let any = false;
      options.forEach((o, i) => {
        const match = !query || (o.dataset.value ?? "").toLowerCase().includes(query);
        items[i].hidden = !match;
        if (match) any = true;
      });
      if (empty) empty.hidden = any;
      if (!active || active.closest("li")?.hidden) setActive(visible()[0] ?? null);
    };

    const open = () => {
      list.setAttribute("data-open", "");
      trigger.setAttribute("aria-expanded", "true");
      chevron?.style.setProperty("transform", "rotate(180deg)");
      const selected = options.find((o) => o.getAttribute("aria-selected") === "true");
      if (searchable) {
        search!.value = "";
        filter("");
        requestAnimationFrame(() => search!.focus());
        setActive(
          selected && !selected.closest("li")?.hidden ? selected : visible()[0] ?? null,
        );
      } else {
        setActive(selected ?? options[0] ?? null);
      }
    };

    const close = () => {
      list.removeAttribute("data-open");
      trigger.setAttribute("aria-expanded", "false");
      chevron?.style.removeProperty("transform");
      setActive(null);
    };

    const choose = (opt: HTMLButtonElement) => {
      options.forEach((o) => o.setAttribute("aria-selected", "false"));
      opt.setAttribute("aria-selected", "true");
      valueInput.value = opt.dataset.value ?? "";
      text.textContent = opt.dataset.value ?? placeholder;
      text.classList.remove("text-black/50");
      root.removeAttribute("data-invalid");
      close();
      trigger.focus();
    };

    trigger.addEventListener("click", () => (isOpen() ? close() : open()));

    trigger.addEventListener("keydown", (e) => {
      if (e.key === "ArrowDown" || e.key === "Enter" || e.key === " ") {
        e.preventDefault();
        isOpen() ? move(1) : open();
      } else if (e.key === "ArrowUp") {
        e.preventDefault();
        if (!isOpen()) open();
        else move(-1);
      } else if (e.key === "Escape") {
        close();
      }
    });

    if (searchable) {
      search!.addEventListener("input", () => filter(search!.value));
      search!.addEventListener("keydown", (e) => {
        if (e.key === "ArrowDown") {
          e.preventDefault();
          move(1);
        } else if (e.key === "ArrowUp") {
          e.preventDefault();
          move(-1);
        } else if (e.key === "Enter") {
          e.preventDefault();
          if (active) choose(active);
        } else if (e.key === "Escape") {
          e.preventDefault();
          close();
          trigger.focus();
        }
      });
    }

    options.forEach((opt) => {
      opt.addEventListener("click", () => choose(opt));
      opt.addEventListener("mousemove", () => {
        if (active !== opt) setActive(opt);
      });
      if (!searchable) {
        opt.addEventListener("keydown", (e) => {
          if (e.key === "ArrowDown") {
            e.preventDefault();
            move(1);
          } else if (e.key === "ArrowUp") {
            e.preventDefault();
            move(-1);
          } else if (e.key === "Enter" || e.key === " ") {
            e.preventDefault();
            choose(opt);
          } else if (e.key === "Escape") {
            e.preventDefault();
            close();
            trigger.focus();
          }
        });
      }
    });

    // Close on outside click.
    document.addEventListener("click", (e) => {
      if (!root.contains(e.target as Node)) close();
    });
  }

  document
    .querySelectorAll<HTMLElement>("[data-select-menu]")
    .forEach(initSelectMenu);
</script>
