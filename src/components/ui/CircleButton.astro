---
/**
 * CircleButton — large circular dotted button with a downward chevron.
 * Faithful to the design's "Frame 2147224426" (134×134): a dotted ring
 * (round-capped dashes) enclosing a down arrow.
 * Renders an <a> when `href` is set, otherwise a <button>.
 */
interface Props {
  href?: string;
  label?: string;
  class?: string;
  [key: string]: unknown;
}
const { href, label = "Scroll to explore", class: className = "", ...rest } =
  Astro.props;

const classes = [
  "group inline-flex size-[134px] items-center justify-center text-black",
  className,
].join(" ");
const Tag = href ? "a" : "button";
---

<Tag class={classes} href={href} aria-label={label} {...rest}>
  <svg
    class="size-[134px]"
    viewBox="0 0 134 134"
    fill="none"
    aria-hidden="true"
  >
    <rect
      x="133"
      y="1"
      width="132"
      height="132"
      rx="66"
      transform="rotate(90 133 1)"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-dasharray="0.01 8"
      class="group-hover:[stroke-dasharray:420_0] group-hover:[stroke-width:1]"></rect>
    <mask
      id="circlebtn-arrow"
      style="mask-type:alpha"
      maskUnits="userSpaceOnUse"
      x="53"
      y="53"
      width="28"
      height="28"
    >
      <rect x="53" y="53" width="28" height="28" fill="#D9D9D9"></rect>
    </mask>
    <g mask="url(#circlebtn-arrow)">
      <path
        d="M67 74.5833L67 58.8333"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"></path>
      <path
        d="M60 68.1666C60 68.1666 65.1554 75.1666 67 75.1666C68.8447 75.1666 74 68.1666 74 68.1666"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"></path>
    </g>
  </svg>
</Tag>
