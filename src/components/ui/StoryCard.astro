---
/**
 * StoryCard — a single customer-story card on the "Our Customers" grid.
 *
 * One generic, content-free component covers every card variant in the design:
 *   type="highlighted" — full-width hero card: lavender bloom, big Lora title,
 *                        two stats, and a photo panel with an overlaid CTA.
 *   type="story"       — logo + Lora title + one stat + CTA(s). Pass `photo` to
 *                        render it as a composite (text pane beside a photo).
 *   type="quote"       — logo + pull-quote + author/role. `photo` → composite.
 *   type="logo"        — a single centered partner logo (a "brand" tile).
 *
 * `tone` sets the surface: white / lavender (filled) / outline (transparent +
 * hairline). Content comes entirely from src/data/customers.json; the card
 * stays generic. The solid CTA reuses the filled ArrowCircle (pill + arrow),
 * matching the rest of the site.
 */
import ArrowCircle from "./ArrowCircle.astro";

interface Stat {
  value: string;
  label: string;
}
interface Cta {
  label: string;
  href?: string;
  style?: "solid" | "outline";
}
interface Props {
  type?: "story" | "quote" | "logo" | "highlighted";
  tone?: "white" | "lavender" | "outline";
  logo?: string;
  logoAlt?: string;
  confidential?: boolean;
  title?: string;
  stat?: Stat;
  stats?: Stat[];
  quote?: string;
  author?: string;
  role?: string;
  cta?: Cta;
  ctas?: Cta[];
  photo?: string;
  photoAlt?: string;
  class?: string;
}
const {
  type = "story",
  tone = "white",
  logo,
  logoAlt = "",
  confidential = false,
  title,
  stat,
  stats = [],
  quote,
  author,
  role,
  cta,
  ctas,
  photo,
  photoAlt = "",
  class: className = "",
} = Astro.props;

const toneClass: Record<string, string> = {
  // White cards drop their fill on hover but keep a hairline outline (the
  // border is always present, only its colour transitions — so nothing shifts).
  white:
    "bg-white border border-transparent transition-colors duration-300 ease-out hover:bg-transparent hover:border-purple-100",
  lavender: "bg-lavender border border-purple-100",
  outline: "border border-purple-100",
};

const ctaList: Cta[] = ctas ?? (cta ? [cta] : []);
const composite = !!photo && type !== "highlighted";
const base = `relative overflow-hidden rounded-card md:h-[510px] ${toneClass[tone]} ${className}`;
---

{
  type === "highlighted" && (
    <article class={`flex flex-col bg-purple-200/40 md:h-[510px] md:flex-row ${className} relative overflow-hidden rounded-card`}>
      <img
        src="/customers/swoosh.svg"
        alt=""
        aria-hidden="true"
        class="pointer-events-none absolute -right-[6%] top-1/2 h-[150%] w-[78%] -translate-y-1/2"
      />
      <div class="relative flex flex-1 flex-col justify-between gap-10 p-10 md:pr-4">
        <header class="flex flex-col gap-10">
          {logo && (
            <img src={logo} alt={logoAlt} class="h-8 w-auto max-w-[185px] self-start object-contain object-left" />
          )}
          <h2 class="font-serif text-[clamp(2rem,3.4vw,48px)] font-normal leading-[1.1] tracking-[-0.02em] text-black md:max-w-[486px]">
            {title}
          </h2>
        </header>
        <div class="flex flex-col gap-6 sm:flex-row sm:gap-4">
          {stats.map((s) => (
            <div class="flex flex-1 flex-col gap-4 border-t border-purple-200 pt-6">
              <span class="font-sans text-[clamp(2.25rem,4vw,52px)] font-normal leading-[1.05] tracking-[-0.03em] text-black">
                {s.value}
              </span>
              <p class="max-w-[180px] text-sm font-semibold uppercase leading-[1.25] text-black">
                {s.label}
              </p>
            </div>
          ))}
        </div>
      </div>
      <div class="relative p-6 md:flex md:flex-1 md:items-center">
        <div class="relative h-60 w-full md:h-full md:flex-1">
          <img src={photo} alt={photoAlt} class="h-full w-full rounded-[24px] object-cover" />
          {ctaList[0] && (
            <span class="group absolute bottom-4 right-4 inline-flex items-center">
              <a
                href={ctaList[0].href}
                class="flex h-10 items-center rounded-[50px] bg-brand px-6 text-sm font-semibold uppercase tracking-[-0.01em] text-white"
              >
                {ctaList[0].label}
              </a>
              <ArrowCircle variant="filled" href={ctaList[0].href} label={ctaList[0].label} detach class="-ml-px" />
            </span>
          )}
        </div>
      </div>
    </article>
  )
}

{
  type === "logo" && (
    <article class={`flex items-center justify-center p-10 ${base}`}>
      {logo && <img src={logo} alt={logoAlt} class="h-12 w-auto max-w-[185px] object-contain" />}
    </article>
  )
}

{
  (type === "story" || type === "quote") && (
    <article class={composite ? `flex flex-col md:h-[510px] md:flex-row ${base}` : `flex flex-col justify-between gap-8 p-10 ${base}`}>
      {/* Text pane */}
      <div class={composite ? "flex flex-1 flex-col justify-between gap-8 p-10 md:pr-4" : "contents"}>
        <header class="flex flex-col gap-6">
          {confidential ? (
            <span class="flex items-center gap-2 self-start text-sm font-semibold uppercase tracking-[-0.01em] text-black">
              <svg viewBox="0 0 24 24" class="size-6 shrink-0" fill="none" aria-hidden="true">
                <path d="M19.439 15.439C20.364 14.521 21.078 13.609 21.544 12.955C21.848 12.529 22 12.316 22 12C22 11.685 21.848 11.471 21.544 11.045C20.178 9.129 16.689 5 12 5C11.092 5 10.229 5.155 9.418 5.418M6.747 6.747C4.731 8.107 3.242 9.943 2.456 11.045C2.152 11.471 2 11.685 2 12C2 12.316 2.152 12.529 2.456 12.955C3.822 14.871 7.311 19 12 19C13.991 19 15.738 18.256 17.181 17.181" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M9.853 9.853C9.327 10.388 9 11.156 9 12C9 13.657 10.343 15 12 15C12.844 15 13.612 14.673 14.147 14.147M3 3L21 21" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              Confidential
            </span>
          ) : (
            logo && (
              <img src={logo} alt={logoAlt} class="h-8 w-auto max-w-[185px] self-start object-contain object-left" />
            )
          )}
          {type === "story" ? (
            <h3 class="font-serif text-[clamp(1.75rem,2.4vw,32px)] font-normal leading-[1.2] tracking-[-0.02em] text-black">
              {title}
            </h3>
          ) : (
            <p class="text-[clamp(1.125rem,1.6vw,20px)] font-normal leading-[1.2] tracking-[-0.01em] text-black">
              &ldquo;{quote}&rdquo;
            </p>
          )}
        </header>

        {type === "story" ? (
          <div class="flex flex-col gap-8">
            {stat && (
              <div class="flex flex-col gap-4 border-t border-black/15 pt-6">
                <span class="font-sans text-[clamp(2rem,3vw,40px)] font-normal leading-[1.05] tracking-[-0.02em] text-black">
                  {stat.value}
                </span>
                <p class="max-w-[260px] text-sm font-semibold uppercase leading-[1.25] text-black">
                  {stat.label}
                </p>
              </div>
            )}
            <div class="flex flex-wrap items-center justify-end gap-3">
              {ctaList.map((c) =>
                c.style === "outline" ? (
                  <a
                    href={c.href}
                    class="inline-flex h-10 items-center rounded-[40px] border border-black px-6 text-sm font-medium uppercase tracking-[-0.02em] text-black transition-colors hover:bg-black hover:text-white"
                  >
                    {c.label}
                  </a>
                ) : (
                  <span class="group inline-flex items-center">
                    <a
                      href={c.href}
                      class="flex h-10 items-center rounded-[50px] bg-brand px-6 text-sm font-semibold uppercase tracking-[-0.01em] text-white"
                    >
                      {c.label}
                    </a>
                    <ArrowCircle variant="filled" href={c.href} label={c.label} detach class="-ml-px" />
                  </span>
                ),
              )}
            </div>
          </div>
        ) : (
          <div class="flex flex-col gap-1 font-medium leading-[1.3] text-black">
            <span class="text-sm uppercase tracking-[-0.01em]">{author}</span>
            <span class="text-base tracking-[-0.01em]">{role}</span>
          </div>
        )}
      </div>

      {/* Photo pane (composite only) */}
      {composite && (
        <div class="p-6 md:flex md:flex-1 md:items-center">
          <img
            src={photo}
            alt={photoAlt}
            class="h-60 w-full rounded-[24px] object-cover md:h-full md:flex-1"
          />
        </div>
      )}
    </article>
  )
}
