---
/**
 * StoryCard — a single customer-story card on the "Our Customers" grid.
 *
 * One generic, content-free component covers every card variant in the design:
 *   type="highlighted" — full-width hero card: lavender bloom, big Lora title,
 *                        two stats, and a photo panel with an overlaid CTA.
 *   type="story"       — logo + Lora title + one stat + CTA(s). Pass `photo` to
 *                        render it as a composite (text pane beside a photo).
 *   type="quote"       — logo + pull-quote + author/role. `photo` → composite.
 *   type="logo"        — a single centered partner logo (a "brand" tile).
 *
 * `tone` sets the surface: white / lavender (filled) / outline (transparent +
 * hairline). Content comes entirely from src/data/customers.json; the card
 * stays generic. The solid CTA reuses the filled ArrowCircle (pill + arrow),
 * matching the rest of the site.
 */
import ArrowCircle from "./ArrowCircle.astro";

interface Stat {
  value: string;
  label: string;
}
interface Cta {
  label: string;
  href?: string;
  style?: "solid" | "outline";
}
interface Props {
  type?: "story" | "quote" | "logo" | "highlighted";
  tone?: "white" | "lavender" | "outline";
  logo?: string;
  logoAlt?: string;
  confidential?: boolean;
  title?: string;
  stat?: Stat;
  statWidth?: string;
  stats?: Stat[];
  quote?: string;
  author?: string;
  role?: string;
  cta?: Cta;
  ctas?: Cta[];
  photo?: string;
  photoAlt?: string;
  class?: string;
}
const {
  type = "story",
  tone = "white",
  logo,
  logoAlt = "",
  confidential = false,
  title,
  stat,
  statWidth = "max-w-[260px]",
  stats = [],
  quote,
  author,
  role,
  cta,
  ctas,
  photo,
  photoAlt = "",
  class: className = "",
} = Astro.props;

const toneClass: Record<string, string> = {
  // White cards drop their fill on hover but keep a hairline outline (the
  // border is always present, only its colour transitions — so nothing shifts).
  white:
    "bg-white border border-transparent transition-colors duration-300 ease-out hover:bg-transparent hover:border-purple-100",
  lavender: "bg-lavender border border-purple-100",
  outline: "border border-purple-100",
};

const ctaList: Cta[] = ctas ?? (cta ? [cta] : []);
// External links (off-site press releases, etc.) open in a new tab.
const isExternal = (href?: string) => !!href?.startsWith("http");
// The card's primary action (the solid CTA) becomes a stretched link that makes
// the whole card clickable; any secondary "outline" CTA stays its own link on
// top. `clickable` gates that behaviour to cards that actually have a target.
const primary = ctaList.find((c) => c.style !== "outline") ?? ctaList[0];
// Only single-CTA cards become fully clickable via the stretched overlay. Cards
// with two buttons keep each button as its own independent link instead, so the
// card surface itself isn't a link.
const clickable = ctaList.length === 1 && !!primary?.href;
const composite = !!photo && type !== "highlighted";
const base = `relative overflow-hidden rounded-card lg:min-h-[510px] ${toneClass[tone]} ${className}`;

// Stat numbers are a fixed 38px on mobile (Figma's numbers opt out of the fluid
// type scale — see the design annotation), with tighter 1.05 leading / -4%
// tracking. On lg+ they hand back to the page's fluid heading token.
const statValue =
  "font-sans font-normal text-black text-[2.375rem] leading-[1.05] tracking-[-0.04em] lg:leading-[1.2] lg:tracking-[-0.02em]";

// A title or stat label may encode an editorial line break with "\n". It renders
// as a <br> that only shows from md up, so the text wraps like the design on
// tablet and desktop while staying full-width and wrapping naturally on mobile.
const titleLines = (title ?? "").split("\n");
const statLabelLines = (stat?.label ?? "").split("\n");
---

{
  type === "highlighted" && (
    <article class={`group flex flex-col bg-purple-200/40 lg:min-h-[510px] lg:flex-row ${className} relative overflow-hidden rounded-card`}>
      <img
        src="/customers/swoosh.svg"
        alt=""
        aria-hidden="true"
        class="pointer-events-none absolute left-1/2 -top-[45%] h-[161%] w-[404%] -translate-x-1/2 lg:left-auto lg:-right-[6%] lg:top-1/2 lg:h-[150%] lg:w-[78%] lg:translate-x-0 lg:-translate-y-1/2"
      />
      <div class="relative flex flex-1 flex-col justify-between gap-8 px-6 py-8 lg:gap-10 lg:p-10 lg:pr-4">
        <header class="flex flex-col gap-8 lg:gap-10">
          {logo && (
            <img src={logo} alt={logoAlt} class="h-12 w-auto max-w-[185px] self-start object-contain object-left lg:h-8" />
          )}
          <h2 class="font-serif text-h6 font-normal text-black lg:max-w-[486px]">
            {title}
          </h2>
        </header>
        <div class="flex flex-row gap-4">
          {stats.map((s) => (
            <div class="flex flex-1 flex-col gap-4 border-t border-purple-200 pt-6">
              <span class={`${statValue} lg:text-h5`}>
                {s.value}
              </span>
              <p class="max-w-[180px] text-sm font-semibold uppercase text-black">
                {s.label}
              </p>
            </div>
          ))}
        </div>
      </div>
      <div class="flex flex-col gap-8 p-6 lg:flex-row lg:flex-1 lg:items-center lg:gap-0">
        <div class="relative h-[170px] w-full lg:h-full lg:flex-1">
          <img src={photo} alt={photoAlt} class="h-full w-full rounded-[24px] object-cover" />
          {/* Desktop: the CTA is overlaid on the photo's bottom-right. */}
          {ctaList[0] && (
            <span class="absolute bottom-4 right-4 hidden items-center lg:inline-flex" aria-hidden="true">
              <span class="flex h-10 items-center rounded-[50px] bg-brand px-6 text-sm font-semibold uppercase text-white">
                {ctaList[0].label}
              </span>
              <ArrowCircle variant="filled" label={ctaList[0].label} decorative detach class="-ml-px" />
            </span>
          )}
        </div>
        {/* Mobile: the CTA sits in its own row below the photo, right-aligned.
            `relative z-10` lifts it above the decorative swoosh (an absolutely
            positioned sibling that would otherwise paint over and wash it out). */}
        {ctaList[0] && (
          <span class="relative z-10 flex w-full items-center justify-end lg:hidden" aria-hidden="true">
            <span class="flex h-10 items-center rounded-[50px] bg-brand px-6 text-sm font-semibold uppercase text-white">
              {ctaList[0].label}
            </span>
            <ArrowCircle variant="filled" label={ctaList[0].label} decorative detach class="-ml-px" />
          </span>
        )}
      </div>
      {clickable && (
        <a
          href={primary.href}
          target={isExternal(primary.href) ? "_blank" : undefined}
          rel={isExternal(primary.href) ? "noopener noreferrer" : undefined}
          aria-label={primary.label}
          class="absolute inset-0 z-20 rounded-card"
        />
      )}
    </article>
  )
}

{
  type === "logo" && (
    <article class={`flex items-center justify-center p-10 ${base}`}>
      {logo && <img src={logo} alt={logoAlt} class="h-12 w-auto max-w-[185px] object-contain" />}
    </article>
  )
}

{
  /* Composite story card (a story with a photo). Stacks logo → title → stat →
     photo → CTAs up to lg; on lg+ it's a 2-col grid: the text column (logo +
     title top, stat + CTAs pinned bottom) beside a full-height photo. The grid
     placement reproduces the desktop flex layout while letting the photo sit
     between the stat and the CTAs on the stacked layout, matching the design. */
  type === "story" && composite && (
    <article class={`group relative flex flex-col overflow-hidden rounded-card lg:grid lg:min-h-[510px] lg:grid-cols-2 lg:grid-rows-[auto_1fr_auto_auto] ${toneClass[tone]} ${className}`}>
      <header class="flex flex-col gap-6 px-6 pt-8 lg:col-start-1 lg:row-start-1 lg:px-10 lg:pr-4 lg:pt-10">
        {logo && (
          <img src={logo} alt={logoAlt} class="h-12 w-auto max-w-[185px] self-start object-contain object-left lg:h-8" />
        )}
        <h3 class="font-serif text-xlg font-normal text-black">
          {titleLines.map((line, i) =>
            i === 0 ? (
              line
            ) : (
              <Fragment>
                <br class="hidden md:block" />
                {" "}
                {line}
              </Fragment>
            ),
          )}
        </h3>
      </header>

      {stat && (
        <div class="px-6 pt-8 lg:col-start-1 lg:row-start-3 lg:px-10 lg:pr-4 lg:pt-0">
          <div class="flex flex-col gap-4 border-t border-black/15 pt-6">
            <span class={`${statValue} lg:text-h6`}>{stat.value}</span>
            <p class={`text-sm font-semibold uppercase text-black ${statWidth}`}>
              {statLabelLines.map((line, i) =>
                i === 0 ? (
                  line
                ) : (
                  <Fragment>
                    <br class="hidden md:block" />
                    {" "}
                    {line}
                  </Fragment>
                ),
              )}
            </p>
          </div>
        </div>
      )}

      <div class="px-6 pt-14 lg:col-start-2 lg:row-span-full lg:flex lg:items-center lg:p-6">
        <img src={photo} alt={photoAlt} class="h-60 w-full rounded-[24px] object-cover lg:h-full lg:flex-1" />
      </div>

      <div class="flex flex-wrap items-center justify-end gap-3 px-6 pb-8 pt-8 lg:col-start-1 lg:row-start-4 lg:px-10 lg:pb-10 lg:pr-4">
        {ctaList.map((c) =>
          c.style === "outline" ? (
            <a
              href={c.href}
              target={isExternal(c.href) ? "_blank" : undefined}
              rel={isExternal(c.href) ? "noopener noreferrer" : undefined}
              class="relative z-30 inline-flex h-10 items-center rounded-[40px] border border-black px-6 text-sm font-medium uppercase text-black transition-colors hover:bg-black hover:text-white group-hover:bg-black group-hover:text-white"
            >
              {c.label}
            </a>
          ) : clickable ? (
            <span class="inline-flex items-center" aria-hidden="true">
              <span class="flex h-10 items-center rounded-[50px] bg-brand px-6 text-sm font-semibold uppercase text-white">
                {c.label}
              </span>
              <ArrowCircle variant="filled" label={c.label} decorative detach class="-ml-px" />
            </span>
          ) : (
            <span class="inline-flex items-center">
              <a
                href={c.href}
                target={isExternal(c.href) ? "_blank" : undefined}
                rel={isExternal(c.href) ? "noopener noreferrer" : undefined}
                class="flex h-10 items-center rounded-[50px] bg-brand px-6 text-sm font-semibold uppercase text-white"
              >
                {c.label}
              </a>
              <ArrowCircle variant="filled" href={c.href} label={c.label} detach class="-ml-px" />
            </span>
          ),
        )}
      </div>

      {clickable && (
        <a
          href={primary.href}
          target={isExternal(primary.href) ? "_blank" : undefined}
          rel={isExternal(primary.href) ? "noopener noreferrer" : undefined}
          aria-label={primary.label}
          class="absolute inset-0 z-20 rounded-card"
        />
      )}
    </article>
  )
}

{
  (type === "quote" || (type === "story" && !composite)) && (
    <article class={composite ? `group flex flex-col lg:min-h-[510px] lg:flex-row ${base}` : `group flex flex-col justify-between gap-14 px-6 py-8 lg:gap-8 lg:p-10 ${base}`}>
      {/* Text pane */}
      <div class={composite ? "flex flex-1 flex-col justify-between gap-8 px-6 py-8 lg:p-10 lg:pr-4" : "contents"}>
        <header class="flex flex-col gap-6">
          {confidential ? (
            <span class="flex items-center gap-2 self-start text-sm font-semibold uppercase text-black">
              <svg viewBox="0 0 24 24" class="size-6 shrink-0" fill="none" aria-hidden="true">
                <path d="M19.439 15.439C20.364 14.521 21.078 13.609 21.544 12.955C21.848 12.529 22 12.316 22 12C22 11.685 21.848 11.471 21.544 11.045C20.178 9.129 16.689 5 12 5C11.092 5 10.229 5.155 9.418 5.418M6.747 6.747C4.731 8.107 3.242 9.943 2.456 11.045C2.152 11.471 2 11.685 2 12C2 12.316 2.152 12.529 2.456 12.955C3.822 14.871 7.311 19 12 19C13.991 19 15.738 18.256 17.181 17.181" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M9.853 9.853C9.327 10.388 9 11.156 9 12C9 13.657 10.343 15 12 15C12.844 15 13.612 14.673 14.147 14.147M3 3L21 21" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              Confidential
            </span>
          ) : (
            logo && (
              <img src={logo} alt={logoAlt} class="h-12 w-auto max-w-[185px] self-start object-contain object-left lg:h-8" />
            )
          )}
          {type === "story" ? (
            <h3 class="font-serif text-xlg font-normal text-black">
              {titleLines.map((line, i) =>
                i === 0 ? (
                  line
                ) : (
                  <Fragment>
                    <br class="hidden md:block" />
                    {" "}
                    {line}
                  </Fragment>
                ),
              )}
            </h3>
          ) : (
            <p class="text-[clamp(1.125rem,1.6vw,20px)] font-normal text-black">
              &ldquo;{quote}&rdquo;
            </p>
          )}
        </header>

        {type === "story" ? (
          <div class="flex flex-col gap-8">
            {stat && (
              <div class="flex flex-col gap-4 border-t border-black/15 pt-6">
                <span class={`${statValue} lg:text-h6`}>
                  {stat.value}
                </span>
                <p class={`text-sm font-semibold uppercase text-black ${statWidth}`}>
                  {statLabelLines.map((line, i) =>
                    i === 0 ? (
                      line
                    ) : (
                      <Fragment>
                        <br class="hidden md:block" />
                        {" "}
                        {line}
                      </Fragment>
                    ),
                  )}
                </p>
              </div>
            )}
            <div class="flex flex-wrap items-center justify-end gap-3">
              {ctaList.map((c) =>
                c.style === "outline" ? (
                  // Secondary action — its own link, kept above the stretched
                  // overlay (z-30) so it stays independently clickable, and lit
                  // on whole-card hover (group-hover) as well as direct hover.
                  <a
                    href={c.href}
                    target={isExternal(c.href) ? "_blank" : undefined}
                    rel={isExternal(c.href) ? "noopener noreferrer" : undefined}
                    class="relative z-30 inline-flex h-10 items-center rounded-[40px] border border-black px-6 text-sm font-medium uppercase text-black transition-colors hover:bg-black hover:text-white group-hover:bg-black group-hover:text-white"
                  >
                    {c.label}
                  </a>
                ) : clickable ? (
                  // Primary action — visual only; the stretched <a> below is the
                  // real link, so the entire card is clickable.
                  <span class="inline-flex items-center" aria-hidden="true">
                    <span class="flex h-10 items-center rounded-[50px] bg-brand px-6 text-sm font-semibold uppercase text-white">
                      {c.label}
                    </span>
                    <ArrowCircle variant="filled" label={c.label} decorative detach class="-ml-px" />
                  </span>
                ) : (
                  <span class="inline-flex items-center">
                    <a
                      href={c.href}
                      target={isExternal(c.href) ? "_blank" : undefined}
                      rel={isExternal(c.href) ? "noopener noreferrer" : undefined}
                      class="flex h-10 items-center rounded-[50px] bg-brand px-6 text-sm font-semibold uppercase text-white"
                    >
                      {c.label}
                    </a>
                    <ArrowCircle variant="filled" href={c.href} label={c.label} detach class="-ml-px" />
                  </span>
                ),
              )}
            </div>
          </div>
        ) : (
          <div class="flex flex-col gap-1 text-black">
            <span class="text-sm font-semibold uppercase">{author}</span>
            <span class="text-base font-medium">{role}</span>
          </div>
        )}
      </div>

      {/* Photo pane (composite only) */}
      {composite && (
        <div class="p-6 lg:flex lg:flex-1 lg:items-center">
          <img
            src={photo}
            alt={photoAlt}
            class="h-60 w-full rounded-[24px] object-cover lg:h-full lg:flex-1"
          />
        </div>
      )}

      {/* Stretched link — makes the entire card clickable (primary action). */}
      {clickable && (
        <a
          href={primary.href}
          target={isExternal(primary.href) ? "_blank" : undefined}
          rel={isExternal(primary.href) ? "noopener noreferrer" : undefined}
          aria-label={primary.label}
          class="absolute inset-0 z-20 rounded-card"
        />
      )}
    </article>
  )
}
