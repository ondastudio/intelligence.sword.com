---
/**
 * Button — pill-shaped action, extracted from the design's nav + CTA pills.
 *
 * Variants:
 *   solid  — purple background, white text (primary CTA, e.g. "Book a meeting")
 *   glass  — translucent blur, black text (nav menu items)
 *
 * Renders an <a> when `href` is set, otherwise a <button>. Set `caret` to show
 * a dropdown chevron (used by the "Solution" nav item).
 */
interface Props {
  variant?: "solid" | "glass";
  /** "dark" — for light backgrounds (default); "light" — for dark backgrounds. */
  tone?: "dark" | "light";
  href?: string;
  caret?: boolean;
  type?: "button" | "submit" | "reset";
  class?: string;
  [key: string]: unknown;
}

const {
  variant = "solid",
  tone = "dark",
  href,
  caret = false,
  type = "button",
  class: className = "",
  ...rest
} = Astro.props;

const base =
  "inline-flex h-10 items-center justify-center gap-2 whitespace-nowrap rounded-full px-6 text-sm font-semibold uppercase transition-colors";

const variants: Record<string, Record<string, string>> = {
  solid: {
    dark: "bg-brand text-white",
    light: "bg-accent text-ink",
  },
  glass: {
    dark: "text-black hover:bg-ink-wash-hover",
    light: "text-white hover:bg-white/10",
  },
};

const classes = [base, variants[variant][tone], className].join(" ");
const Tag = href ? "a" : "button";
---

<Tag class={classes} href={href} type={href ? undefined : type} {...rest}>
  <slot />
  {
    caret && (
      <svg
        class="h-[6px] w-[10px]"
        viewBox="0 0 9.17558 5.58579"
        fill="none"
        aria-hidden="true"
      >
        <path
          d="M5.2949 5.29289C4.90437 5.68342 4.27121 5.68342 3.88068 5.29289L0.294898 1.70711C-0.335067 1.07714 0.111099 0 1.002 0H8.17358C9.06448 0 9.51065 1.07714 8.88068 1.70711L5.2949 5.29289Z"
          fill="currentColor"
        />
      </svg>
    )
  }
</Tag>
