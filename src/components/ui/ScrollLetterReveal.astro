---
/**
 * ScrollLetterReveal — scroll-driven letter-by-letter text reveal.
 *
 * Each character starts a muted gray (`--color-ink-muted`) and "lights up" to
 * solid black as a reading head — a band that tracks scroll progress through the
 * block — sweeps across it in reading order. The effect is gated on motion + JS;
 * without either, every letter renders solid black (the design end state), so
 * the message is never hidden or faint.
 *
 * Content is passed as `paragraphs`: an array of paragraphs, each an array of
 * segments ({ text, bold? }). The component keeps whole words together (for
 * natural line-breaking) but splits every word into per-character spans so each
 * letter can be lit independently.
 *
 * Used by AboutStory (manifesto block) and the home Intro statement.
 */
type Segment = { text: string; bold?: boolean };

interface Props {
  /** Paragraphs of styled text segments, rendered in order. */
  paragraphs: Segment[][];
  /** Typography classes for the measured block (font, size, leading, align). */
  class?: string;
  /** Class added to every paragraph except the last (vertical rhythm). */
  spacingClass?: string;
  /** Class applied to bold segments. */
  boldClass?: string;
  /** Initial (un-revealed) letter color. Defaults to `--color-ink-muted`. The
   *  scrubber reads this back from the computed style, so any CSS color works. */
  mutedColor?: string;
}

const {
  paragraphs,
  class: className = "",
  spacingClass = "",
  boldClass = "font-semibold",
  mutedColor,
} = Astro.props;

// Flatten to a running letter index so the scrubber can light characters in
// reading order across every paragraph. Whitespace stays as plain text nodes so
// it remains a line-break opportunity; each word is wrapped (nowrap) so its
// letters never split across lines.
let letterIndex = 0;
const renderedParagraphs = paragraphs.map((segments) =>
  segments.map((segment) => {
    const tokens = segment.text.split(/(\s+)/).filter((t) => t.length > 0);
    return tokens.map((token) => {
      const isSpace = /^\s+$/.test(token);
      return {
        isSpace,
        token,
        bold: segment.bold ?? false,
        chars: isSpace
          ? []
          : Array.from(token).map((ch) => ({ ch, index: letterIndex++ })),
      };
    });
  }),
);
const letterCount = letterIndex;
---

<div
  data-letter-reveal
  class:list={["letter-reveal", className]}
  style={`--letter-count:${letterCount}${mutedColor ? `;--lr-muted:${mutedColor}` : ""}`}
>
  {
    renderedParagraphs.map((segments, p) => (
      <p class:list={[p < renderedParagraphs.length - 1 && spacingClass]}>
        {segments.map((tokens) =>
          tokens.map((tok) =>
            tok.isSpace ? (
              tok.token
            ) : (
              // prettier-ignore — no whitespace inside the word/char spans, or letters space out
              <span class="lr-word" class:list={[tok.bold && boldClass]}>{tok.chars.map(({ ch, index }) => (
                <span class="lr-char" style={`--i:${index}`}>{ch}</span>
              ))}</span>
            ),
          ),
        )}
      </p>
    ))
  }
</div>

<style>
  /* Keep each word's letters together; letters are inline so kerning matches. */
  .lr-word {
    white-space: nowrap;
  }
  .lr-char {
    display: inline;
  }

  /* Base = design end state: fully resolved black text (no-JS / reduced-motion
     readers get the finished message immediately). */
  @media (prefers-reduced-motion: no-preference) {
    /* Enhanced: letters start a muted gray; the scrubber darkens them to black
       per-frame. Setting the muted start state here (gated on .js) keeps the
       first paint flash-free before the rAF loop takes over. */
    :global(html.js) .lr-char {
      color: var(--lr-muted, var(--color-ink-muted));
      will-change: color;
    }
  }
</style>

<script>
  // Scroll-driven letter-by-letter reveal. A "reading head" advances through the
  // character list as the block travels up the viewport; each letter darkens
  // from muted gray to solid black as the head reaches it, with a soft trailing
  // band (FADE letters wide) so the edge is a gradient rather than a hard switch.
  // Normalize any CSS color string (hex, rgb(), named, …) to an [r,g,b] triple,
  // independent of stylesheet/layout timing. Canvas does the parsing: assigning
  // an invalid color leaves fillStyle unchanged, so we seed a sentinel and treat
  // an unchanged result as "couldn't parse". Returns null on failure.
  function parseRgb(color: string): [number, number, number] | null {
    if (!color) return null;
    const ctx = document.createElement("canvas").getContext("2d");
    if (!ctx) return null;
    ctx.fillStyle = "#000000";
    ctx.fillStyle = color;
    const a = ctx.fillStyle as string; // "#rrggbb" or "rgba(r, g, b, a)"
    if (a[0] === "#") {
      return [
        parseInt(a.slice(1, 3), 16),
        parseInt(a.slice(3, 5), 16),
        parseInt(a.slice(5, 7), 16),
      ];
    }
    const m = a.match(/\d+/g);
    return m && m.length >= 3 ? [+m[0], +m[1], +m[2]] : null;
  }

  function initLetterReveal(block: HTMLElement) {
    if (!window.matchMedia("(prefers-reduced-motion: no-preference)").matches)
      return;

    const letters = Array.from(
      block.querySelectorAll<HTMLElement>(".lr-char"),
    );
    if (letters.length === 0) return;

    const N = letters.length;
    const FADE = 16; // letters mid-transition at once (trailing softness)
    // Dimmed start color. Read from the CSS custom property the muted rule uses
    // (`--lr-muted`, overridable via the `mutedColor` prop; falls back to the
    // `--color-ink-muted` token). We deliberately DON'T read the letter's own
    // resolved `color`: that comes from the component's scoped stylesheet, which
    // on some engines (notably mobile WebKit/Safari) has not applied yet when
    // this deferred module script first runs — yielding black, which would make
    // the reveal interpolate black→black and never light up. The custom property
    // is an inline style on the block, so it's available immediately. The value
    // is normalized to RGB via a canvas, which is independent of stylesheet
    // timing. Falls back to the design default #BFC0CC if it can't be parsed.
    const blockStyle = getComputedStyle(block);
    const mutedColor =
      blockStyle.getPropertyValue("--lr-muted").trim() ||
      blockStyle.getPropertyValue("--color-ink-muted").trim();
    const MUTED = parseRgb(mutedColor) ?? [191, 192, 204];
    // Reveal window, in viewport-height fractions: progress is 0 when the block
    // top sits at START·vh (entering low) and 1 when it has risen to END·vh.
    const START = 0.82;
    const END = 0.42;

    const clamp01 = (n: number) => Math.min(1, Math.max(0, n));
    const easeOutCubic = (t: number) => 1 - Math.pow(1 - t, 3);

    let ticking = false;

    const render = () => {
      ticking = false;
      const rect = block.getBoundingClientRect();
      const vh = window.innerHeight;
      const travel = vh * START - (vh * END - rect.height);
      const p =
        travel > 0
          ? clamp01((vh * START - rect.top) / travel)
          : rect.top < vh * END
            ? 1
            : 0;

      // Reading head in letter units; scaled by +FADE so the last letter fully
      // lights exactly at p === 1.
      const head = easeOutCubic(p) * (N + FADE);
      for (let i = 0; i < N; i++) {
        const lit = clamp01((head - i) / FADE);
        // Interpolate muted gray → black as the letter lights up.
        const r = Math.round(MUTED[0] * (1 - lit));
        const g = Math.round(MUTED[1] * (1 - lit));
        const b = Math.round(MUTED[2] * (1 - lit));
        letters[i].style.color = `rgb(${r}, ${g}, ${b})`;
      }
    };

    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(render);
    };

    render();
    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onScroll);
  }

  document
    .querySelectorAll<HTMLElement>("[data-letter-reveal]")
    .forEach(initLetterReveal);
</script>
