---
/**
 * FormField — the bordered, pill-rounded form control from the contact form
 * design (Figma "INPUT", node 9213:4335…). One primitive covers the three
 * shapes used on the Book-an-intro page:
 *
 *   text | email — single-line <input>
 *   textarea     — multi-line message box (taller, top-aligned)
 *   select       — native <select> styled to match, with the design's
 *                  drop-down chevron drawn on top (appearance stripped)
 *
 * Every control shares the same black hairline, `rounded-[16px]` corners,
 * 24/12 padding and uppercase placeholder. The placeholder is uppercased via
 * `placeholder:uppercase` (NOT a blanket `uppercase`) so the value the user
 * types — name, email — stays in its natural case.
 */
interface Props {
  type?: "text" | "email" | "textarea" | "select";
  name: string;
  /** Placeholder text (and, for selects, the disabled default option). */
  placeholder: string;
  required?: boolean;
  /** Options for `type="select"`. */
  options?: string[];
  class?: string;
}
const {
  type = "text",
  name,
  placeholder,
  required = false,
  options = [],
  class: className = "",
} = Astro.props;

const base =
  "block w-full rounded-[16px] border border-black/50 bg-transparent px-6 py-3 text-sm text-black placeholder:uppercase placeholder:text-black/50 transition-colors focus:border-black focus:outline-none focus:ring-2 focus:ring-brand/40";
---

{
  type === "textarea" ? (
    <textarea
      id={name}
      name={name}
      required={required}
      placeholder={placeholder}
      rows={5}
      class={`${base} h-[157px] resize-none p-6 ${className}`}
    />
  ) : type === "select" ? (
    <div class={`relative ${className}`}>
      <select
        id={name}
        name={name}
        required={required}
        defaultValue=""
        class={`${base} appearance-none pr-12 [&:has(option[value='']:checked)]:uppercase [&:has(option[value='']:checked)]:text-black/50`}
      >
        <option value="" disabled selected>
          {placeholder}
        </option>
        {options.map((opt) => (
          <option value={opt}>{opt}</option>
        ))}
      </select>
      {/* Design's arrow_drop_down chevron — rounded downward triangle, drawn
          over the native control. */}
      <svg
        class="pointer-events-none absolute right-6 top-1/2 h-[6px] w-[10px] -translate-y-1/2 text-black/50"
        viewBox="0 0 10 6"
        fill="none"
        aria-hidden="true"
      >
        <path
          d="M5.295 5.29289C4.90447 5.68342 4.27131 5.68342 3.88078 5.29289L0.294998 1.70711C-0.334967 1.07714 0.111199 0 1.0021 0L8.17368 0C9.06458 0 9.51075 1.07714 8.88078 1.70711L5.295 5.29289Z"
          fill="currentColor"
        />
      </svg>
    </div>
  ) : (
    <input
      id={name}
      type={type}
      name={name}
      required={required}
      placeholder={placeholder}
      class={`${base} ${className}`}
    />
  )
}
