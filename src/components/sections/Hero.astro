---
/**
 * Hero — the "Home • Desktop" landing screen from the design.
 * Full-bleed mesh-gradient background with the navbar overlaid, a large Lora
 * headline, an eyebrow label, a divider cross, a supporting paragraph, and a
 * circular arrow button. Content comes from src/data/hero.json.
 */
import hero from "../../data/hero.json";
import Navbar from "../layout/Navbar.astro";
import Eyebrow from "../ui/Eyebrow.astro";
import CircleButton from "../ui/CircleButton.astro";
---

<section
  class="relative flex min-h-screen flex-col overflow-hidden bg-coral text-black"
>
  <!-- Background: animated swirl (WebGL) over the static mesh gradient.
       The image paints instantly and stays as the no-JS / fallback layer;
       the canvas fades in once the swirl effect has mounted. -->
  <img
    src="/hero/mesh-gradient.png"
    alt=""
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 z-0 h-full w-full object-cover"
  />
  <canvas
    data-swirl
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 z-0 h-full w-full opacity-0 transition-opacity duration-700"
  ></canvas>

  <!-- Bottom fade: blends the swirl/mesh into the next section's surface tone so
       the colour flows out instead of ending on a hard horizontal edge. -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-x-0 bottom-0 z-0 h-64 bg-gradient-to-b from-transparent to-surface"
  ></div>

  <Navbar />

  <div
    class="relative z-10 mx-auto flex min-h-screen w-full max-w-[1440px] flex-col px-6 lg:px-20"
  >
    <!-- Headline block -->
    <div class="max-w-[1160px] pt-[160px] lg:pt-[200px]">
      <div data-reveal><Eyebrow>{hero.eyebrow}</Eyebrow></div>
      <h1
        data-reveal="title"
        class="mt-8 font-serif font-normal leading-[1.03] tracking-[-0.02em] text-[clamp(2.75rem,6vw,88px)]"
      >
        {hero.headline}
      </h1>
    </div>

    <!-- Divider cross + lower content -->
    <div class="mt-auto pb-10">
      <div data-reveal="line" class="border-t border-black"></div>
      <div class="grid grid-cols-1 md:grid-cols-2">
        <div data-reveal class="flex items-center py-10" style="transition-delay:120ms">
          <CircleButton data-hero-scroll label={hero.cta.label} />
        </div>
        <div
          data-reveal
          class="py-10 md:border-l md:border-black md:pl-12"
          style="transition-delay:200ms"
        >
          <p class="max-w-[540px] text-2xl leading-[1.2] tracking-[-0.01em]">
            {hero.paragraph}
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { initSwirl } from "../../lib/swirl";

  const canvas = document.querySelector<HTMLCanvasElement>("canvas[data-swirl]");
  const container = canvas?.closest("section");
  if (canvas && container) {
    initSwirl(canvas, container, {
      grainUrl: "/hero/swirl/perlin1.png",
    });
    // Reveal the canvas once it's mounted so it overlays the static image.
    requestAnimationFrame(() => canvas.classList.remove("opacity-0"));
  }
</script>

<script>
  // Smooth-scroll the dotted circle button to the next section (one viewport down),
  // with a custom eased animation for a gentler glide than the browser default.
  const easeInOutQuart = (t: number) =>
    t < 0.5 ? 8 * t * t * t * t : 1 - Math.pow(-2 * t + 2, 4) / 2;

  const glideTo = (targetY: number) => {
    const startY = window.scrollY;
    const distance = targetY - startY;
    if (Math.abs(distance) < 1) return;
    // Scale duration with distance, clamped, so it always feels deliberate.
    const duration = Math.min(1700, Math.max(1100, Math.abs(distance) * 1.4));
    let startTime: number | null = null;

    const step = (now: number) => {
      if (startTime === null) startTime = now;
      const progress = Math.min((now - startTime) / duration, 1);
      window.scrollTo(0, startY + distance * easeInOutQuart(progress));
      if (progress < 1) requestAnimationFrame(step);
    };
    requestAnimationFrame(step);
  };

  document.querySelectorAll<HTMLElement>("[data-hero-scroll]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const hero = btn.closest("section");
      let next = hero?.nextElementSibling as HTMLElement | null;
      while (next && next.tagName !== "SECTION") {
        next = next.nextElementSibling as HTMLElement | null;
      }
      const targetY = next
        ? next.getBoundingClientRect().top + window.scrollY
        : window.innerHeight;
      if (reduce) {
        window.scrollTo(0, targetY);
      } else {
        glideTo(targetY);
      }
    });
  });
</script>
