---
/**
 * SolutionsLogos — partner-logo strip on the Solutions page (Figma node
 * 8634:646, "Logos"): a centered uppercase title over a single row of five
 * healthcare-organization logos, each in an equal-width cell topped by a faint
 * hairline rule. Reuses the shared LogoStrip; content comes from
 * src/data/solutions.json.
 */
import solutions from "../../data/solutions.json";
import LogoStrip from "../layout/LogoStrip.astro";

const { title, items } = solutions.logos;
---

<section class="px-6 pb-[200px] pt-20 lg:px-20">
  <div class="mx-auto flex max-w-[1280px] flex-col items-center gap-20">
    <h2
      data-reveal
      class="max-w-[962px] text-center text-sm font-semibold uppercase leading-[1.2]"
    >
      {title}
    </h2>
    <div data-reveal class="w-full" style="transition-delay:120ms">
      <LogoStrip logos={items} borderClass="border-black/24" />
    </div>
  </div>
</section>
