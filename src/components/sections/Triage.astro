---
/**
 * Triage — the "agentic workforce" use-case section below Care.
 * On arrival: a centered serif headline, the Triage navbar, and a lime-themed
 * Clinical Triage SolutionCard. As the section pins and the user scrolls, the
 * navbar swaps instantly (a trigger — one state is shown at a time, no
 * crossfade) to the Care Orchestration navbar the moment the first purple card
 * takes over; the remaining purple cards then slide in over the lime card, one
 * per scroll segment.
 * Content comes from src/data/triage.json.
 */
import triage from "../../data/triage.json";
import Eyebrow from "../ui/Eyebrow.astro";
import SolutionCard from "../ui/SolutionCard.astro";

const { eyebrow, heading, tabs, card, case: useCase, orchestration } = triage;
const orchCards = orchestration.cards;
---

<section
  data-triage-section
  class="triage-section relative overflow-x-clip bg-surface text-black backdrop-blur-[20px]"
>
  <!-- Heading -->
  <div
    class="mx-auto flex w-full max-w-[1440px] flex-col items-center gap-10 px-4 pb-20 pt-[120px] sm:px-6 lg:px-20"
  >
    <div data-reveal><Eyebrow>{eyebrow}</Eyebrow></div>
    <h2
      data-reveal="title"
      class="max-w-[952px] text-center font-serif font-normal text-4xl md:text-display text-ink"
    >
      {heading.before}<span class="text-brand">{heading.highlight}</span><br
      />{heading.afterBreak}{heading.after}
    </h2>
  </div>

  <!-- Pinned card column: on lg the track runs taller than the viewport so the
       stage can stick. The stage sits in normal flow — so the headline → navbar
       spacing is just the heading's bottom padding — and only offsets to
       vertical-center once it sticks. The pinned scroll distance scrubs the
       purple cards sliding in over the lime card before it releases. -->
  <div
    data-triage-track
    class="triage-track mx-auto w-full max-w-[1440px] px-4 pb-40 sm:px-6 lg:px-20 lg:pb-0"
  >
    <div
      data-triage-stage
      class="triage-stage mx-auto flex w-full max-w-[1064px] flex-col items-center gap-8"
    >
      <!-- Trigger nav (centered): the Triage tab (state A) on arrival, swapped
           instantly for the Care Orchestration navbar (state B) when the first
           purple card takes over. Both states are stacked in one grid cell but
           only one is displayed at a time, so the wrapper auto-sizes to it — JS
           just toggles which state shows (no crossfade, no gradual expansion). -->
      <div class="flex w-full justify-center">
          <div
            data-nav-wrap
            class="nav-wrap relative max-w-full rounded-[40px] bg-ink-wash"
          >
            <!-- State A — Triage -->
            <div
              data-nav-a
              class="nav-layer flex items-center gap-6 py-2 pl-8 pr-2"
            >
              <span class="shrink-0 text-sm font-semibold uppercase"
                >{tabs.label}</span
              >
              <span
                class="flex shrink-0 items-center justify-center whitespace-pre-line rounded-[40px] border border-gray-200 bg-accent px-8 py-4 text-center text-sm font-semibold uppercase"
                >{tabs.active}</span
              >
            </div>

            <!-- State B — Care Orchestration -->
            <div
              data-nav-b
              class="nav-layer flex items-center gap-6 py-2 pl-8 pr-2"
            >
              <span class="shrink-0 text-sm font-semibold uppercase"
                >{orchestration.navLabel}</span
              >
              <div class="flex shrink-0 items-stretch gap-2">
                {
                  orchestration.tabs.map((t, i) => (
                    <button
                      type="button"
                      data-orch-tab={i}
                      aria-label={`Show ${orchCards[i].title}`}
                      class="orch-tab flex shrink-0 cursor-pointer items-center justify-center whitespace-pre-line rounded-[40px] border border-gray-200 px-8 py-4 text-center text-sm font-semibold uppercase transition-colors"
                    >
                      {t}
                    </button>
                  ))
                }
              </div>
            </div>
          </div>
        </div>

        <!-- Card stage: the lime Clinical Triage card and the purple Care
             Orchestration cards share one relative box so the purple cards can
             slide in horizontally and overlap the lime card as the section pins. -->
        <div class="relative w-full" data-cards>
          <!-- triage-reveal = horizontal slide-in on first view. The inner
               [data-triage-card] wrapper carries the scroll-driven scale/fade so
               it doesn't fight the entrance transform. -->
          <div class="triage-reveal w-full" data-triage-reveal>
            <div data-triage-card>
              <SolutionCard
                theme="lime"
                title={card.title}
                headline={`${card.headline.highlight}${card.headline.rest}`}
                points={card.points}
                glow="/triage/card-bg.svg"
                badge={card.badge}
                logo={useCase.logo}
                logoAlt={useCase.logoAlt}
                stat={useCase.stat}
                statLabel={useCase.statLabel}
                cta={useCase.cta}
              />
            </div>
          </div>

          <!-- Care Orchestration cards — absolutely stacked over the lime card.
               Each reveals horizontally (slides in from the right) one per scroll
               segment while the section stays pinned. Later cards sit on higher
               z-index so each new reveal covers the previous. -->
          {
            orchCards.map((c, i) => (
              <div
                class="orch-card absolute inset-x-0 top-0"
                data-orch-card={i}
                style={`z-index: ${10 + i}`}
              >
                <SolutionCard
                  theme="purple"
                  title={c.title}
                  headline={`${c.headline.highlight}${c.headline.rest}`}
                  points={c.points}
                  glow="/triage/card-glow-purple.svg"
                  logo={c.case.logo}
                  logoText={c.case.logoText}
                  logoAlt={c.case.logoAlt}
                  stat={c.case.stat}
                  statLabel={c.case.statLabel}
                  cta={c.case.cta}
                />
              </div>
            ))
          }
        </div>
    </div>
  </div>
  <noscript>
    <style>
      .nav-wrap {
        visibility: visible !important;
      }
    </style>
  </noscript>
</section>

<style>
  /* Trigger nav -----------------------------------------------------------
     State A and State B share a single grid cell (stacked), but only one is
     displayed at a time so the wrapper auto-sizes to whichever shows. JS adds
     `.show-b` to swap them instantly — no opacity, no width tween. Hidden until
     JS is ready to avoid a flash; <noscript> reveals the Triage state for no-JS. */
  .nav-wrap {
    display: grid;
    justify-items: start;
    width: max-content;
    visibility: hidden;
  }
  .nav-wrap.is-ready {
    visibility: visible;
  }
  .nav-layer {
    grid-area: 1 / 1;
    white-space: nowrap;
  }
  [data-nav-b] {
    display: none;
  }
  .nav-wrap.show-b [data-nav-a] {
    display: none;
  }
  .nav-wrap.show-b [data-nav-b] {
    display: flex;
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-wrap {
      visibility: visible;
    }
  }

  /* Pin: while scrubbing (lg, motion allowed), the stage sticks so the card
     sequence is scrubbed in place. The stage stays in normal flow (headline → navbar
     spacing = the heading's padding); JS sets its `top` so it lands centered once
     stuck, plus the track height (taller than the viewport) and is-pinned.
     `overflow-x: clip` on the section clips the card slide-in without creating a
     scroll container, so this sticky still resolves against the viewport. */
  .triage-section.is-pinned .triage-stage {
    position: sticky;
  }

  /* Card slides in from the right and settles centered when scrolled into view. */
  .triage-reveal {
    opacity: 0;
    transform: translateX(240px);
    transition:
      opacity 1.2s ease-out,
      transform 1.6s cubic-bezier(0.33, 1, 0.68, 1);
    will-change: opacity, transform;
  }
  .triage-reveal.is-visible {
    opacity: 1;
    transform: translateX(0);
  }
  @media (prefers-reduced-motion: reduce) {
    .triage-reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }

  /* Scroll-driven card sequence -----------------------------------------------
     The purple [data-orch-card]s slide in horizontally (one per scroll segment)
     over the lime card while the section stays pinned. JS writes every transform
     inline against the pinned scroll progress; these defaults are the at-rest
     state so nothing flashes before JS runs and on no-JS / non-pinned viewports
     only the lime Clinical Triage card shows. */
  .orch-card {
    opacity: 0;
    pointer-events: none;
    will-change: transform, opacity;
  }

  /* Care Orchestration nav pills: the active use case is filled brand purple. */
  .orch-tab.is-active {
    background-color: var(--color-brand);
    color: #fff;
    border-color: transparent;
  }
</style>

<script>
  const reveals = document.querySelectorAll<HTMLElement>("[data-triage-reveal]");

  // Entrance: slide in horizontally on first view.
  if (!("IntersectionObserver" in window)) {
    reveals.forEach((el) => el.classList.add("is-visible"));
  } else {
    const observer = new IntersectionObserver(
      (entries, obs) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            obs.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.2 },
    );
    reveals.forEach((el) => observer.observe(el));
  }

  // --- Pinned card sequence ------------------------------------------------
  // On arrival the Triage navbar (state A) and the lime card show. Once the stage
  // centers and pins, the continued scroll toward the next section is scrubbed
  // into one segment per purple card:
  //   segment 0: the navbar swaps (crossfade, width snaps at the midpoint — no
  //     gradual expansion) into the Care Orchestration navbar (B) as the first
  //     purple card slides in over the lime card.
  //   segments 1…N-1: each remaining purple card slides in horizontally from the
  //     right, covering the previous one; the active nav pill follows.
  // After the last card the pin releases. Everything reverses on scroll-up. Runs
  // only while pinned (lg + motion allowed); otherwise it settles to the arrival
  // state (Triage navbar + lime card).
  const wrap = document.querySelector<HTMLElement>("[data-nav-wrap]");
  const section = document.querySelector<HTMLElement>("[data-triage-section]");
  const track = document.querySelector<HTMLElement>("[data-triage-track]");
  const stage = document.querySelector<HTMLElement>("[data-triage-stage]");
  const cardsBox = document.querySelector<HTMLElement>("[data-cards]");
  const triageCard = document.querySelector<HTMLElement>("[data-triage-card]");
  const orchCardEls = Array.from(
    document.querySelectorAll<HTMLElement>("[data-orch-card]"),
  );
  const tabEls = Array.from(
    document.querySelectorAll<HTMLElement>("[data-orch-tab]"),
  );
  const reduceMotion = window.matchMedia(
    "(prefers-reduced-motion: reduce)",
  ).matches;
  const lgMQ = window.matchMedia("(min-width: 1024px)");

  if (wrap && section && track && stage && cardsBox) {
    const N = orchCardEls.length; // orchestration cards
    let cardLen = 0; // scroll px each horizontal card reveal is scrubbed across
    let scrub = 0; // total pinned scroll distance
    let stickTop = 0; // sticky `top` that lands the stage vertically centered
    let pinned = false;
    let ticking = false;

    const clamp = (n: number) => Math.min(1, Math.max(0, n));
    // Smoothstep for an eased slide.
    const ease = (n: number) => n * n * (3 - 2 * n);

    const setActiveTab = (i: number) => {
      tabEls.forEach((t, k) => t.classList.toggle("is-active", k === i));
    };

    // offset = pinned scroll distance travelled (0 … scrub), in px.
    const apply = (offset: number) => {
      // Each card i slides in horizontally over its own segment [i, i+1)·cardLen.
      // While none is past halfway the lime card shows and no pill is active.
      let active = -1;
      orchCardEls.forEach((el, i) => {
        const r = clamp((offset - i * cardLen) / cardLen);
        const e = ease(r);
        el.style.transform = `translateX(${110 * (1 - e)}%)`;
        el.style.opacity = `${e}`;
        el.style.pointerEvents = "none";
        if (r >= 0.5) active = i;
      });
      // The instant a purple card takes over (becomes active) the navbar swaps
      // from Triage to Care Orchestration; the topmost card is interactive and
      // its nav pill is highlighted.
      wrap.classList.toggle("show-b", active >= 0);
      if (active >= 0) orchCardEls[active].style.pointerEvents = "auto";
      setActiveTab(active);
    };

    const settle = () => {
      // Non-pinned state: only the lime Clinical Triage card shows, so the Triage
      // navbar (state A) stays; orchestration cards hidden, no nav pill active.
      wrap.classList.remove("show-b");
      orchCardEls.forEach((el) => {
        el.style.transform = "";
        el.style.opacity = "";
        el.style.pointerEvents = "none";
      });
      setActiveTab(-1);
    };

    const measure = () => {
      section.classList.remove("is-pinned");
      track.style.height = "";
      stage.style.top = "";
      cardsBox.style.height = "";
      const vh = window.innerHeight;
      pinned = lgMQ.matches && !reduceMotion;
      if (pinned) {
        // Reserve the tallest card's height so the centered stage and the pin
        // distance account for cards taller than the lime card.
        const maxCardH = orchCardEls.reduce(
          (h, el) => Math.max(h, el.offsetHeight),
          triageCard ? triageCard.offsetHeight : 0,
        );
        cardsBox.style.height = `${maxCardH}px`;
        cardLen = Math.round(vh * 0.6);
        scrub = N * cardLen;
        // Land the stage centered when it fits; otherwise anchor near the top
        // (min 24px) so the navbar stays on screen on shorter viewports.
        stickTop = Math.max(24, Math.round((vh - stage.offsetHeight) / 2));
        stage.style.top = `${stickTop}px`;
        section.classList.add("is-pinned");
        track.style.height = `${stage.offsetHeight + scrub}px`;
      }
    };

    const render = () => {
      ticking = false;
      if (!pinned) return settle();
      // The stage sticks at top:stickTop and holds for `scrub` px. Track top runs
      // stickTop → stickTop − scrub across that span; map it to the travelled px.
      const offset = clamp(
        (stickTop - track.getBoundingClientRect().top) / scrub,
      );
      apply(offset * scrub);
    };

    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(render);
    };

    const init = () => {
      measure();
      render();
      wrap.classList.add("is-ready");
    };

    const onResize = () => {
      measure();
      render();
    };

    // Clicking a Care Orchestration nav pill jumps to the scroll position where
    // that card is fully revealed (the end of its own horizontal-reveal segment).
    // Only meaningful while pinned — otherwise only the lime card shows.
    const offsetForCard = (i: number) => (i + 1) * cardLen;

    const scrollToCard = (i: number) => {
      if (!pinned) return;
      const trackTop = window.scrollY + track.getBoundingClientRect().top;
      const target = trackTop - stickTop + offsetForCard(i);
      window.scrollTo({ top: target, behavior: "smooth" });
    };

    tabEls.forEach((tab, i) => {
      tab.addEventListener("click", () => scrollToCard(i));
    });

    init();
    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onResize);
    lgMQ.addEventListener("change", onResize);
  }
</script>
