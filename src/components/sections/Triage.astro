---
/**
 * Triage — the "agentic workforce" use-case section below Care.
 * A centered serif headline with a purple accent, a tab/segmented control
 * highlighting the active use case, and a lime-themed SolutionCard that slides
 * in horizontally on first view.
 * Content comes from src/data/triage.json.
 */
import triage from "../../data/triage.json";
import Eyebrow from "../ui/Eyebrow.astro";
import SolutionCard from "../ui/SolutionCard.astro";

const { eyebrow, heading, tabs, card, case: useCase, orchestration } = triage;
const orchCards = orchestration.cards;
---

<section
  data-triage-section
  class="triage-section relative overflow-x-clip bg-surface text-black backdrop-blur-[20px]"
>
  <!-- Heading -->
  <div
    class="mx-auto flex w-full max-w-[1440px] flex-col items-center gap-10 px-4 pb-20 pt-[120px] sm:px-6 lg:px-20"
  >
    <div data-reveal><Eyebrow>{eyebrow}</Eyebrow></div>
    <h2
      data-reveal="title"
      class="max-w-[952px] text-center font-serif font-normal leading-[1.2] tracking-[-0.02em] text-4xl md:text-display text-ink"
    >
      {heading.before}<span class="text-brand">{heading.highlight}</span><br
      />{heading.afterBreak}{heading.after}
    </h2>
  </div>

  <!-- Pinned card column: on lg the track runs taller than the viewport so the
       stage can stick. The stage sits in normal flow — so the headline → navbar
       spacing is just the heading's bottom padding — and only offsets to
       vertical-center once it sticks. The pinned scroll distance scrubs the
       navbar morph (Triage → Care Orchestration) before it releases. -->
  <div
    data-triage-track
    class="triage-track mx-auto w-full max-w-[1440px] px-4 pb-40 sm:px-6 lg:px-20 lg:pb-0"
  >
    <div
      data-triage-stage
      class="triage-stage mx-auto flex w-full max-w-[1064px] flex-col items-center gap-8"
    >
      <!-- Morphing nav (centered): starts as the Triage tab (state A) and
           crossfades + expands into the Care Orchestration navbar (state B). Both
           states are stacked in one grid cell so the wrapper sizes to the wider
           B; JS interpolates the wrapper width and crossfades the two layers
           against the pinned scroll progress. -->
      <div class="flex w-full justify-center">
          <div
            data-nav-wrap
            class="nav-wrap relative max-w-full rounded-[40px] bg-black/[0.04]"
          >
            <!-- State A — Triage (collapsed) -->
            <div
              data-nav-a
              class="nav-layer flex items-center gap-6 py-2 pl-8 pr-2"
            >
              <span
                class="shrink-0 text-sm font-semibold uppercase tracking-[-0.01em]"
                >{tabs.label}</span
              >
              <span
                class="shrink-0 rounded-[40px] border border-gray-200 bg-accent px-8 py-4 text-center text-sm font-semibold uppercase leading-tight tracking-[-0.01em]"
                >{tabs.active}</span
              >
            </div>

            <!-- State B — Care Orchestration (expanded) -->
            <div
              data-nav-b
              class="nav-layer flex items-center gap-6 py-2 pl-8 pr-2"
            >
              <span
                class="shrink-0 text-sm font-semibold uppercase tracking-[-0.01em]"
                >{orchestration.navLabel}</span
              >
              <div class="flex shrink-0 items-stretch gap-2">
                {
                  orchestration.tabs.map((t, i) => (
                    <span
                      data-orch-tab={i}
                      class:list={[
                        "orch-tab flex shrink-0 items-center justify-center whitespace-pre-line rounded-[40px] border border-gray-200 px-8 py-4 text-center text-sm font-semibold uppercase leading-tight tracking-[-0.01em] transition-colors",
                        i === 0 && "is-active",
                      ]}
                    >
                      {t}
                    </span>
                  ))
                }
              </div>
            </div>
          </div>
        </div>

        <!-- Card stage: the Triage (lime) card and the first Care Orchestration
             (purple) card share one relative box so the purple card can slide up
             from below and overlap the Triage card as the navbar morphs. -->
        <div class="relative w-full" data-cards>
          <!-- triage-reveal = horizontal slide-in on first view. The inner
               [data-triage-card] wrapper carries the scroll-driven scale/fade so
               it doesn't fight the entrance transform. -->
          <div class="triage-reveal w-full" data-triage-reveal>
            <div data-triage-card>
              <SolutionCard
                theme="lime"
                title={card.title}
                headline={`${card.headline.highlight}${card.headline.rest}`}
                points={card.points}
                glow="/triage/card-bg.svg"
                badge={card.badge}
                logo={useCase.logo}
                logoAlt={useCase.logoAlt}
                stat={useCase.stat}
                statLabel={useCase.statLabel}
                cta={useCase.cta}
              />
            </div>
          </div>

          <!-- Care Orchestration cards — absolutely stacked over the Triage card.
               Card 0 rises vertically from below as the navbar morphs; cards 1–3
               then reveal horizontally (slide in from the right) one per scroll
               segment while the section stays pinned. Later cards sit on higher
               z-index so each new reveal covers the previous. -->
          {
            orchCards.map((c, i) => (
              <div
                class="orch-card absolute inset-x-0 top-0"
                data-orch-card={i}
                style={`z-index: ${10 + i}`}
              >
                <SolutionCard
                  theme="purple"
                  title={c.title}
                  headline={`${c.headline.highlight}${c.headline.rest}`}
                  points={c.points}
                  glow="/triage/card-glow-purple.svg"
                  logo={c.case.logo}
                  logoText={c.case.logoText}
                  logoAlt={c.case.logoAlt}
                  stat={c.case.stat}
                  statLabel={c.case.statLabel}
                  cta={c.case.cta}
                />
              </div>
            ))
          }
        </div>
    </div>
  </div>
  <noscript>
    <style>
      .nav-wrap {
        visibility: visible !important;
      }
    </style>
  </noscript>
</section>

<style>
  /* Morphing nav -----------------------------------------------------------
     State A and State B share a single grid cell (stacked); the wrapper sizes
     to the wider/taller B. JS interpolates `width` (clipping B's extra pills
     while collapsed) and crossfades the two layers. Hidden until measured to
     avoid a flash of the end-state on load; <noscript> reveals it for no-JS. */
  .nav-wrap {
    display: grid;
    justify-items: start;
    align-items: stretch;
    width: max-content;
    overflow: hidden;
    visibility: hidden;
  }
  .nav-wrap.is-ready {
    visibility: visible;
  }
  .nav-layer {
    grid-area: 1 / 1;
    white-space: nowrap;
    will-change: opacity;
  }
  [data-nav-b] {
    opacity: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-wrap {
      visibility: visible;
    }
  }

  /* Pin: while morphing (lg, motion allowed), the stage sticks so the navbar
     morph is scrubbed in place. The stage stays in normal flow (headline → navbar
     spacing = the heading's padding); JS sets its `top` so it lands centered once
     stuck, plus the track height (taller than the viewport) and is-pinned.
     `overflow-x: clip` on the section clips the card slide-in without creating a
     scroll container, so this sticky still resolves against the viewport. */
  .triage-section.is-pinned .triage-stage {
    position: sticky;
  }

  /* Card slides in from the right and settles centered when scrolled into view. */
  .triage-reveal {
    opacity: 0;
    transform: translateX(240px);
    transition:
      opacity 1.2s ease-out,
      transform 1.6s cubic-bezier(0.33, 1, 0.68, 1);
    will-change: opacity, transform;
  }
  .triage-reveal.is-visible {
    opacity: 1;
    transform: translateX(0);
  }
  @media (prefers-reduced-motion: reduce) {
    .triage-reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }

  /* Morph-driven card sequence -----------------------------------------------
     [data-triage-card] scales down + fades as the navbar morphs; the first
     [data-orch-card] slides up from below to overlap it; the remaining orch cards
     then slide in horizontally (one per scroll segment) while the section stays
     pinned. JS writes every transform inline against the pinned scroll progress;
     these defaults are the at-rest state so nothing flashes before JS runs and on
     no-JS / non-morph viewports only the Triage card shows. */
  [data-triage-card] {
    transform-origin: center top;
    will-change: transform, opacity;
  }
  .orch-card {
    opacity: 0;
    pointer-events: none;
    will-change: transform, opacity;
  }

  /* Care Orchestration nav pills: the active use case is filled brand purple. */
  .orch-tab.is-active {
    background-color: var(--color-brand);
    color: #fff;
    border-color: transparent;
  }
</style>

<script>
  const reveals = document.querySelectorAll<HTMLElement>("[data-triage-reveal]");

  // Entrance: slide in horizontally on first view.
  if (!("IntersectionObserver" in window)) {
    reveals.forEach((el) => el.classList.add("is-visible"));
  } else {
    const observer = new IntersectionObserver(
      (entries, obs) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            obs.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.2 },
    );
    reveals.forEach((el) => observer.observe(el));
  }

  // --- Pinned card sequence ------------------------------------------------
  // Once the stage centers and pins, the continued scroll toward the next section
  // is scrubbed into a sequence of segments:
  //   segment 0 (morph): the Triage tab (A) expands + crossfades into the Care
  //     Orchestration navbar (B); the Triage card scales down + fades; the first
  //     orchestration card slides up from below to overlap it.
  //   segments 1…N-1: each remaining orchestration card slides in horizontally
  //     from the right, covering the previous one; the active nav pill follows.
  // After the last card the pin releases. Everything reverses on scroll-up. Runs
  // only while pinned (lg + motion allowed); otherwise it settles to the collapsed
  // Triage-only state.
  const wrap = document.querySelector<HTMLElement>("[data-nav-wrap]");
  const layerA = document.querySelector<HTMLElement>("[data-nav-a]");
  const layerB = document.querySelector<HTMLElement>("[data-nav-b]");
  const section = document.querySelector<HTMLElement>("[data-triage-section]");
  const track = document.querySelector<HTMLElement>("[data-triage-track]");
  const stage = document.querySelector<HTMLElement>("[data-triage-stage]");
  const cardsBox = document.querySelector<HTMLElement>("[data-cards]");
  const triageCard = document.querySelector<HTMLElement>("[data-triage-card]");
  const orchCardEls = Array.from(
    document.querySelectorAll<HTMLElement>("[data-orch-card]"),
  );
  const tabEls = Array.from(
    document.querySelectorAll<HTMLElement>("[data-orch-tab]"),
  );
  const reduceMotion = window.matchMedia(
    "(prefers-reduced-motion: reduce)",
  ).matches;
  const lgMQ = window.matchMedia("(min-width: 1024px)");

  if (wrap && layerA && layerB && section && track && stage && cardsBox) {
    const N = orchCardEls.length; // orchestration cards
    let wA = 0; // collapsed (Triage) content width
    let wB = 0; // expanded (Care Orchestration) content width
    let morphLen = 0; // scroll px the navbar morph (segment 0) is scrubbed across
    let cardLen = 0; // scroll px each horizontal card reveal is scrubbed across
    let scrub = 0; // total pinned scroll distance
    let stickTop = 0; // sticky `top` that lands the stage vertically centered
    let morph = false;
    let ticking = false;

    const clamp = (n: number) => Math.min(1, Math.max(0, n));
    // Smoothstep for an eased crossfade/expand/slide.
    const ease = (n: number) => n * n * (3 - 2 * n);

    const setActiveTab = (i: number) => {
      tabEls.forEach((t, k) => t.classList.toggle("is-active", k === i));
    };

    // offset = pinned scroll distance travelled (0 … scrub), in px.
    const apply = (offset: number) => {
      // Segment 0 — navbar morph + Triage→card-0 swap.
      const m = ease(clamp(offset / morphLen));
      wrap.style.width = `${wA + (wB - wA) * m}px`;
      layerA.style.opacity = `${1 - m}`;
      layerB.style.opacity = `${m}`;
      if (triageCard) {
        triageCard.style.transform = `scale(${1 - 0.12 * m})`;
        triageCard.style.opacity = `${1 - m}`;
      }

      // Card 0 rises vertically from below as the morph runs; cards 1…N-1 each
      // slide in horizontally from the right over their own segment.
      let active = 0;
      orchCardEls.forEach((el, i) => {
        if (i === 0) {
          el.style.transform = `translateY(${56 * (1 - m)}%)`;
          el.style.opacity = `${m}`;
        } else {
          const r = clamp((offset - (morphLen + (i - 1) * cardLen)) / cardLen);
          const e = ease(r);
          el.style.transform = `translateX(${110 * (1 - e)}%)`;
          el.style.opacity = `${e}`;
          if (r >= 0.5) active = i;
        }
        el.style.pointerEvents = "none";
      });
      // Topmost revealed card is interactive; its nav pill is highlighted.
      orchCardEls[active].style.pointerEvents = m > 0.5 ? "auto" : "none";
      setActiveTab(active);
    };

    const settle = () => {
      // Non-morph states: end-state on reduced motion, collapsed otherwise.
      if (reduceMotion) {
        wrap.style.width = `${wB}px`;
        layerA.style.opacity = "0";
        layerB.style.opacity = "1";
      } else {
        wrap.style.width = `${wA}px`;
        layerA.style.opacity = "1";
        layerB.style.opacity = "0";
      }
      // No sequence → only the Triage card shows; orchestration cards stay hidden.
      if (triageCard) {
        triageCard.style.transform = "";
        triageCard.style.opacity = "";
      }
      orchCardEls.forEach((el) => {
        el.style.transform = "";
        el.style.opacity = "";
        el.style.pointerEvents = "none";
      });
      setActiveTab(0);
    };

    const measure = () => {
      // Read both nav layers at their natural widths, then decide whether to pin.
      section.classList.remove("is-pinned");
      track.style.height = "";
      stage.style.top = "";
      wrap.style.width = "";
      cardsBox.style.height = "";
      wA = layerA.offsetWidth;
      wB = layerB.offsetWidth;
      const vh = window.innerHeight;
      morph = lgMQ.matches && !reduceMotion && wB > wA;
      if (morph) {
        // Reserve the tallest card's height so the centered stage and the pin
        // distance account for cards taller than the Triage card.
        const maxCardH = orchCardEls.reduce(
          (h, el) => Math.max(h, el.offsetHeight),
          triageCard ? triageCard.offsetHeight : 0,
        );
        cardsBox.style.height = `${maxCardH}px`;
        morphLen = Math.round(vh * 0.7);
        cardLen = Math.round(vh * 0.6);
        scrub = morphLen + (N - 1) * cardLen;
        // Land the stage centered when it fits; otherwise anchor near the top
        // (min 24px) so the morphing nav stays on screen on shorter viewports.
        stickTop = Math.max(24, Math.round((vh - stage.offsetHeight) / 2));
        stage.style.top = `${stickTop}px`;
        section.classList.add("is-pinned");
        track.style.height = `${stage.offsetHeight + scrub}px`;
      }
    };

    const render = () => {
      ticking = false;
      if (!morph) return settle();
      // The stage sticks at top:stickTop and holds for `scrub` px. Track top runs
      // stickTop → stickTop − scrub across that span; map it to the travelled px.
      const offset = clamp(
        (stickTop - track.getBoundingClientRect().top) / scrub,
      );
      apply(offset * scrub);
    };

    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(render);
    };

    const init = () => {
      measure();
      render();
      wrap.classList.add("is-ready");
    };

    const onResize = () => {
      measure();
      render();
    };

    init();
    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onResize);
    lgMQ.addEventListener("change", onResize);
  }
</script>
