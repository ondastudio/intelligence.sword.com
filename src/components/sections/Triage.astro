---
/**
 * Triage — the "agentic workforce" use-case section below Care.
 * A centered serif headline with a purple accent, a tab/segmented control
 * highlighting the active use case, and a lime-themed SolutionCard. The card
 * slides in horizontally on first view, then crossfades out (with a slight
 * scale-down) as the Care Orchestration section fades in and replaces it.
 * Content comes from src/data/triage.json.
 */
import triage from "../../data/triage.json";
import Eyebrow from "../ui/Eyebrow.astro";
import SolutionCard from "../ui/SolutionCard.astro";

const { eyebrow, heading, tabs, card, case: useCase } = triage;
---

<section
  class="relative overflow-hidden bg-surface text-black backdrop-blur-[20px]"
>
  <div
    class="mx-auto flex w-full max-w-[1440px] flex-col items-center gap-20 px-4 pb-40 pt-[120px] sm:px-6 lg:px-20"
  >
    <!-- Heading -->
    <div class="flex flex-col items-center gap-10">
      <div data-reveal><Eyebrow>{eyebrow}</Eyebrow></div>
      <h2
        data-reveal="title"
        class="max-w-[952px] text-center font-serif font-normal leading-[1.2] tracking-[-0.02em] text-4xl md:text-display text-ink"
      >
        {heading.before}<span class="text-brand">{heading.highlight}</span><br
        />{heading.afterBreak}{heading.after}
      </h2>
    </div>

    <!-- Card column -->
    <div class="flex w-full max-w-[1064px] flex-col items-center gap-8">
      <!-- Tab / segmented control -->
      <div
        class="flex items-center gap-6 rounded-[40px] bg-black/[0.04] py-2 pl-8 pr-2"
      >
        <span class="text-sm font-semibold uppercase tracking-[-0.01em]"
          >{tabs.label}</span
        >
        <span
          class="rounded-[40px] border border-gray-200 bg-accent px-8 py-4 text-center text-sm font-semibold uppercase leading-tight tracking-[-0.01em]"
          >{tabs.active}</span
        >
      </div>

      <!-- triage-reveal = horizontal slide-in; data-triage-exit = fade/scale out
           as the Care Orchestration section fades in over the same scroll. -->
      <div class="triage-reveal w-full" data-triage-reveal>
        <div data-triage-exit class="origin-center will-change-[transform,opacity]">
          <SolutionCard
            theme="lime"
            title={card.title}
            headline={`${card.headline.highlight}${card.headline.rest}`}
            points={card.points}
            glow="/triage/card-glow.svg"
            badge={card.badge}
            logo={useCase.logo}
            logoAlt={useCase.logoAlt}
            stat={useCase.stat}
            statLabel={useCase.statLabel}
            cta={useCase.cta}
          />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Card slides in horizontally and settles centered when scrolled into view. */
  .triage-reveal {
    opacity: 0;
    transform: translateX(-240px);
    transition:
      opacity 1.2s ease-out,
      transform 1.6s cubic-bezier(0.33, 1, 0.68, 1);
    will-change: opacity, transform;
  }
  .triage-reveal.is-visible {
    opacity: 1;
    transform: translateX(0);
  }
  @media (prefers-reduced-motion: reduce) {
    .triage-reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  const reveals = document.querySelectorAll<HTMLElement>("[data-triage-reveal]");
  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  // Entrance: slide in horizontally on first view.
  if (!("IntersectionObserver" in window)) {
    reveals.forEach((el) => el.classList.add("is-visible"));
  } else {
    const observer = new IntersectionObserver(
      (entries, obs) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            obs.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.2 },
    );
    reveals.forEach((el) => observer.observe(el));
  }

  // Crossfade: as the Care Orchestration section scrolls up into view, fade the
  // lime card out (with a slight scale-down) and fade Care in over the same
  // scroll range — so Care visibly "replaces" Triage.
  const exitEl = document.querySelector<HTMLElement>("[data-triage-exit]");
  const careEl = document.querySelector<HTMLElement>("[data-care]");
  if (exitEl && careEl && !reduce) {
    let ticking = false;
    const update = () => {
      ticking = false;
      const vh = window.innerHeight;
      const careTop = careEl.getBoundingClientRect().top;
      // 0 while Care is still below the fold; 1 by the time Care nears the top.
      const p = Math.min(1, Math.max(0, (vh - careTop) / (vh * 0.85)));
      exitEl.style.opacity = String(1 - p);
      exitEl.style.transform = `scale(${1 - 0.05 * p})`;
      careEl.style.opacity = String(p);
    };
    const onScroll = () => {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(update);
      }
    };
    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onScroll, { passive: true });
    update();
  }
</script>
