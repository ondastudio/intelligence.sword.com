---
/**
 * Triage — the "agentic workforce" use-case section below Care.
 * On arrival: a centered serif headline, the Triage navbar, and a lime-themed
 * Clinical Triage SolutionCard. As the section pins and the user scrolls, the
 * navbar swaps instantly (a trigger — one state is shown at a time, no
 * crossfade) to the Care Orchestration navbar the moment the first purple card
 * takes over; the remaining purple cards then slide in over the lime card, one
 * per scroll segment.
 * Content comes from src/data/triage.json.
 */
import triage from "../../data/triage.json";
import Eyebrow from "../ui/Eyebrow.astro";
import SolutionCard from "../ui/SolutionCard.astro";
import ArrowCircle from "../ui/ArrowCircle.astro";

const { eyebrow, heading, tabs, card, case: useCase, orchestration } = triage;
const orchCards = orchestration.cards;

// Per-card baked full-card backgrounds (index-aligned to orchCards). A null/
// missing entry falls back to the shared overlay bloom (card-glow-purple.svg).
const cardBg: Record<number, string> = {
  1: "/triage/card-bg-population.svg", // Population Health Campaigns
  2: "/triage/card-bg-surgery.svg", // Surgery Prehab and Rehab
  3: "/triage/card-bg-readmission.svg", // Readmission Prevention
};
---

<section
  data-triage-section
  class="triage-section relative overflow-x-clip bg-surface text-black backdrop-blur-[20px]"
>
  <!-- Heading -->
  <div
    class="relative z-10 mx-auto flex w-full max-w-[1440px] flex-col items-center gap-10 px-4 pb-20 pt-[120px] sm:px-6 lg:px-20"
  >
    <div data-reveal class="flex w-full justify-center">
      <!-- Figma: a centered block with left-aligned 220px label text (not
           centered text); reverts to the default inline label on lg. -->
      <Eyebrow class="max-w-[236px] text-left lg:max-w-none"
        >{eyebrow}</Eyebrow
      >
    </div>
    <h2
      data-reveal="title"
      class="max-w-[952px] text-center font-serif font-normal text-h5 text-ink"
    >
      {heading.before}<span class="text-brand">{heading.highlight}</span><br
      />{heading.afterBreak}{heading.after}
    </h2>
  </div>

  <!-- Pinned card column: on lg the track runs taller than the viewport so the
       stage can stick. The stage sits in normal flow — so the headline → navbar
       spacing is just the heading's bottom padding — and only offsets to
       vertical-center once it sticks. The pinned scroll distance scrubs the
       purple cards sliding in over the lime card before it releases. -->
  <div
    data-triage-track
    class="triage-track relative z-10 mx-auto w-full max-w-[1440px] px-[5px] pb-0 sm:px-6 lg:px-20"
  >
    <div
      data-triage-stage
      class="triage-stage mx-auto flex w-full max-w-[1064px] flex-col items-center gap-8"
    >
      <!-- Trigger nav (centered): the Triage tab (state A) on arrival, swapped
           instantly for the Care Orchestration navbar (state B) when the first
           purple card takes over. Both states are stacked in one grid cell but
           only one is displayed at a time, so the wrapper auto-sizes to it — JS
           just toggles which state shows (no crossfade, no gradual expansion). -->
      <!-- Mobile nav (below lg): arrows scroll the card strip horizontally.
           The strip itself is the source of truth, so touch swipes update the
           active label and pagination in the same way as buttons. Trackpad
           horizontal wheel gestures step one card at a time. -->
      <div
        data-mobile-nav
        class="mobile-nav flex w-full items-center justify-between lg:hidden"
      >
        <ArrowCircle
          variant="dotted"
          rotate={180}
          data-mobile-prev
          type="button"
          label="Previous use case"
        />
        <div
          data-mobile-dots
          class="flex items-center gap-2.5 rounded-full border border-black/24 p-2.5"
        >
          {
            Array.from({ length: orchCards.length + 1 }).map(() => (
              <span class="dot flex h-2.5 items-center overflow-hidden rounded-full bg-ink-muted">
                <span class="dot-fill h-2.5 w-2.5 shrink-0 rounded-full bg-ink-mid" />
              </span>
            ))
          }
        </div>
        <ArrowCircle
          variant="dotted"
          data-mobile-next
          type="button"
          label="Next use case"
        />
      </div>

      <div class="hidden w-full justify-center lg:flex">
          <div
            data-nav-wrap
            class="nav-wrap relative max-w-full rounded-[40px] bg-ink-wash"
          >
            <!-- State A — Triage -->
            <div
              data-nav-a
              class="nav-layer flex items-center gap-6 py-2 pl-8 pr-2"
            >
              <span class="shrink-0 text-sm font-semibold uppercase"
                >{tabs.label}</span
              >
              <span
                class="flex shrink-0 items-center justify-center whitespace-pre-line rounded-[40px] border border-gray-200 bg-accent px-8 py-4 text-center text-sm font-semibold uppercase"
                >{tabs.active}</span
              >
            </div>

            <!-- State B — Care Orchestration -->
            <div
              data-nav-b
              class="nav-layer flex items-center gap-6 py-2 pl-8 pr-2"
            >
              <span class="shrink-0 text-sm font-semibold uppercase"
                >{orchestration.navLabel}</span
              >
              <div class="flex shrink-0 items-stretch gap-2">
                {
                  orchestration.tabs.map((t, i) => (
                    <button
                      type="button"
                      data-orch-tab={i}
                      aria-label={`Show ${orchCards[i].title}`}
                      class="orch-tab flex shrink-0 cursor-pointer items-center justify-center whitespace-pre-line rounded-[40px] border border-gray-200 px-8 py-4 text-center text-sm font-semibold uppercase transition-colors"
                    >
                      {t}
                    </button>
                  ))
                }
              </div>
            </div>
          </div>
        </div>

        <!-- Card label + stage. The label (mobile only) names the current card's
             category ("Triage" / "Care Orchestration"); JS swaps its text as the
             carousel advances. Wrapped tight to the card so it reads as a header. -->
        <div class="flex w-full flex-col items-center">
          <div
            data-card-label
            data-label-a={tabs.label}
            data-label-b={orchestration.navLabel}
            class="flex h-14 w-full items-center justify-center rounded-[40px] bg-ink-wash lg:hidden"
          >
            <span
              data-card-label-text
              class="text-sm font-semibold uppercase text-black">{tabs.label}</span
            >
          </div>

          <!-- Card stage: the lime Clinical Triage card and the purple Care
               Orchestration cards share one relative box so the purple cards can
               slide in horizontally and overlap the lime card as the section pins. -->
          <div class="relative w-full" data-cards>
          <!-- The lime Clinical Triage card is the initial, static card — no
               entrance animation. The inner [data-triage-card] wrapper carries
               the scroll-driven fade as the purple cards take over. -->
          <div class="w-full" data-triage-reveal>
            <div data-triage-card>
              <SolutionCard
                theme="lime"
                title={card.title}
                headline={`${card.headline.highlight}${card.headline.rest}`}
                points={card.points}
                glow="/triage/card-bg.svg"
                badge={card.badge}
                logo={useCase.logo}
                logoAlt={useCase.logoAlt}
                stat={useCase.stat}
                statLabel={useCase.statLabel}
                cta={useCase.cta}
              />
            </div>
          </div>

          <!-- Care Orchestration cards — absolutely stacked over the lime card.
               Each reveals horizontally (slides in from the right) one per scroll
               segment while the section stays pinned. Later cards sit on higher
               z-index so each new reveal covers the previous. -->
          {
            orchCards.map((c, i) => (
              <div
                class="orch-card absolute inset-x-0 top-0"
                data-orch-card={i}
                style={`z-index: ${10 + i}`}
              >
                <SolutionCard
                  theme="purple"
                  title={c.title}
                  headline={`${c.headline.highlight}${c.headline.rest}`}
                  points={c.points}
                  glow={cardBg[i] ?? "/triage/card-glow-purple.svg"}
                  glowFill={cardBg[i] != null}
                  logo={c.case.logo}
                  logoText={c.case.logoText}
                  logoAlt={c.case.logoAlt}
                  stat={c.case.stat}
                  statLabel={c.case.statLabel}
                  mobile={c.case.mobile}
                  cta={c.case.cta}
                />
              </div>
            ))
          }
          </div>
        </div>
    </div>
  </div>
  <noscript>
    <style>
      .nav-wrap {
        visibility: visible !important;
      }
    </style>
  </noscript>
</section>

<style>
  /* Trigger nav -----------------------------------------------------------
     State A and State B share a single grid cell (stacked), but only one is
     displayed at a time so the wrapper auto-sizes to whichever shows. JS adds
     `.show-b` to swap them instantly — no opacity, no width tween. Hidden until
     JS is ready to avoid a flash; <noscript> reveals the Triage state for no-JS. */
  .nav-wrap {
    display: grid;
    justify-items: start;
    width: max-content;
    visibility: hidden;
  }
  .nav-wrap.is-ready {
    visibility: visible;
  }
  .nav-layer {
    grid-area: 1 / 1;
    white-space: nowrap;
  }
  [data-nav-b] {
    display: none;
  }
  .nav-wrap.show-b [data-nav-a] {
    display: none;
  }
  .nav-wrap.show-b [data-nav-b] {
    display: flex;
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-wrap {
      visibility: visible;
    }
  }

  /* Pin: while scrubbing (lg, motion allowed), the stage sticks so the card
     sequence is scrubbed in place. The stage stays in normal flow (headline → navbar
     spacing = the heading's padding); JS sets its `top` so it lands centered once
     stuck, plus the track height (taller than the viewport) and is-pinned.
     `overflow-x: clip` on the section clips the card slide-in without creating a
     scroll container, so this sticky still resolves against the viewport. */
  .triage-section.is-pinned .triage-stage {
    position: sticky;
  }

  /* Scroll-driven card sequence -----------------------------------------------
     The purple [data-orch-card]s slide in horizontally (one per scroll segment)
     over the lime card while the section stays pinned. JS writes every transform
     inline against the pinned scroll progress; these defaults are the at-rest
     state so nothing flashes before JS runs and on no-JS / non-pinned viewports
     only the lime Clinical Triage card shows. */
  .orch-card {
    opacity: 0;
    pointer-events: none;
    will-change: transform, opacity;
  }

  /* Care Orchestration nav pills: the active use case is filled brand purple. */
  .orch-tab.is-active {
    background-color: var(--color-brand);
    color: #fff;
    border-color: transparent;
  }

  /* Mobile (below lg) ----------------------------------------------------------
     By default mobile uses the same scroll-pinned reveal as lg: the stage pins
     and vertical scroll scrubs the purple cards in horizontally, one per
     segment, before the pin releases to normal scroll. The mobile nav (arrows,
     dots, label) is driven from the same scroll progress.
     `.is-carousel` (added only as the reduced-motion fallback) reverts to a
     native horizontal snap strip instead. */
  @media (max-width: 1023.98px) {
    .mobile-nav button[disabled] {
      opacity: 0.3;
      pointer-events: none;
    }
  }

  .triage-section.is-carousel [data-cards] {
    display: flex;
    gap: 0;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-behavior: smooth;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }
  .triage-section.is-carousel [data-cards]::-webkit-scrollbar {
    display: none;
  }
  .triage-section.is-carousel [data-triage-reveal] {
    flex: 0 0 100%;
    scroll-snap-align: start;
    scroll-snap-stop: always;
    transform: none;
    transition: opacity 0.45s ease;
  }
  .triage-section.is-carousel .orch-card {
    position: relative;
    inset: auto;
    top: auto;
    flex: 0 0 100%;
    scroll-snap-align: start;
    scroll-snap-stop: always;
    transform: none;
    opacity: 1;
    pointer-events: auto;
    transition: none;
  }

  /* Pagination dots: each card is a 10px ink-muted dot; the active card's dot
     stretches into a 30px lozenge with the dark fill revealed at its left. */
  .dot {
    width: 10px;
    transition: width 0.3s ease;
  }
  .dot .dot-fill {
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .dot.is-active {
    width: 30px;
  }
  .dot.is-active .dot-fill {
    opacity: 1;
  }

  @media (max-width: 1023.98px) and (prefers-reduced-motion: reduce) {
    [data-triage-reveal],
    .orch-card,
    .dot,
    .dot .dot-fill {
      transition: none;
    }
  }
</style>

<script>
  // --- Pinned card sequence ------------------------------------------------
  // On arrival the Triage navbar (state A) and the lime card show. Once the stage
  // centers and pins, the continued scroll toward the next section is scrubbed
  // into one segment per purple card:
  //   segment 0: the navbar swaps (crossfade, width snaps at the midpoint — no
  //     gradual expansion) into the Care Orchestration navbar (B) as the first
  //     purple card slides in over the lime card.
  //   segments 1…N-1: each remaining purple card slides in horizontally from the
  //     right, covering the previous one; the active nav pill follows.
  // After the last card the pin releases. Everything reverses on scroll-up. Runs
  // only while pinned (lg + motion allowed); otherwise it settles to the arrival
  // state (Triage navbar + lime card).
  const wrap = document.querySelector<HTMLElement>("[data-nav-wrap]");
  const section = document.querySelector<HTMLElement>("[data-triage-section]");
  const track = document.querySelector<HTMLElement>("[data-triage-track]");
  const stage = document.querySelector<HTMLElement>("[data-triage-stage]");
  const cardsBox = document.querySelector<HTMLElement>("[data-cards]");
  const triageCard = document.querySelector<HTMLElement>("[data-triage-card]");
  const triageReveal = document.querySelector<HTMLElement>(
    "[data-triage-reveal]",
  );
  const prevBtn = document.querySelector<HTMLElement>("[data-mobile-prev]");
  const nextBtn = document.querySelector<HTMLElement>("[data-mobile-next]");
  const dotEls = Array.from(
    document.querySelectorAll<HTMLElement>("[data-mobile-dots] .dot"),
  );
  const cardLabel = document.querySelector<HTMLElement>("[data-card-label]");
  const cardLabelText = document.querySelector<HTMLElement>(
    "[data-card-label-text]",
  );
  const orchCardEls = Array.from(
    document.querySelectorAll<HTMLElement>("[data-orch-card]"),
  );
  const tabEls = Array.from(
    document.querySelectorAll<HTMLElement>("[data-orch-tab]"),
  );
  const reduceMotion = window.matchMedia(
    "(prefers-reduced-motion: reduce)",
  ).matches;
  const lgMQ = window.matchMedia("(min-width: 1024px)");

  if (wrap && section && track && stage && cardsBox) {
    const N = orchCardEls.length; // orchestration cards
    let cardLen = 0; // scroll px each horizontal card reveal is scrubbed across
    let scrub = 0; // total pinned scroll distance
    let stickTop = 0; // sticky `top` that lands the stage vertically centered
    let pinned = false;
    let ticking = false;
    // Layout mode: "pinned" = lg scroll-scrub, "mobile" = native scroll carousel,
    // "settle" = static lime-only (lg + reduced motion). `current` is the
    // carousel index (0 = lime Clinical Triage, 1…N = the purple cards).
    let mode: "pinned" | "mobile" | "settle" = "settle";
    let current = 0;

    const clamp = (n: number) => Math.min(1, Math.max(0, n));
    // Smoothstep for an eased slide.
    const ease = (n: number) => n * n * (3 - 2 * n);

    const setActiveTab = (i: number) => {
      tabEls.forEach((t, k) => t.classList.toggle("is-active", k === i));
    };

    // Mobile carousel: update controls from the scroll-derived card index.
    const updateMobileState = (idx: number) => {
      current = Math.max(0, Math.min(N, idx));
      if (triageReveal) {
        triageReveal.style.opacity = "";
        triageReveal.style.pointerEvents = "";
      }
      if (triageCard) triageCard.style.opacity = "";
      orchCardEls.forEach((el, i) => {
        el.style.transform = "none";
        el.style.opacity = "";
        el.style.pointerEvents = "";
      });
      setActiveTab(current - 1);
      // Pagination dots: only the current card's dot is the elongated lozenge.
      dotEls.forEach((d, i) => d.classList.toggle("is-active", i === current));
      // Card label: lime card → "Triage", purple cards → "Care Orchestration".
      if (cardLabel && cardLabelText) {
        cardLabelText.textContent =
          current === 0
            ? cardLabel.dataset.labelA || ""
            : cardLabel.dataset.labelB || "";
      }
      if (prevBtn) prevBtn.toggleAttribute("disabled", current === 0);
      if (nextBtn) nextBtn.toggleAttribute("disabled", current === N);
    };

    // Pinned mode: keep the mobile nav (dots, label, arrows) in step with the
    // scroll-derived card index without disturbing the JS-driven card transforms.
    let lastMobileIdx = -1;
    const syncMobileNav = (idx: number) => {
      current = idx;
      if (idx === lastMobileIdx) return;
      lastMobileIdx = idx;
      dotEls.forEach((d, i) => d.classList.toggle("is-active", i === idx));
      if (cardLabel && cardLabelText) {
        cardLabelText.textContent =
          idx === 0
            ? cardLabel.dataset.labelA || ""
            : cardLabel.dataset.labelB || "";
      }
      if (prevBtn) prevBtn.toggleAttribute("disabled", idx === 0);
      if (nextBtn) nextBtn.toggleAttribute("disabled", idx === N);
    };

    // offset = pinned scroll distance travelled (0 … scrub), in px.
    const apply = (offset: number) => {
      // Each card i slides in horizontally over its own segment [i, i+1)·cardLen.
      // While none is past halfway the lime card shows and no pill is active.
      let active = -1;
      // Per-card slide-in progress (0→1 across its own segment).
      const prog = orchCardEls.map((_, i) =>
        clamp((offset - i * cardLen) / cardLen),
      );
      orchCardEls.forEach((el, i) => {
        const r = prog[i];
        const e = ease(r);
        el.style.transform = `translateX(${110 * (1 - e)}%)`;
        // Once entered the card stays opaque until the next card slides in over
        // it, then fades out so the incoming card cleanly replaces the previous.
        const next = i + 1 < prog.length ? ease(prog[i + 1]) : 0;
        el.style.opacity = r > 0 ? String(1 - next) : "0";
        el.style.pointerEvents = "none";
        if (r >= 0.5) active = i;
      });
      // The lime base card likewise fades out as the first purple card enters.
      if (triageCard) triageCard.style.opacity = String(1 - ease(prog[0] ?? 0));
      // The instant a purple card takes over (becomes active) the navbar swaps
      // from Triage to Care Orchestration; the topmost card is interactive and
      // its nav pill is highlighted.
      wrap.classList.toggle("show-b", active >= 0);
      if (active >= 0) orchCardEls[active].style.pointerEvents = "auto";
      setActiveTab(active);
      // Card 0 = lime Clinical Triage; card i (purple) active → mobile index i+1.
      syncMobileNav(active + 1);
    };

    const settle = () => {
      // Non-pinned state: only the lime Clinical Triage card shows, so the Triage
      // navbar (state A) stays; orchestration cards hidden, no nav pill active.
      wrap.classList.remove("show-b");
      if (triageCard) triageCard.style.opacity = "";
      orchCardEls.forEach((el) => {
        el.style.transform = "";
        el.style.opacity = "";
        el.style.pointerEvents = "none";
      });
      setActiveTab(-1);
    };

    // Reserve the tallest card's height so the absolutely-stacked purple cards
    // (and the centered pinned stage) get room for cards taller than the lime one.
    const reserveCardHeight = () => {
      const maxCardH = orchCardEls.reduce(
        (h, el) => Math.max(h, el.offsetHeight),
        triageCard ? triageCard.offsetHeight : 0,
      );
      cardsBox.style.height = `${maxCardH}px`;
    };

    const measure = () => {
      section.classList.remove("is-pinned");
      track.style.height = "";
      stage.style.top = "";
      cardsBox.style.height = "";
      const vh = window.innerHeight;
      const isLg = lgMQ.matches;
      // Both mobile and lg scroll-pin the card reveal; reduced motion falls back
      // to the static lime card (lg) or the native horizontal carousel (mobile).
      pinned = !reduceMotion;
      mode = pinned ? "pinned" : isLg ? "settle" : "mobile";
      // The carousel strip layout only applies in the mobile reduced-motion case.
      section.classList.toggle("is-carousel", mode === "mobile");
      lastMobileIdx = -1;
      if (mode === "pinned") {
        reserveCardHeight();
        cardLen = Math.round(vh * 0.6);
        scrub = N * cardLen;
        // Land the stage centered when it fits; otherwise anchor near the top so
        // the navbar stays on screen on shorter viewports. On mobile the fixed
        // page nav floats over the top, so keep a larger inset to clear it.
        const minTop = isLg ? 24 : 76;
        stickTop = Math.max(minTop, Math.round((vh - stage.offsetHeight) / 2));
        stage.style.top = `${stickTop}px`;
        section.classList.add("is-pinned");
        track.style.height = `${stage.offsetHeight + scrub}px`;
      } else if (mode === "mobile") {
        reserveCardHeight();
      }
      // Leaving the carousel: clear its inline lime-card overrides so the pinned
      // / settle states start from a clean slate.
      if (mode !== "mobile" && triageReveal) {
        triageReveal.style.opacity = "";
        triageReveal.style.pointerEvents = "";
        current = 0;
      }
    };

    const render = () => {
      ticking = false;
      if (mode === "mobile") return updateMobileState(current);
      if (mode === "settle") return settle();
      // pinned: the stage sticks at top:stickTop and holds for `scrub` px. Track
      // top runs stickTop → stickTop − scrub across that span; map it to px.
      const offset = clamp(
        (stickTop - track.getBoundingClientRect().top) / scrub,
      );
      apply(offset * scrub);
    };

    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(render);
    };

    const init = () => {
      measure();
      render();
      wrap.classList.add("is-ready");
    };

    const onResize = () => {
      measure();
      render();
    };

    // Clicking a Care Orchestration nav pill jumps to the scroll position where
    // that card is fully revealed (the end of its own horizontal-reveal segment).
    // Only meaningful while pinned — otherwise only the lime card shows.
    const offsetForCard = (i: number) => (i + 1) * cardLen;

    const scrollToCard = (i: number) => {
      if (!pinned) return;
      const trackTop = window.scrollY + track.getBoundingClientRect().top;
      const target = trackTop - stickTop + offsetForCard(i);
      window.scrollTo({ top: target, behavior: "smooth" });
    };

    // Mobile arrows while pinned: jump to the scroll offset for carousel index
    // `c` (0 = lime card, 1…N = purple cards). Index c lands at c·cardLen.
    const scrollToPinnedIndex = (c: number) => {
      const idx = Math.max(0, Math.min(N, c));
      const trackTop = window.scrollY + track.getBoundingClientRect().top;
      window.scrollTo({
        top: trackTop - stickTop + idx * cardLen,
        behavior: "smooth",
      });
    };

    tabEls.forEach((tab, i) => {
      tab.addEventListener("click", () => scrollToCard(i));
    });

    // --- Mobile carousel inputs (only act while in "mobile" mode) ------------
    const mobileCardWidth = () =>
      cardsBox.clientWidth || triageReveal?.clientWidth || 1;

    const scrollToMobileCard = (idx: number, behavior: ScrollBehavior) => {
      const next = Math.max(0, Math.min(N, idx));
      updateMobileState(next);
      cardsBox.scrollTo({
        left: next * mobileCardWidth(),
        behavior,
      });
    };

    const step = (dir: number) => {
      if (mode === "mobile") return scrollToMobileCard(current + dir, "smooth");
      if (mode === "pinned") scrollToPinnedIndex(current + dir);
    };

    prevBtn?.addEventListener("click", () => step(-1));
    nextBtn?.addEventListener("click", () => step(1));

    let mobileScrollTicking = false;
    cardsBox.addEventListener(
      "scroll",
      () => {
        if (mode !== "mobile" || mobileScrollTicking) return;
        mobileScrollTicking = true;
        requestAnimationFrame(() => {
          mobileScrollTicking = false;
          updateMobileState(Math.round(cardsBox.scrollLeft / mobileCardWidth()));
        });
      },
      { passive: true },
    );

    // Sideways wheel/trackpad scroll: one horizontal gesture advances one card.
    // Touch dragging still uses the native snap strip above.
    let wheelLock = false;
    cardsBox.addEventListener(
      "wheel",
      (e) => {
        if (mode !== "mobile") return;
        if (Math.abs(e.deltaX) <= Math.abs(e.deltaY)) return;
        e.preventDefault();
        if (wheelLock) return;
        wheelLock = true;
        window.setTimeout(() => {
          wheelLock = false;
        }, 650);
        scrollToMobileCard(current + (e.deltaX > 0 ? 1 : -1), "smooth");
      },
      { passive: false },
    );

    init();
    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onResize);
    lgMQ.addEventListener("change", onResize);
  }
</script>
