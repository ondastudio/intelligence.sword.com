---
/**
 * Scaling — "Scaling care with AI: been there, done that."
 *
 * Editorial proof section: an Eyebrow label over a two-column row (Lora display
 * headline with a purple "done that" accent on the left, supporting paragraph on
 * the right), followed by a four-up row of company stats. Each stat is a column
 * with a left hairline rule, a lime icon disc, a big Lora number with a frosted
 * "+" chip, and a caption. A white→lime mesh gradient blooms from the right.
 *
 * Columns collapse to a stack on mobile, 2-up at sm, 4-up at lg. Content comes
 * from src/data/scaling.json. Blocks fade up on first view.
 */
import Eyebrow from "../ui/Eyebrow.astro";
import PlusChip from "../ui/PlusChip.astro";
import data from "../../data/scaling.json";

const { eyebrow, heading, body, stats } = data;
---

<!-- overflow-x-clip (not overflow-hidden) so the bloom can bleed past the
     section's top/bottom into the neighbouring sections without adding a
     horizontal scrollbar. -->
<section id="scaling" class="scaling relative overflow-x-clip py-[120px] text-black lg:pt-[240px]">
  <!-- Animated neon-lime swirl bloom blooming from the right, behind the copy
       and stats. The shared hero swirl recoloured to the lime palette; a CSS
       lime wash is the no-JS / reduced-motion fallback. Sits at z-0 below the
       content (z-10). -->
  <div
    data-sc-swirl-stage
    aria-hidden="true"
    class="sc-swirl pointer-events-none absolute z-0"
  >
    <canvas
      data-sc-swirl
      class="absolute inset-0 h-full w-full opacity-0 transition-opacity duration-700"
    ></canvas>
  </div>

  <div
    id="scaling-heading"
    class="relative z-10 mx-auto w-full max-w-[1440px] scroll-mt-20 px-5 sm:px-6 lg:px-20"
  >
    <!-- Heading block -->
    <div class="flex flex-col gap-6">
      <div data-reveal>
        <Eyebrow
          dotClass="bg-purple-500"
          textClass="text-black max-w-[221px] lg:max-w-none"
        >
          {eyebrow}
        </Eyebrow>
      </div>

      <div
        class="flex flex-col gap-8 lg:flex-row lg:items-end lg:justify-between lg:gap-[133px]"
      >
        <!-- text-box-trim trims each block's bottom leading to the alphabetic
             baseline, so lg:items-end aligns the paragraph's last line precisely
             with the bottom of the title (not the line-box, whose half-leading
             differs between the two font sizes). -->
        <h2
          data-reveal="title"
          class="font-serif text-h5 font-normal lg:[text-box-edge:cap_alphabetic] lg:[text-box-trim:trim-end]"
        >
          {heading.line1}<br /><span class="whitespace-nowrap"
            >{heading.line2}<span class="text-brand">{heading.accent}</span>{
              heading.after
            }</span
          >
        </h2>

        <p
          data-reveal
          class="max-w-[628px] text-base text-xmd lg:[text-box-edge:cap_alphabetic] lg:[text-box-trim:trim-end]"
          style="transition-delay:160ms;letter-spacing:0"
        >
          {body}
        </p>
      </div>
    </div>

    <!-- Stats row -->
    <!-- Mobile (Figma): single column, compact stat blocks (icon → 40px gap →
         content, 24px between blocks). At sm the desktop layout is restored:
         min-height + justify-between align the 2-up / 4-up rows. -->
    <div
      class="mt-20 grid grid-cols-1 gap-x-6 gap-y-6 sm:grid-cols-2 sm:gap-y-12 lg:mt-[120px] lg:grid-cols-4"
    >
      {
        stats.map((stat, i) => (
          <div
            data-reveal
            class="flex flex-col gap-10 border-l border-black/24 px-6 sm:min-h-[260px] sm:justify-between sm:gap-0"
            style={`transition-delay:${120 + i * 100}ms`}
          >
            <span class="flex size-12 items-center justify-center rounded-full bg-accent">
              <img src={stat.icon} alt="" aria-hidden="true" class="size-8" />
            </span>

            <div class="flex flex-col gap-4">
              <div class="flex items-start gap-2">
                <span class="font-serif text-h4 font-normal">{stat.value}</span>
                {stat.plus && <PlusChip class="mt-[11px]" />}
              </div>
              <p class="min-h-[44px] max-w-[254px] text-xmd">{stat.label}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  /* Mobile (Figma): the bloom is a full-width neon-lime wash running down the
     top of the section and fading to white by ~85%. The animated swirl is a
     screen-space circle (see lib/swirl) and can't read as a full-width top
     wash, so on phones the bloom is a static vertical gradient instead — which
     also matches the Figma mesh gradient and skips WebGL on mobile. Stops are
     measured off the 390px frame: solid lime to ~35%, ~0.8 at 50%, ~0.5 at 62%,
     fading out by ~86%. The canvas is hidden here (desktop re-enables it). */
  .sc-swirl {
    inset: 0;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      var(--color-accent) 10%,
      var(--color-accent) 35%,
      color-mix(in srgb, var(--color-accent) 80%, transparent) 50%,
      color-mix(in srgb, var(--color-accent) 50%, transparent) 62%,
      color-mix(in srgb, var(--color-accent) 22%, transparent) 72%,
      transparent 86%
    );
  }
  .sc-swirl canvas {
    display: none;
  }

  /* Desktop: the animated circular lime swirl, blooming from the right behind
     the copy and stats. `top`/`left` mark the bloom's centre (the layer is
     pulled back by half its own size); a radial mask keeps it a soft circular
     bloom. The background is the no-JS / reduced-motion fallback wash. */
  @media (min-width: 1024px) {
    .sc-swirl {
      inset: auto;
      left: 66%;
      top: 56%;
      width: 100%;
      height: 165%;
      transform: translate(-50%, -50%);
      background: radial-gradient(
        circle closest-side at 50% 50%,
        color-mix(in srgb, var(--color-accent) 42%, transparent),
        transparent 68%
      );
      -webkit-mask-image: radial-gradient(
        circle closest-side at 50% 50%,
        #000 0%,
        #000 16%,
        transparent 70%
      );
      mask-image: radial-gradient(
        circle closest-side at 50% 50%,
        #000 0%,
        #000 16%,
        transparent 70%
      );
    }
    .sc-swirl canvas {
      display: block;
    }
  }
</style>

<script>
  // Animated neon-lime swirl bloom — the shared hero swirl recoloured to the
  // lime palette, blooming from the right (circular, gentle drift).
  import { initSwirl } from "../../lib/swirl";

  const stage = document.querySelector<HTMLElement>("[data-sc-swirl-stage]");
  const canvas = stage?.querySelector<HTMLCanvasElement>(
    "canvas[data-sc-swirl]",
  );

  // The animated swirl is desktop-only; on mobile the bloom is a static CSS
  // vertical wash (see the <style> block) and the canvas is hidden, so there's
  // no need to spin up WebGL there.
  if (stage && canvas && window.matchMedia("(min-width: 1024px)").matches) {
    initSwirl(canvas, stage, {
      grainUrl: "/hero/swirl/perlin1.png",
      circular: true,
      warp: 0.6, // gentle drift, cohesive blob
      speed: 4.6, // fast drift
      falloffStart: 0.5,
      falloffEnd: 0.94,
      colors: {
        bgColor: [0.98, 0.99, 0.96], // outer field — near-white
        soft: [0.9, 0.99, 0.62], // inner core — bright lime
        body: [0.8, 1.0, 0.22], // dominant bloom — neon lime (#ccff33)
        lavender: [0.92, 0.99, 0.72], // secondary highlight — pale lime
        crest: [0.97, 0.97, 0.97], // gradient crest — white
      },
    });
    requestAnimationFrame(() => canvas.classList.remove("opacity-0"));
  }
</script>
