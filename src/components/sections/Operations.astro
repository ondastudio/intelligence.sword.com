---
/**
 * Operations — closing statement banner.
 * "Unbreakable operations. Undeniable outcomes." A soft, heavily-blurred
 * purple→lime→lavender bloom sits centered behind a small eyebrow label and a
 * large two-line Lora headline. Content comes from src/data/operations.json.
 */
import Eyebrow from "../ui/Eyebrow.astro";
import data from "../../data/operations.json";

const { eyebrow, heading } = data;
---

<section
  class="operations relative flex min-h-[clamp(620px,62.5vw,900px)] items-center justify-center overflow-hidden bg-surface px-4 py-[120px]"
>
  <!-- Decorative blurred bloom — full-bleed, keeps the design's 1440×900
       framing/scale and crops to the section via object-cover. The bloom is
       faded to fully transparent before the bottom edge so it dissolves into
       the surface instead of cutting off in a hard line at the Numbers seam. -->
  <img
    src="/operations/bloom.svg"
    alt=""
    aria-hidden="true"
    class="bloom pointer-events-none absolute inset-0 z-0 h-full w-full object-cover"
  />

  <div class="relative z-10 flex flex-col items-center gap-6 text-center">
    <div data-reveal><Eyebrow dotClass="bg-purple-500">{eyebrow}</Eyebrow></div>

    <h2
      data-reveal="title"
      class="font-serif font-normal leading-[1.1] tracking-[-0.02em] text-black text-[clamp(2.5rem,6vw,80px)]"
      style="transition-delay:120ms"
    >
      {heading[0]}<br />{heading[1]}
    </h2>
  </div>
</section>

<style>
  /* Dissolve the bloom into the surface at the top & bottom edges so it never
     ends in a hard horizontal line where the section meets its neighbours. */
  .bloom {
    -webkit-mask-image: linear-gradient(
      to bottom,
      transparent 0%,
      #000 18%,
      #000 78%,
      transparent 100%
    );
    mask-image: linear-gradient(
      to bottom,
      transparent 0%,
      #000 18%,
      #000 78%,
      transparent 100%
    );
  }
</style>
