---
/**
 * AboutCta — closing call-to-action on the About page (Figma "Platform",
 * node 8628:8). Unlike the home page `Cta` (a full-bleed dotted-mesh band),
 * this is a centered white `rounded-card` on a `purple-tint` section: a
 * two-line Lora headline over a brand-purple pill ("Let's make you AI-first,
 * too") seamed to a `filled` `ArrowCircle`. The whole card is clickable (site
 * card rule): one stretched overlay link covers it, the pill + arrow are
 * decorative, and the arrow's `detach` nudge fires on card hover. The pill+arrow
 * entrance rides the shared `[data-reveal]` observer. Reads `data/about.json`
 * (`cta`).
 */
import ArrowCircle from "../ui/ArrowCircle.astro";
import about from "../../data/about.json";

const { heading, cta } = about.cta;
---

<section class="px-8 py-16 text-black sm:px-6 md:py-24">
  <div
    class="group relative mx-auto flex max-w-[1040px] flex-col items-center justify-center gap-8 rounded-card bg-white px-6 py-16 text-center sm:px-12 md:gap-10 md:py-20 lg:px-24"
  >
    <h2
      data-reveal="title"
      class="font-serif text-xlg font-normal"
    >
      {heading.line1}<br />{heading.line2}
    </h2>

    <div data-reveal class="flex items-center" style="transition-delay:140ms">
      <span
        class="text-balance rounded-[50px] bg-brand px-6 py-3 text-center text-sm font-semibold uppercase leading-tight text-white"
      >
        {cta.label}
      </span>
      <ArrowCircle
        variant="filled"
        label={cta.label}
        detach
        decorative
        class="-ml-px"
      />
    </div>

    <!-- Whole-card link -->
    <a
      href={cta.href}
      aria-label={cta.label}
      class="absolute inset-0 z-20 rounded-card"></a>
  </div>
</section>
