---
/**
 * AboutStory — the manifesto text block directly below the About hero
 * (Figma node 8616:406). Two large Figtree paragraphs, left-aligned in a
 * narrow column, with one semibold phrase in the second.
 *
 * Effect (matches the live site): a scroll-driven letter-by-letter reveal. Each
 * character starts a muted gray (`--color-ink-muted`) and "lights up" to solid
 * black as the reading head — a band that tracks scroll progress through the
 * block — sweeps across it. The effect is gated on motion + JS; without either,
 * every letter renders solid black (the Figma end state), so the message is
 * never hidden or faint.
 *
 * Content comes from src/data/about.json (`story`). Each paragraph is an array
 * of segments ({ text, bold? }); the component keeps whole words together (for
 * natural line-breaking) but splits every word into per-character spans so each
 * letter can be lit independently.
 */
import about from "../../data/about.json";

type Segment = { text: string; bold?: boolean };
const paragraphs = about.story.paragraphs as Segment[][];

// Flatten to a running letter index so the scrubber can light characters in
// reading order across both paragraphs. Whitespace stays as plain text nodes so
// it remains a line-break opportunity; each word is wrapped (nowrap) so its
// letters never split across lines.
let letterIndex = 0;
const renderedParagraphs = paragraphs.map((segments) =>
  segments.map((segment) => {
    const tokens = segment.text.split(/(\s+)/).filter((t) => t.length > 0);
    return tokens.map((token) => {
      const isSpace = /^\s+$/.test(token);
      return {
        isSpace,
        token,
        bold: segment.bold ?? false,
        chars: isSpace
          ? []
          : Array.from(token).map((ch) => ({ ch, index: letterIndex++ })),
      };
    });
  }),
);
const letterCount = letterIndex;
---

<section
  data-about-story
  class="about-story text-black"
  style={`--letter-count:${letterCount}`}
>
  <div
    class="mx-auto w-full max-w-[1440px] px-[clamp(1.5rem,5.2vw,80px)] py-[clamp(6rem,18vw,200px)]"
  >
    <div
      data-story-block
      class="story-block max-w-[1031px] font-sans font-normal leading-[1.15] text-h6"
    >
      {
        renderedParagraphs.map((segments, p) => (
          <p class={p === 0 ? "mb-8" : ""}>
            {segments.map((tokens) =>
              tokens.map((tok) =>
                tok.isSpace ? (
                  tok.token
                ) : (
                  // prettier-ignore — no whitespace inside the word/char spans, or letters space out
                  <span class="story-word" class:list={[tok.bold && "font-semibold"]}>{tok.chars.map(({ ch, index }) => (
                    <span class="story-char" style={`--i:${index}`}>{ch}</span>
                  ))}</span>
                ),
              ),
            )}
          </p>
        ))
      }
    </div>
  </div>
</section>

<style>
  /* Keep each word's letters together; letters are inline so kerning matches. */
  .story-word {
    white-space: nowrap;
  }
  .story-char {
    display: inline;
  }

  /* Base = Figma end state: fully resolved black text (no-JS / reduced-motion
     readers get the finished message immediately). */
  @media (prefers-reduced-motion: no-preference) {
    /* Enhanced: letters start a muted gray; the scrubber darkens them to black
       per-frame. Setting the muted start state here (gated on .js) keeps the
       first paint flash-free before the rAF loop takes over. */
    :global(html.js) .story-char {
      color: var(--color-ink-muted);
      will-change: color;
    }
  }
</style>

<script>
  // Scroll-driven letter-by-letter reveal. A "reading head" advances through the
  // character list as the block travels up the viewport; each letter darkens
  // from muted gray to solid black as the head reaches it, with a soft trailing
  // band (FADE letters wide) so the edge is a gradient rather than a hard switch.
  function initAboutStory(section: HTMLElement) {
    if (!window.matchMedia("(prefers-reduced-motion: no-preference)").matches)
      return;

    const block = section.querySelector<HTMLElement>("[data-story-block]");
    const letters = Array.from(
      section.querySelectorAll<HTMLElement>(".story-char"),
    );
    if (!block || letters.length === 0) return;

    const N = letters.length;
    const FADE = 16; // letters mid-transition at once (trailing softness)
    const MUTED = [191, 192, 204]; // #BFC0CC — dimmed start color (matches CSS)
    // Reveal window, in viewport-height fractions: progress is 0 when the block
    // top sits at START·vh (entering low) and 1 when it has risen to END·vh.
    const START = 0.82;
    const END = 0.42;

    const clamp01 = (n: number) => Math.min(1, Math.max(0, n));
    const easeOutCubic = (t: number) => 1 - Math.pow(1 - t, 3);

    let ticking = false;

    const render = () => {
      ticking = false;
      const rect = block.getBoundingClientRect();
      const vh = window.innerHeight;
      const travel = vh * START - (vh * END - rect.height);
      const p =
        travel > 0
          ? clamp01((vh * START - rect.top) / travel)
          : rect.top < vh * END
            ? 1
            : 0;

      // Reading head in letter units; scaled by +FADE so the last letter fully
      // lights exactly at p === 1.
      const head = easeOutCubic(p) * (N + FADE);
      for (let i = 0; i < N; i++) {
        const lit = clamp01((head - i) / FADE);
        // Interpolate muted gray → black as the letter lights up.
        const r = Math.round(MUTED[0] * (1 - lit));
        const g = Math.round(MUTED[1] * (1 - lit));
        const b = Math.round(MUTED[2] * (1 - lit));
        letters[i].style.color = `rgb(${r}, ${g}, ${b})`;
      }
    };

    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(render);
    };

    render();
    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onScroll);
  }

  document
    .querySelectorAll<HTMLElement>("[data-about-story]")
    .forEach(initAboutStory);
</script>
