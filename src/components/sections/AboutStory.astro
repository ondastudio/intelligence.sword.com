---
/**
 * AboutStory — the manifesto text block directly below the About hero
 * (Figma node 8616:406). Two large Figtree paragraphs, left-aligned in a
 * narrow column, with one semibold phrase in the second.
 *
 * The scroll-driven letter-by-letter reveal is provided by the shared
 * `ScrollLetterReveal` UI component (also used by the home Intro statement).
 *
 * Content comes from src/data/about.json (`story`). Each paragraph is an array
 * of segments ({ text, bold? }).
 */
import about from "../../data/about.json";
import ScrollLetterReveal from "../ui/ScrollLetterReveal.astro";

type Segment = { text: string; bold?: boolean };
const paragraphs = about.story.paragraphs as Segment[][];
---

<section class="text-black">
  <div
    class="mx-auto w-full max-w-[1440px] px-[clamp(1.25rem,5.2vw,80px)] py-[clamp(7.5rem,18vw,200px)]"
  >
    <ScrollLetterReveal
      paragraphs={paragraphs}
      spacingClass="mb-8"
      class="max-w-[1031px] font-sans font-normal leading-[1.15] text-h6"
    />
  </div>
</section>
