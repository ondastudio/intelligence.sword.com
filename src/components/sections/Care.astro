---
/**
 * Care — the "AI Care Managers" capabilities section below the Intro.
 * A faint mesh-gradient wash, a centered serif headline with a purple accent,
 * a supporting line, a 3×2 grid of FeatureCards, and a full-width
 * "Humans in the loop" banner with a decorative dotted-globe graphic.
 * Content comes from src/data/care.json.
 */
import care from "../../data/care.json";
import LabelPill from "../ui/LabelPill.astro";
import FeatureCard from "../ui/FeatureCard.astro";

// Per-card illustration styling (keyed by card index). Every card carries a
// dotLottie animation (authored in a 416×600 frame with the artwork centred and
// empty margins around it) rendered into a <canvas> that fills the card body.
// The canvas always stretches to the full body box (`lottieFill`); `fit: cover`
// shows each animation at its native proportions, the card's overflow-hidden
// trimming only the frame's empty top/bottom margin so the motion reads large.
const lottieFill = "h-full w-full";
// Document processing (idx 4): its artwork spans the full frame width, so the
// body box widens to content+both paddings and pulls itself back with matching
// negative margins, letting the animation bleed through the left/right padding
// to the card edges (the card's overflow-hidden + rounded corners trim it).
const bleedX =
  "relative -mx-8 flex min-h-0 w-[calc(100%+4rem)] flex-1 items-center justify-center md:-mx-10 md:w-[calc(100%+5rem)]";
// Autonomous browsing (idx 5): its artwork is right-biased, so the box widens
// only on the right (bleeding through the right padding to the card edge) and
// the animation is aligned right ([1, 0.5]) so the browser window hugs and
// bleeds off that edge.
const bleedRight =
  "relative -mr-8 flex min-h-0 w-[calc(100%+2rem)] flex-1 items-center justify-center md:-mr-10 md:w-[calc(100%+2.5rem)]";
const cardImage: Record<
  number,
  {
    img: string;
    wrap?: string;
    fit?: "cover" | "contain" | "fill" | "fit-width" | "fit-height";
    align?: [number, number];
  }
> = {
  0: { img: lottieFill, fit: "cover" },
  1: { img: lottieFill, fit: "cover" },
  2: { img: lottieFill, fit: "cover" },
  3: { img: lottieFill, fit: "cover" },
  4: { img: lottieFill, fit: "cover", wrap: bleedX },
  5: { img: lottieFill, fit: "cover", wrap: bleedRight, align: [1, 0.5] },
};
---

<!-- No own background: this section sits inside the shared swirl wrapper (see
     index.astro) so the hero swirl can bleed down behind the heading. The
     wrapper's bg-surface shows through below where the swirl fades out. -->
<section class="relative overflow-hidden text-black">
  <div
    class="relative z-10 mx-auto w-full max-w-[1440px] px-4 sm:px-6 lg:px-20"
  >
    <div
      class="mx-auto flex max-w-[1280px] flex-col gap-20 pb-32 pt-[120px] lg:gap-[120px]"
    >
      <!-- Heading + supporting line -->
      <div class="flex flex-col items-center gap-8">
        <h2
          data-reveal="title"
          data-swirl-end
          class="max-w-[290px] text-center font-serif font-normal text-h5 md:max-w-[923px]"
        >
          {care.heading.line1}<br />{care.heading.line2}<span class="text-brand"
            >{care.heading.highlight}</span
          >{care.heading.after}
        </h2>
        <p
          data-reveal
          class="text-center text-lg text-black"
          style="transition-delay:120ms"
        >
          {care.subheading}
        </p>
      </div>

      <!-- Cards + banner share a 16px gap (one container in the design) -->
      <div class="relative isolate flex flex-col gap-4">
        <!-- Purple swirl sitting BEHIND the cards (negative z within this
             isolated stacking context) so the white frosted cards lift off the
             page. The blobs spill a little past the grid for a soft halo; the
             section's overflow-hidden trims the horizontal bleed. The cards'
             backdrop-blur samples this, giving a faint frosted-purple tint. -->
        <div
          aria-hidden="true"
          class="pointer-events-none absolute -inset-x-[160px] -inset-y-32 -z-10 bg-[image:var(--gradient-care-swirl)] [mask-composite:intersect] [mask-image:linear-gradient(to_bottom,transparent_0%,#000_14%,#000_86%,transparent_100%),linear-gradient(to_right,transparent_0%,#000_12%,#000_88%,transparent_100%)] [-webkit-mask-composite:source-in] [-webkit-mask-image:linear-gradient(to_bottom,transparent_0%,#000_14%,#000_86%,transparent_100%),linear-gradient(to_right,transparent_0%,#000_12%,#000_88%,transparent_100%)]"
        >
        </div>

        <!-- Capability grid: 3 columns × 2 rows on desktop. Each card carries
             its own reveal with a stepped delay so they cascade in. Hidden on
             mobile, where the swipe-through deck below takes over. -->
        <div class="hidden gap-4 md:grid md:grid-cols-2 lg:grid-cols-3">
          {
            care.cards.map((card, i) => (
              <div data-reveal style={`transition-delay:${i * 110}ms`}>
                <FeatureCard
                  label={card.label}
                  description={card.description}
                  image={card.image}
                  imageClass={cardImage[i]?.img}
                  imageWrapperClass={cardImage[i]?.wrap}
                  lottieFit={cardImage[i]?.fit}
                  lottieAlign={cardImage[i]?.align}
                />
              </div>
            ))
          }
        </div>

        <!-- Mobile: a stacked card deck. The cards sit piled on screen; each
             upward swipe slides the next card up over the pile, and once the
             last card lands the pin releases so the same motion carries on into
             the banner below. JS-driven (the section's overflow-hidden would
             neutralise CSS sticky); with JS off or reduced motion it falls back
             to a plain vertical column. See the script at the foot of the file. -->
        <div class="care-deck md:hidden" data-care-deck>
          <div class="care-deck__track" data-care-track>
            <div class="care-deck__stage" data-care-stage>
              {
                care.cards.map((card, i) => (
                  <div class="care-deck__card" data-care-card style={`z-index:${i}`}>
                    <FeatureCard
                      label={card.label}
                      description={card.description}
                      image={card.image}
                      imageClass={cardImage[i]?.img}
                      imageWrapperClass={cardImage[i]?.wrap}
                      lottieFit={cardImage[i]?.fit}
                      lottieAlign={cardImage[i]?.align}
                      class="h-full min-h-0"
                    />
                  </div>
                ))
              }
              {/* The "Humans in the loop" banner is the final card in the deck on
                  mobile — it fades in over the pile like every other card. The
                  full-width banner below is its desktop counterpart. */}
              <div
                class="care-deck__card"
                data-care-card
                style={`z-index:${care.cards.length}`}
              >
                <div
                  class="flex h-full flex-col items-center gap-6 overflow-hidden rounded-[24px] bg-[image:var(--gradient-care-banner)] p-8"
                >
                  <LabelPill>{care.banner.label}</LabelPill>
                  <p class="text-center text-lg">
                    {care.banner.before}<span class="font-semibold"
                      >{care.banner.highlight}</span
                    >
                  </p>
                  <img
                    src={care.banner.graphic}
                    alt={care.banner.graphicAlt}
                    class="mt-auto h-44 w-44"
                  />
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Humans-in-the-loop banner (desktop) — continues the card cascade as
             the 7th step. On mobile this is hidden; the deck above carries its
             own banner card instead. -->
        <div
          data-reveal
          style="transition-delay:660ms"
          class="relative hidden flex-col items-start justify-between gap-10 overflow-hidden rounded-[24px] bg-[image:var(--gradient-care-banner)] p-10 md:flex md:h-[300px] md:flex-row md:items-center"
        >
          <div
            class="relative z-10 flex h-full flex-col items-start justify-between gap-10"
          >
            <LabelPill>{care.banner.label}</LabelPill>
            <p class="max-w-[778px] text-lg">
              {care.banner.before}<span class="font-semibold"
                >{care.banner.highlight}</span
              >
            </p>
          </div>

          <img
            src={care.banner.graphic}
            alt={care.banner.graphicAlt}
            class="relative z-10 h-44 w-44 shrink-0 self-end md:h-[220px] md:w-[220px] md:self-center"
          />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Mobile card deck. Default (no JS / reduced motion): a plain vertical column
     — the stage just stacks its cards with a gap. The script adds `.is-active`
     and switches the stage into the pinned, absolutely-stacked deck. */
  .care-deck__stage {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .care-deck.is-active .care-deck__track {
    position: relative;
  }

  .care-deck.is-active .care-deck__stage {
    display: block;
    /* position/top/left/width/height are driven inline by the script */
  }

  /* Each card fills the stage box and overlays the others; the script sets the
     transform (fade-in rise) and opacity per scroll frame. The entering card
     rises quickly into the front while the previous card fades out, so only one
     card is visible at a time — no stacking, no half-transparent overlap. */
  .care-deck.is-active .care-deck__card {
    position: absolute;
    inset: 0;
    height: 100%;
    will-change: transform, opacity;
  }
</style>

<script>
  // Mobile-only swipe-through deck. The cards pile up on screen; scrolling
  // pins the stack in the viewport centre and slides one card up at a time. The
  // pin is done with position:fixed (not CSS sticky — the section's
  // overflow-hidden would neutralise sticky) and measured the project's usual
  // way: vanilla rAF + getBoundingClientRect.
  const deck = document.querySelector<HTMLElement>("[data-care-deck]");

  if (deck) {
    const track = deck.querySelector<HTMLElement>("[data-care-track]")!;
    const stage = deck.querySelector<HTMLElement>("[data-care-stage]")!;
    const cards = Array.from(
      deck.querySelectorAll<HTMLElement>("[data-care-card]"),
    );
    const N = cards.length;

    // Active only on phones with motion allowed; desktop keeps the static grid.
    const mq = window.matchMedia(
      "(max-width: 767px) and (prefers-reduced-motion: no-preference)",
    );

    let stageH = 0; // px height of one card box (the pinned stage)
    let pinTravel = 0; // px of scroll the deck stays pinned for
    let centerTop = 0; // viewport offset the pinned stage rests at
    let active = false;
    let ticking = false;

    function measure() {
      const vh = window.innerHeight;
      // Tall cards so the portrait video illustrations read large instead of
      // being cropped to a thin band: take most of the viewport height, but
      // leave ≥16px top/bottom so the pinned stage never overflows the screen.
      stageH = Math.min(Math.max(Math.round(vh * 0.82), 460), vh - 32);
      const perCard = vh * 0.7; // scroll distance to bring in each next card
      pinTravel = perCard * (N - 1);
      centerTop = Math.max(16, Math.round((vh - stageH) / 2));
      track.style.height = `${stageH + pinTravel}px`;
      stage.style.height = `${stageH}px`;
    }

    // Per-card style for a continuous deck position `s` (0 = first card front,
    // N-1 = last card front). At s=0 only the first card shows. As `s` grows the
    // next card rises quickly into the front while the card it covers fades out —
    // cards do NOT stack or peek above one another, so the pile never shows two
    // half-transparent cards layered together.
    const ENTER_RISE = 64; // px the entering card rises from as it fades in
    // Each card holds fully in front for this fraction of its scroll step before
    // the next one starts sliding in; the remaining fraction plays the hand-off.
    // Lower = the next card starts sooner (lower threshold) and the swap is snappier.
    const HOLD = 0.3;
    function styleFor(i: number, s: number) {
      const rel = s - i;
      let ty: number;
      let opacity = 1;
      if (rel <= -1) {
        // not in yet — parked just below the front, invisible
        ty = ENTER_RISE;
        opacity = 0;
      } else if (rel < 0) {
        // entering: rise into the front and fade in fast. Opacity reaches full
        // well before the rise completes so the card is solid early and never
        // lingers as a half-transparent overlay on the one beneath.
        const t = rel + 1; // 0 → 1
        ty = (1 - t) * ENTER_RISE;
        opacity = Math.min(1, t * 3.5);
      } else {
        // behind the front card — fade out quickly so previous cards disappear
        // instead of stacking up. No upward stagger: nothing peeks above.
        ty = 0;
        opacity = Math.max(0, 1 - rel * 3);
      }
      return { transform: `translateY(${ty}px)`, opacity };
    }

    function render() {
      ticking = false;
      if (!active) return;

      const rect = track.getBoundingClientRect();
      const progress = centerTop - rect.top; // px scrolled into the pin range
      const clamped = Math.max(0, Math.min(pinTravel, progress));

      // Map raw scroll position to deck position `s`, but hold on each card for
      // the first HOLD of its step (card stays fully front, next stays hidden),
      // then smoothstep the hand-off over the rest — so cards dwell instead of
      // the next continuously creeping in from the moment you scroll.
      const sRaw = pinTravel > 0 ? (clamped / pinTravel) * (N - 1) : 0;
      const base = Math.min(N - 1, Math.floor(sRaw));
      const frac = sRaw - base;
      const adv = frac <= HOLD ? 0 : (frac - HOLD) / (1 - HOLD);
      const s = base + adv * adv * (3 - 2 * adv); // smoothstep the transition

      if (progress < 0) {
        // Before the pin: stage rides along at the top of the track.
        stage.style.position = "absolute";
        stage.style.top = "0px";
        stage.style.left = "0";
        stage.style.width = "100%";
      } else if (progress > pinTravel) {
        // After the pin: stage rests at the bottom of the track and scrolls off.
        stage.style.position = "absolute";
        stage.style.top = `${pinTravel}px`;
        stage.style.left = "0";
        stage.style.width = "100%";
      } else {
        // Pinned: stage held in the viewport centre while the cards animate.
        stage.style.position = "fixed";
        stage.style.top = `${centerTop}px`;
        stage.style.left = `${rect.left}px`;
        stage.style.width = `${rect.width}px`;
      }

      for (let i = 0; i < N; i++) {
        const st = styleFor(i, s);
        cards[i].style.transform = st.transform;
        cards[i].style.opacity = String(st.opacity);
      }
    }

    function onScroll() {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(render);
    }

    function activate() {
      if (active) return;
      active = true;
      deck.classList.add("is-active");
      measure();
      render();
      window.addEventListener("scroll", onScroll, { passive: true });
    }

    function deactivate() {
      if (!active) return;
      active = false;
      deck.classList.remove("is-active");
      window.removeEventListener("scroll", onScroll);
      for (const el of [track, stage]) {
        el.style.height = "";
      }
      stage.style.position = "";
      stage.style.top = "";
      stage.style.left = "";
      stage.style.width = "";
      cards.forEach((c) => {
        c.style.transform = "";
        c.style.opacity = "";
        c.style.filter = "";
      });
    }

    function sync() {
      if (mq.matches) activate();
      else deactivate();
    }

    sync();
    // Re-measure only when the viewport WIDTH changes (orientation / real
    // layout change). On mobile the browser chrome (URL bar) grows and shrinks
    // the viewport HEIGHT constantly while scrolling; re-measuring on those
    // height-only changes would recompute the vh-based pin geometry mid-scroll
    // and shift the scroll→card mapping, making the deck advance to the next
    // card on its own. We ignore height-only resizes (re-rendering is enough to
    // keep the pin tracking the real scroll position).
    let lastWidth = window.innerWidth;
    window.addEventListener("resize", () => {
      if (!active) return;
      if (window.innerWidth !== lastWidth) {
        lastWidth = window.innerWidth;
        measure();
      }
      render();
    });
    mq.addEventListener("change", sync);
  }
</script>
