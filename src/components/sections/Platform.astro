---
/**
 * Platform — the "Clinical Intelligence" system diagram.
 *
 * A centered headline + subhead over a fixed-canvas (1280×781) diagram: a
 * glowing "Clinical Intelligence" orb in the middle, fed on the left by the
 * data it learns from (stat cards + Unified Clinical Memory) and governed on
 * the right (certifications, deterministic logic, protocols), with Patients in
 * at the top and Full audits out the bottom. Flowing connector lines sweep in
 * from the page edges.
 *
 * The diagram is authored at its native Figma size and scaled to fit the
 * container width by a tiny ResizeObserver (never upscaled past 1×). Content
 * comes from src/data/platform.json.
 */
import data from "../../data/platform.json";
import PlusChip from "../ui/PlusChip.astro";

const {
  heading,
  subheading,
  orb,
  learnsLabel,
  governedLabel,
  patients,
  audits,
  stats,
  memory,
  governance,
} = data;

// Shared styling for the top/bottom flow pills (Patients, Full audits).
const iconDisc =
  "flex shrink-0 items-center justify-center rounded-[40px] bg-white p-2";
const pillLabel =
  "whitespace-nowrap text-sm font-semibold uppercase text-black";
const labelTag =
  "rounded-[40px] border border-black/24 px-4 py-2 text-sm font-semibold uppercase text-black";
// Shared geometry for the four sweeping connector curves (authored once, then
// flipped/rotated per corner). A black "flow" circle travels this same path so
// it stays glued to the visible stroke under any transform.
const curvePath = "M0.5 0.5H543.472C676.834 0.5 624 84.5 778 84.5";

// Mobile dotted strokes reproduce the Figma spec exactly: solid-black round
// dots, 1.5px across, 8px apart (the design's stroke-dasharray "0.01 8" with
// round caps). Authored at 1:1 px so the spacing never scales with the box.
const dottedYLine =
  "background-image:radial-gradient(circle,#000 0.75px,transparent 0.75px);background-size:1.5px 8px;background-repeat:repeat-y;background-position:center";
const dottedXLine =
  "background-image:radial-gradient(circle,#000 0.75px,transparent 0.75px);background-size:8px 1.5px;background-repeat:repeat-x;background-position:center";

// Per-curve flow timing. All four share the same duration and start, so the
// dots run edge → centre in lockstep and reach the orb at the same instant.
const FLOW_DUR = "5s";
const curves = [
  { pos: "left:-216px;top:62px", dur: FLOW_DUR, begin: "0s" },
  {
    pos: "left:719px;top:62px;transform:scaleX(-1)",
    dur: FLOW_DUR,
    begin: "0s",
  },
  {
    pos: "left:-215px;top:697px;transform:scaleY(-1)",
    dur: FLOW_DUR,
    begin: "0s",
  },
  {
    pos: "left:720px;top:697px;transform:rotate(180deg)",
    dur: FLOW_DUR,
    begin: "0s",
  },
];
---

<section
  class="platform relative overflow-x-clip bg-surface py-[120px] text-black"
>
  <div class="mx-auto w-full max-w-[1440px] px-4 sm:px-6 lg:px-20">
    <!-- Heading -->
    <div
      class="mx-auto flex max-w-[820px] flex-col items-center gap-6 text-center"
    >
      <h2
        data-reveal="title"
        class="max-w-[350px] font-serif text-[28px] font-normal lg:max-w-none lg:text-h5"
      >
        {heading}
      </h2>
      <p
        data-reveal
        class="max-w-[350px] text-[22px] text-black lg:max-w-[600px] lg:text-lg"
        style="transition-delay:120ms"
      >
        {subheading}
      </p>
    </div>

    <!-- Diagram (scaled to fit), desktop / tablet only -->
    <div
      data-stage-wrap
      data-reveal
      class="relative mt-20 hidden lg:block"
      style="transition-delay:160ms"
    >
      <div
        data-stage
        class="absolute left-1/2 top-0 h-[781px] w-[1280px]"
        style="transform-origin: top center; transform: translateX(-50%);"
      >
        <!-- ============ Connector lines (behind everything) ============ -->
        <!-- Four sweeping curves from the page edges. Each is the same authored
             path (flipped/rotated per corner) with a black flow dot endlessly
             traveling edge → centre, so the diagram looks alive. -->
        {
          curves.map((c) => (
            <svg
              viewBox="0 0 778.5 85"
              preserveAspectRatio="none"
              overflow="visible"
              fill="none"
              aria-hidden="true"
              class="absolute h-[84px] w-[777px]"
              style={c.pos}
            >
              <path d={curvePath} stroke="black" stroke-linecap="round" />
              <circle class="flow-dot" r="4" fill="black">
                <animateMotion
                  dur={c.dur}
                  begin={c.begin}
                  repeatCount="indefinite"
                  path={curvePath}
                />
                <animate
                  attributeName="opacity"
                  dur={c.dur}
                  begin={c.begin}
                  repeatCount="indefinite"
                  values="0;1;1;1;0"
                  keyTimes="0;0.1;0.5;0.88;1"
                />
              </circle>
            </svg>
          ))
        }

        <!-- Short dotted connectors into the orb -->
        <img
          src="/platform/line-left.svg"
          alt=""
          aria-hidden="true"
          class="absolute h-2 w-[116px]"
          style="left:306px;top:417px"
        />
        <img
          src="/platform/line-right.svg"
          alt=""
          aria-hidden="true"
          class="absolute h-2 w-[81px]"
          style="left:874px;top:417px"
        />
        <img
          src="/platform/line-down.svg"
          alt=""
          aria-hidden="true"
          class="absolute h-2 w-[74px]"
          style="left:603px;top:161px;transform:rotate(90deg)"
        />

        <!-- Black flow dot running down from Patients into the orb -->
        <span
          class="flow-conn flow-conn--y absolute size-2 rounded-full bg-black"
          style="left:636px;top:124px;--from:0px;--to:57px;animation-duration:2.4s;animation-delay:-0.8s"
        ></span>

        <!-- Top rounded caps under the section labels -->
        <span
          class="absolute h-[10px] w-[60px] rounded-full bg-black"
          style="left:120px;top:57px"></span>
        <span
          class="absolute h-[10px] w-[60px] rounded-full bg-black"
          style="left:1096px;top:57px"></span>

        <!-- ============ Section labels ============ -->
        <span class={`absolute ${labelTag}`} style="left:35px;top:0"
          >{learnsLabel}</span
        >
        <span class={`absolute ${labelTag}`} style="left:1061px;top:0"
          >{governedLabel}</span
        >

        <!-- ============ Center orb (ring + glow + label + MDR seal, one asset) ============ -->
        <img
          src="/platform/orb.svg"
          alt={`${orb.title} — ${orb.badgeLine1} ${orb.badgeLine2}`}
          class="absolute h-[442px] w-[439px]"
          style="left:420px;top:200px"
        />

        <!-- Arrow buttons pointing into the orb -->
        <span
          class="absolute flex size-8 items-center justify-center rounded-[40px] bg-brand"
          style="left:406px;top:405px"
        >
          <img
            src="/platform/icon-arrow-right.svg"
            alt=""
            aria-hidden="true"
            class="size-4"
          />
        </span>
        <span
          class="absolute flex size-8 items-center justify-center rounded-[40px] bg-brand"
          style="left:842px;top:405px"
        >
          <img
            src="/platform/icon-arrow-left.svg"
            alt=""
            aria-hidden="true"
            class="size-4"
          />
        </span>

        <!-- ============ Left column: continuously learns from ============ -->
        <!-- Dotted container + stat cards + Unified Clinical Memory (one asset) -->
        <img
          src="/platform/column-left.svg"
          alt={`${stats[0].value}+ ${stats[0].label}. ${memory.label}. ${stats[1].value}+ ${stats[1].label}.`}
          class="absolute h-[542px] w-[308px]"
          style="left:-1px;top:150px"
        />

        <!-- ============ Right column: governed by ============ -->
        <!-- Dotted container + governance pills (one asset) -->
        <img
          src="/platform/column-right.svg"
          alt={governance.map((g) => g.label).join(". ")}
          class="absolute h-[242px] w-[327px]"
          style="left:953px;top:300px"
        />

        <!-- Black flow dots that trace each lateral column's dotted border,
             then dart into the orb. Drawn after the columns so they sit on top.
             Paths are in stage (1280×781) coordinates. -->
        <svg
          viewBox="0 0 1280 781"
          width="1280"
          height="781"
          fill="none"
          overflow="visible"
          aria-hidden="true"
          class="pointer-events-none absolute left-0 top-0"
        >
          <circle class="flow-dot" r="4" fill="black">
            <animateMotion
              dur="9s"
              repeatCount="indefinite"
              path="M307 421 V652 A40 40 0 0 1 267 692 H39 A40 40 0 0 1 -1 652 V190 A40 40 0 0 1 39 150 H267 A40 40 0 0 1 307 190 V421 L416 421"
            ></animateMotion>
            <animate
              attributeName="opacity"
              dur="9s"
              repeatCount="indefinite"
              values="0;1;1;1;0"
              keyTimes="0;0.04;0.5;0.93;1"></animate>
          </circle>
          <circle class="flow-dot" r="4" fill="black">
            <animateMotion
              dur="6.5s"
              repeatCount="indefinite"
              path="M953 421 V340 A40 40 0 0 1 993 300 H1240 A40 40 0 0 1 1280 340 V502 A40 40 0 0 1 1240 542 H993 A40 40 0 0 1 953 502 V421 L863 421"
            ></animateMotion>
            <animate
              attributeName="opacity"
              dur="6.5s"
              repeatCount="indefinite"
              values="0;1;1;1;0"
              keyTimes="0;0.05;0.5;0.92;1"></animate>
          </circle>
        </svg>

        <!-- ============ Top: Patients ============ -->
        <div
          class="absolute -translate-x-1/2 flex h-16 w-[282px] items-center gap-4 overflow-hidden rounded-[50px] bg-lavender pl-2 pr-8"
          style="left:640px;top:45px"
        >
          <span
            class="flex shrink-0 items-center gap-2.5 rounded-[40px] bg-white p-2"
          >
            {
              patients.icons.map((ic) => (
                <img src={ic.src} alt={ic.alt} class="size-8" />
              ))
            }
          </span>
          <span class={pillLabel}>{patients.label}</span>
        </div>

        <!-- ============ Bottom: Full audits ============ -->
        <div
          class="absolute -translate-x-1/2 flex h-16 items-center gap-4 overflow-hidden rounded-[50px] bg-lavender pl-2 pr-8"
          style="left:640px;top:663px"
        >
          <span class={iconDisc}
            ><img
              src={audits.icon}
              alt=""
              aria-hidden="true"
              class="size-8"
            /></span
          >
          <span class={pillLabel}>{audits.label}</span>
        </div>
      </div>
    </div>

    <!-- ============ Mobile diagram (vertical stack) ============ -->
    <!-- The fixed-canvas diagram does not scale down to phone widths, so on
         small screens the same system is re-laid-out as a single column:
         "learns from" card -> orb -> "governed by" card. Dots flow along the
         dotted connectors toward the orb in lockstep, and the orb keeps its
         self-animating spin (baked into orb.svg). -->
    <div data-reveal class="mt-16 flex flex-col items-center lg:hidden" style="transition-delay:160ms">
      <!-- Continuously learns from -->
      <div class="flex w-full max-w-[350px] flex-col items-center gap-4">
        <span class={`whitespace-nowrap ${labelTag}`}>{learnsLabel}</span>
        <div class="relative w-full">
          <!-- Dotted border (round dots, 1.5px @ 8px, non-scaling) -->
          <svg class="pointer-events-none absolute inset-0 size-full overflow-visible" fill="none" aria-hidden="true">
            <rect x="0" y="0" width="100%" height="100%" rx="40" stroke="black" stroke-width="1.5" stroke-linecap="round" stroke-dasharray="0.01 8" />
          </svg>
          <div class="p-2">
            <div class="grid grid-cols-2 gap-2">
              {stats.map((stat) => (
                <div class="flex flex-col items-center gap-[18px] rounded-[40px] bg-lavender px-4 py-4 text-center">
                  <span class="flex items-start gap-1">
                    <span class="font-serif text-[28px] font-normal leading-[1.1]">{stat.value}</span>
                    {stat.plus && <PlusChip class="mt-1.5 size-5" iconClass="size-3.5" />}
                  </span>
                  <span class="text-sm font-semibold uppercase leading-[1.25]">{stat.label}</span>
                </div>
              ))}
            </div>
            <div class="mt-2 flex items-center gap-4 rounded-full bg-lavender p-1 pr-6">
              <span class="flex size-7 shrink-0 items-center justify-center rounded-full bg-white">
                <img src={memory.icon} alt="" aria-hidden="true" class="size-5" />
              </span>
              <span class="text-sm font-semibold uppercase text-black">{memory.label}</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Connector: card -> orb (dot flows down toward the orb) -->
      <span class="relative block h-[50px] w-2.5 shrink-0">
        <span class="absolute inset-y-0 left-1/2 w-[1.5px] -translate-x-1/2" style={dottedYLine}></span>
        <span class="m-flow absolute left-[calc(50%-5px)] top-0 size-2.5 rounded-full bg-black" style="--from:0px;--to:50px"></span>
      </span>

      <!-- Center orb: the mobile asset bakes the ring, glow, two-line MDR
           badge, label and the purple entry/exit dots; its arcs self-spin
           (orb-arc-spin, identical behaviour to the desktop orb). -->
      <div class="relative flex shrink-0 items-center justify-center">
        <img
          src="/platform/orb-mobile.svg"
          alt={`${orb.title} — ${orb.badgeLine1} ${orb.badgeLine2}`}
          class="w-[211px]"
        />
        <span class="absolute right-full top-1/2 mr-[-12px] h-[1.5px] w-[30px] -translate-y-1/2" style={dottedXLine}></span>
        <span class="absolute left-full top-1/2 ml-[-12px] h-[1.5px] w-[30px] -translate-y-1/2" style={dottedXLine}></span>
      </div>

      <!-- Connector: orb -> card (dot flows up toward the orb, in sync) -->
      <span class="relative block h-[50px] w-2.5 shrink-0">
        <span class="absolute inset-y-0 left-1/2 w-[1.5px] -translate-x-1/2" style={dottedYLine}></span>
        <span class="m-flow absolute left-[calc(50%-5px)] top-0 size-2.5 rounded-full bg-black" style="--from:50px;--to:0px"></span>
      </span>

      <!-- Governed by -->
      <div class="flex w-full max-w-[309px] flex-col items-center gap-4">
        <div class="relative w-full">
          <svg class="pointer-events-none absolute inset-0 size-full overflow-visible" fill="none" aria-hidden="true">
            <rect x="0" y="0" width="100%" height="100%" rx="32" stroke="black" stroke-width="1.5" stroke-linecap="round" stroke-dasharray="0.01 8" />
          </svg>
          <div class="flex flex-col gap-2 p-2">
            {governance.map((g) => (
              <div class="flex items-center gap-4 rounded-full bg-lavender p-1 pr-8">
                <span class="flex size-7 shrink-0 items-center justify-center rounded-full bg-white">
                  <img src={g.icon} alt="" aria-hidden="true" class="size-5" />
                </span>
                <span class="text-sm font-semibold uppercase text-black">{g.label}</span>
              </div>
            ))}
          </div>
        </div>
        <span class={`whitespace-nowrap ${labelTag}`}>{governedLabel}</span>
      </div>
    </div>
  </div>
</section>

<style>
  /* Black dot that flows down from Patients into the orb. */
  .flow-conn {
    pointer-events: none;
    will-change: transform, opacity;
  }
  .flow-conn--y {
    animation: flow-y linear infinite;
  }

  @keyframes flow-y {
    0% {
      transform: translateY(var(--from));
      opacity: 0;
    }
    14% {
      opacity: 1;
    }
    80% {
      opacity: 1;
    }
    100% {
      transform: translateY(var(--to));
      opacity: 0;
    }
  }

  /* Mobile connector dots — flow toward the orb in lockstep (one runs down
     from the top card, one runs up from the bottom card; same timing). */
  .m-flow {
    pointer-events: none;
    will-change: transform, opacity;
    animation: m-flow 2.4s linear infinite;
  }

  /* Only translateY is animated — horizontal centering is done with `left`
     so the animation's transform can't knock the dot off the line. */
  @keyframes m-flow {
    0%   { transform: translateY(var(--from)); opacity: 0; }
    15%  { opacity: 1; }
    85%  { opacity: 1; }
    100% { transform: translateY(var(--to)); opacity: 0; }
  }

  /* Respect users who prefer reduced motion — no traveling dots. */
  @media (prefers-reduced-motion: reduce) {
    .flow-dot {
      display: none;
    }
    .flow-conn {
      animation: none;
      opacity: 0;
    }
    .m-flow {
      animation: none;
      opacity: 0;
    }
  }
</style>

<script>
  // Scale the fixed 1280-wide diagram down to the container width (never up).
  // Entrance reveal is handled site-wide via [data-reveal] (see Layout.astro).
  const wrap = document.querySelector<HTMLElement>(
    ".platform [data-stage-wrap]",
  );
  const stage = document.querySelector<HTMLElement>(".platform [data-stage]");

  const fit = () => {
    if (!wrap || !stage) return;
    const scale = Math.min(1, wrap.clientWidth / 1280);
    stage.style.transform = `translateX(-50%) scale(${scale})`;
    wrap.style.height = `${781 * scale}px`;
  };

  if (wrap) {
    const ro = new ResizeObserver(fit);
    ro.observe(wrap);
  }
  window.addEventListener("load", fit);
  fit();
</script>
