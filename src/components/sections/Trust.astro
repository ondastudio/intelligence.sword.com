---
/**
 * Trust — "Trusted by the most regulated industry in the world."
 *
 * A rounded lavender panel (with a soft blurred purple bloom) holding a centered
 * editorial headline, a wrapping grid of certification/compliance badges, and
 * three supporting points along the bottom. Each badge is a transparent pill
 * with an inner purple glow ring; its logo is composed from one or more SVG
 * layers positioned at their native Figma offsets. Content comes from
 * src/data/trust.json.
 */
import data from "../../data/trust.json";

const { heading, badges, points } = data;
---

<section class="trust bg-surface overflow-hidden py-[120px]">
  <!-- The panel is a scroll-driven stage: it begins slightly compressed (inset
       with rounded corners), expands to full-bleed (edge-to-edge, square
       corners) as the section reaches the centre of the viewport, then
       compresses again as it scrolls away — same scrubber as the Intro video.
       It sits BEHIND the 1280-wide content, which never moves. -->
  <div data-trust-scroll class="relative mx-auto w-full">
    <!-- The scrubber scales this frame (panel + content together) so the whole
         block compresses and expands as one, then clips the bg's corners. -->
    <div
      data-trust-frame
      class="trust-frame relative overflow-hidden will-change-transform"
    >
      <!-- Decorative panel fill + blurred bloom (stretched to fit) -->
      <img
        src="/trust/bg-frame.svg"
        alt=""
        aria-hidden="true"
        class="pointer-events-none absolute inset-0 z-0 h-full w-full"
      />

      <div
        class="relative z-10 mx-auto flex max-w-[1280px] flex-col items-center gap-20 px-4 pb-[120px] pt-[88px] lg:gap-[120px] lg:pb-[168px]"
      >
      <!-- Heading -->
      <h2
        data-reveal="title"
        class="max-w-[816px] text-center font-serif text-3xl font-normal leading-[1.2] tracking-[-0.02em] text-black sm:text-4xl lg:text-display"
      >
        {heading}
      </h2>

      <!-- Badge grid -->
      <div data-reveal class="flex w-full flex-wrap justify-center gap-5" style="transition-delay:100ms">
        {
          badges.map((badge) => (
            <div class="relative flex h-20 w-60 shrink-0 items-center justify-center overflow-hidden rounded-[40px] backdrop-blur-[2px]">
              {/* inner purple glow ring (blurred border, clipped by the pill) */}
              <span class="pointer-events-none absolute left-1/2 top-0 h-20 w-60 -translate-x-1/2 rounded-[40px] border-[15px] border-purple-200 blur-[8px]" />
              {/* logo, composed from its native-sized layers */}
              <div class="relative" style={`width:${badge.w}px;height:${badge.h}px`}>
                {badge.layers.map((l, i) => (
                  <img
                    src={l.src}
                    alt={i === 0 ? badge.alt : ""}
                    class="absolute block max-w-none"
                    style={`left:${l.x}px;top:${l.y}px;width:${l.w}px;height:${l.h}px`}
                  />
                ))}
              </div>
            </div>
          ))
        }
      </div>

      <!-- Supporting points -->
      <div
        data-reveal
        class="grid w-full grid-cols-1 gap-x-6 gap-y-10 md:grid-cols-3"
        style="transition-delay:200ms"
      >
        {
          points.map((p) => (
            <div class="flex min-h-[218px] flex-col justify-between gap-10 border-l border-black px-6">
              <span class="flex size-12 shrink-0 items-center justify-center rounded-[40px] bg-purple-150 p-2">
                <img src={p.icon} alt="" aria-hidden="true" class="size-8" />
              </span>
              <div class="flex flex-col gap-6 leading-[1.2] text-black">
                <p class="text-xl font-semibold tracking-[-0.02em]">{p.title}</p>
                <p class="text-lg tracking-[-0.02em]">{p.body}</p>
              </div>
            </div>
          ))
        }
      </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Fallback (no JS / reduced motion): the design's contained panel, inset to a
     16px gutter with rounded corners. */
  .trust-frame {
    border-radius: var(--radius-card);
    transform-origin: center center;
    transform: scale(0.978); /* ≈ 16px gutter on a 1440 viewport */
  }

  /* Enhanced: the scrubber drives scale (0.82 → 1) and corner radius
     (40px → 0) per frame; no CSS easing. */
  @media (prefers-reduced-motion: no-preference) {
    :global(html.js) .trust-frame {
      transform: scale(0.82);
    }
  }
</style>

<script>
  // Scroll-driven full-bleed expansion for the Trust panel. Mirrors the Intro
  // video scrubber: map the distance from the panel's centre to the viewport's
  // centre into a 0→1 proximity, ease it, and drive scale (0.82 → 1) and corner
  // radius (40px → 0). Symmetric about centre, so the panel peaks edge-to-edge
  // exactly when the section is centred and compresses back as it leaves.
  function initTrustScroll(stage: HTMLElement) {
    const frame = stage.querySelector<HTMLElement>("[data-trust-frame]");
    if (!frame) return;
    if (!window.matchMedia("(prefers-reduced-motion: no-preference)").matches)
      return;

    const MIN_SCALE = 0.82;
    const MAX_RADIUS = 40; // px — matches --radius-card
    const easeOutCubic = (t: number) => 1 - Math.pow(1 - t, 3);

    let ticking = false;

    const render = () => {
      ticking = false;
      const rect = stage.getBoundingClientRect();
      const vh = window.innerHeight;
      const center = rect.top + rect.height / 2;
      const distance = Math.abs(center - vh / 2);
      // Full effect within one viewport height of dead centre.
      const proximity = Math.max(0, 1 - distance / vh);
      const eased = easeOutCubic(proximity);

      const scale = MIN_SCALE + (1 - MIN_SCALE) * eased;
      const radius = MAX_RADIUS * (1 - eased);
      frame.style.transform = `scale(${scale})`;
      frame.style.borderRadius = `${radius}px`;
    };

    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(render);
    };

    render();
    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onScroll);
  }

  document
    .querySelectorAll<HTMLElement>("[data-trust-scroll]")
    .forEach(initTrustScroll);
</script>
