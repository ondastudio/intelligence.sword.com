---
/**
 * SolutionsTestimonials — the "TESTIMONIALS / Don't take our word for it, take
 * theirs." block on the Solutions page (Figma node 9298:1043, "Testimonial").
 *
 * A centered Eyebrow + Lora headline sit over a decorative purple/blue swirl
 * (a blurred radial blob exported from Figma). Below, a two-cell customer-logo
 * row (each cell topped by a hairline; the second logo dimmed) leads into the
 * testimonial itself: on the left an avatar photo card beside the quote and its
 * attribution; on the right a big serif stat ("10M+" citizens served, its
 * number underlined by a lavender highlight bar) above a "Read case study" CTA
 * pill + filled arrow circle.
 *
 * Below `lg` the two halves stack (avatar over quote, stat/CTA left-aligned).
 * Entrance uses the shared `[data-reveal]` observer (see global.css / Layout).
 *
 * Content-free — copy comes from src/data/solutions.json (`testimonials`).
 */
import Eyebrow from "../ui/Eyebrow.astro";
import PlusChip from "../ui/PlusChip.astro";
import ArrowCircle from "../ui/ArrowCircle.astro";
import solutions from "../../data/solutions.json";

const { eyebrow, heading, logos, quote, author, stat, cta } =
  solutions.testimonials;
---

<section
  class="testimonials relative overflow-hidden px-6 py-20 lg:px-20 lg:py-[120px]"
>
  {/* Decorative swirl — a soft blurred purple/blue bloom behind the content. */}
  <img
    src="/solutions/testimonials/swirl.svg"
    alt=""
    aria-hidden="true"
    class="pointer-events-none absolute left-1/2 top-16 -z-10 w-[1200px] max-w-none -translate-x-1/2 select-none lg:top-24"
  />

  <div
    class="relative mx-auto flex max-w-[1280px] flex-col items-center gap-16 lg:gap-[120px]"
  >
    {/* Header */}
    <div class="flex flex-col items-center gap-6 lg:gap-10">
      <div data-reveal><Eyebrow>{eyebrow}</Eyebrow></div>
      <h2
        data-reveal="title"
        class="max-w-[952px] text-center font-serif text-h5"
      >
        {heading}
      </h2>
    </div>

    {/* Customer logos */}
    <ul class="flex w-full flex-col gap-7 sm:flex-row">
      {
        logos.map((logo, i) => (
          <li
            data-reveal
            class="flex flex-1 flex-col items-center gap-6"
            style={`transition-delay:${i * 100}ms`}
          >
            <span
              data-reveal="line"
              class="h-px w-full origin-left bg-black/24"
            />
            <img
              src={logo.src}
              alt={logo.alt}
              loading="lazy"
              class:list={[
                "max-h-[52px] w-auto object-contain [filter:brightness(0)]",
                logo.muted && "opacity-15",
              ]}
            />
          </li>
        ))
      }
    </ul>

    {/* Testimonial */}
    <div
      class="flex w-full flex-col gap-12 lg:flex-row lg:items-stretch lg:justify-between lg:gap-8"
    >
      {/* Left — avatar + quote */}
      <div
        data-reveal
        class="flex flex-col gap-8 sm:flex-row sm:gap-8 lg:max-w-[772px] lg:flex-1"
      >
        <img
          src={author.avatar}
          alt={author.name}
          loading="lazy"
          class="h-[219px] w-full shrink-0 rounded-card object-cover sm:w-[227px]"
        />
        <div class="flex flex-1 flex-col justify-between gap-8">
          <p class="text-md text-ink">{quote}</p>
          <div class="flex flex-col gap-1">
            <p class="text-sm font-semibold uppercase">{author.name}</p>
            <p class="text-base text-black">{author.role}</p>
          </div>
        </div>
      </div>

      {/* Right — stat + CTA */}
      <div
        data-reveal
        class="flex flex-col justify-between gap-10 lg:items-end lg:text-right"
        style="transition-delay:120ms"
      >
        <div class="flex flex-col items-start gap-4 lg:items-end">
          <div class="flex items-start gap-2">
            <span class="relative">
              <span
                aria-hidden="true"
                class="absolute inset-x-0 bottom-[0.14em] -z-10 h-2 bg-purple-tint"
              ></span>
              <span class="font-serif text-h3">{stat.value}</span>
            </span>
            {stat.plus && <PlusChip class="mt-3" />}
          </div>
          <p class="text-sm font-semibold uppercase">{stat.label}</p>
        </div>

        <div class="group flex items-center">
          <a
            href={cta.href}
            class="flex h-10 items-center rounded-full bg-brand px-6 text-sm font-semibold uppercase text-white"
          >
            {cta.label}
          </a>
          <ArrowCircle
            variant="filled"
            href={cta.href}
            label={cta.label}
            detach
            class="-ml-px"
          />
        </div>
      </div>
    </div>
  </div>
</section>
