---
/**
 * ClinicalLayer — "The clinical intelligence layer between your patients and
 * your tech stack." (Figma "Clinical Intelligence Layer", 8718:1332).
 *
 * A centered Lora title (purple "clinical intelligence layer" accent) over a
 * row that pairs a left-hugging column of three frosted (`bg-ink-wash`)
 * capability cards — each a LabelPill above a short centered Figtree
 * description — with the patients→tech-stack node diagram on the right.
 *
 * The diagram has two states that crossfade as the section pins: state A is the
 * "01 / Channels" beat (`ClinicalDiagram`); as the reader scrolls on toward the
 * next section the stage holds and the illustration resolves into the
 * "02 / Clinical intelligence" beat (`ClinicalDiagram02`), the step chip
 * swapping 01→02 with it. Both diagrams share one slot; a vanilla rAF scrubber
 * maps scroll progress into the crossfade — the same mechanism SolutionsHandoff
 * uses. Gated on motion + JS + lg+: without them the two states render as
 * normal stacked figures (each with its own chip), both fully legible.
 *
 * Content comes from src/data/clinical-layer.json.
 */
import LabelPill from "../ui/LabelPill.astro";
import ClinicalStepPill from "../ui/ClinicalStepPill.astro";
import ClinicalDiagram from "../ui/ClinicalDiagram.astro";
import ClinicalDiagram02 from "../ui/ClinicalDiagram02.astro";
import ClinicalDiagram03 from "../ui/ClinicalDiagram03.astro";
import ClinicalDiagram04 from "../ui/ClinicalDiagram04.astro";
import ClinicalDiagram05 from "../ui/ClinicalDiagram05.astro";
import ClinicalDiagram06 from "../ui/ClinicalDiagram06.astro";
import ClinicalLogoMarquee from "../ui/ClinicalLogoMarquee.astro";
import data from "../../data/clinical-layer.json";

const { heading, steps, cards, integrationLogos, closing } = data;
---

<section data-clinical-layer class="clinical-layer relative text-black">
  <!-- DESKTOP (lg+): the pinned, side-by-side crossfade stage. Hidden below lg,
       where the mobile layout below takes over. -->
  <div data-clinical-stage class="clinical-stage hidden lg:block">
    <div class="mx-auto w-full max-w-[1440px] px-4 sm:px-6 lg:px-20">
      <!-- Title -->
      <h2
        data-reveal="title"
        class="mx-auto max-w-[980px] text-center font-serif text-h5 font-normal"
      >
        {heading.before}<span class="text-brand">{heading.accent}</span>{
          heading.after
        }
      </h2>

      <!-- Cards (left) + crossfading diagram (right). On lg+ the row is pinned
           centred in the viewport (.clinical-pin) so the whole illustration is
           visible while the title scrolls away above it. Stacks on mobile. -->
      <div class="clinical-pin">
        <!-- Animated swirl bloom behind the diagram — the shared hero swirl in a
           soft brand-blue palette. Lives inside the pin so it tracks the pinned
           illustration across the beats; `-z-10` keeps it behind the row, over
           the section surface. A CSS radial wash is the no-JS / reduced-motion
           fallback. -->
        <div
          data-cl-swirl-stage
          aria-hidden="true"
          class="cl-swirl pointer-events-none absolute -z-10"
        >
          <canvas
            data-cl-swirl
            class="absolute inset-0 h-full w-full opacity-0 transition-opacity duration-700"
          ></canvas>
        </div>
        <div
          class="clinical-row mt-12 flex flex-col items-center gap-16 lg:mt-[120px] lg:flex-row lg:items-center lg:justify-between lg:gap-0"
        >
          <!-- Card column: two layers share one slot. The original capability
             cards (state "a") are held through beats A–F; on the final beat they
             crossfade out to the alternate "Complex operations" card set
             (state "b"), in sync with the diagram swapping to ClinicalDiagram06.
             On mobile / no-JS both layers stack in normal flow. -->
          <div class="clinical-cards relative w-full max-w-[340px]">
            <div data-clinical-cards="a" class="flex flex-col gap-4">
              {
                cards.map((card, i) => (
                  <div
                    data-reveal
                    class="flex flex-col items-center justify-center gap-5 rounded-card bg-ink-wash p-8"
                    style={`transition-delay:${120 + (cards.length - 1 - i) * 120}ms`}
                  >
                    <LabelPill>{card.label}</LabelPill>
                    <p class="text-center text-xmd leading-[1.25]">
                      {card.lines.map((line, j) => (
                        <>
                          {j > 0 && <br />}
                          {line}
                        </>
                      ))}
                    </p>
                  </div>
                ))
              }
            </div>
            <!-- Alternate column for the closing beat: the same HTML the mobile
                 closing block renders, driven by the shared `closing` data
                 (Figma 8797:58230). Was a baked SVG (ClinicalCards06); now real,
                 editable HTML so copy lives in one place (clinical-layer.json). -->
            <div
              data-clinical-cards="b"
              class="clinical-cards-alt flex w-full flex-col items-center gap-[34px]"
            >
              <div class="flex flex-col items-center gap-[10px] text-center">
                <h3 class="text-[1.75rem] font-normal leading-[1.15]">
                  {closing.heading[0]}<br />{closing.heading[1]}
                </h3>
                <p class="text-[1.25rem] leading-[1.2]">
                  {
                    closing.subtitle.map((seg) =>
                      seg.bold ? (
                        <span class="font-semibold">{seg.text}</span>
                      ) : (
                        <>
                          {seg.text}
                          {seg.br && <br />}
                        </>
                      ),
                    )
                  }
                </p>
              </div>
              <div class="flex w-full flex-col gap-4">
                {
                  closing.cards.map((card) => (
                    <div class="flex flex-col items-center justify-center gap-5 rounded-card bg-purple-tint p-8 backdrop-blur-[30px]">
                      <span class="grid size-10 place-items-center rounded-full border border-black/24">
                        <img
                          src={card.icon}
                          alt={card.alt}
                          width="25"
                          height="25"
                          class="size-[25px]"
                        />
                      </span>
                      <p class="text-center text-xmd leading-[1.25]">
                        {card.segments.map((seg) =>
                          seg.bold ? (
                            <span class="font-semibold">{seg.text}</span>
                          ) : (
                            <>
                              {seg.text}
                              {seg.br && <br />}
                            </>
                          ),
                        )}
                      </p>
                    </div>
                  ))
                }
              </div>
            </div>
          </div>

          <!-- Diagram stack: both states share one slot and crossfade. Each state
             carries its own top-left step chip (inlined SVGs so the icon-disc
             backdrop-filter blur chips render). -->
          <div class="clinical-diagrams w-full max-w-[827px]">
            <div data-clinical-state="a" class="clinical-state">
              <div
                class="clinical-figure relative mx-auto w-full max-w-[827px]"
              >
                <ClinicalStepPill
                  num={steps[0].num}
                  label={steps[0].label}
                  class="absolute left-0 top-0 z-10"
                />
                <ClinicalDiagram />
              </div>
            </div>
            <div data-clinical-state="b" class="clinical-state">
              <div
                class="clinical-figure relative mx-auto w-full max-w-[827px]"
              >
                <ClinicalStepPill
                  num={steps[1].num}
                  label={steps[1].label}
                  class="absolute left-0 top-0 z-10"
                />
                <ClinicalDiagram02 />
              </div>
            </div>
            <div data-clinical-state="c" class="clinical-state">
              <div
                class="clinical-figure relative mx-auto w-full max-w-[827px]"
              >
                <ClinicalStepPill
                  num={steps[2].num}
                  label={steps[2].label}
                  class="absolute left-0 top-0 z-10"
                />
                <ClinicalDiagram03 />
              </div>
            </div>
            <div data-clinical-state="d" class="clinical-state">
              <div
                class="clinical-figure relative mx-auto w-full max-w-[827px]"
              >
                <ClinicalStepPill
                  num={steps[3].num}
                  label={steps[3].label}
                  class="absolute left-0 top-0 z-10"
                />
                <ClinicalDiagram04 logos={integrationLogos} />
              </div>
            </div>
            <div data-clinical-state="e" class="clinical-state">
              <div
                class="clinical-figure relative mx-auto w-full max-w-[827px]"
              >
                <ClinicalStepPill
                  num={steps[4].num}
                  label={steps[4].label}
                  class="absolute left-0 top-0 z-10"
                />
                <ClinicalDiagram05 />
              </div>
            </div>
            <!-- Closing beat: no step chip — pairs with the alternate card set. -->
            <div data-clinical-state="f" class="clinical-state">
              <div
                class="clinical-figure relative mx-auto w-full max-w-[827px]"
              >
                <ClinicalDiagram06 />
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- MOBILE (below lg). Three stacked blocks, matching the mobile Figma
       (8797:51970): (1) title + capability cards; (2) a pinned crossfade of the
       Channels→Data-foundation beats (A–F); (3) the closing "Complex operations"
       beat pulled into its own static section with its own title + card set.
       The desktop side-by-side pin above is hidden here. -->
  <div class="clinical-mobile lg:hidden">
    <!-- Swirl bloom — a single soft glow held fixed in the viewport (via a
         sticky zero-height anchor) so it stays centred behind every card and
         illustration for the whole mobile section, then scrolls away with it.
         Sits behind all content (negative z within the section's own stacking
         context). CSS radial wash is the no-JS / reduced-motion fallback. -->
    <div class="cl-swirl-fixed" aria-hidden="true">
      <div
        data-cl-swirl-stage
        class="cl-swirl-m pointer-events-none absolute opacity-0"
      >
        <canvas data-cl-swirl class="absolute inset-0 h-full w-full opacity-0"
        ></canvas>
      </div>
    </div>

    <!-- Block 1 — title over three capability cards -->
    <div class="relative mx-auto w-full max-w-[420px] px-5 pt-[120px]">
      <h2
        data-reveal="title"
        class="mx-auto max-w-[320px] text-center font-serif text-h5 font-normal"
      >
        {heading.before}<span class="text-brand">{heading.accent}</span>{
          heading.after
        }
      </h2>

      <div class="mt-16 flex flex-col gap-2">
        {
          cards.map((card, i) => (
            <div
              data-reveal
              class="flex flex-col items-center justify-center gap-5 rounded-card bg-ink-wash p-8 backdrop-blur-[30px]"
              style={`transition-delay:${i * 80}ms`}
            >
              <LabelPill>{card.label}</LabelPill>
              <p class="text-center text-xmd leading-[1.25]">
                {card.lines.map((line, j) => (
                  <>
                    {j > 0 && <br />}
                    {line}
                  </>
                ))}
              </p>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Block 2 — pinned crossfade of beats A–F. Each state is a step chip above
         its diagram; the six states overlap in one slot and crossfade as the pin
         scrolls. No-JS / reduced-motion: the states fall back to a normal stack. -->
    <div data-clinical-m-pin class="clinical-m-pin mt-[120px]">
      <div class="clinical-m-sticky">
        <div class="mx-auto w-full max-w-[420px] px-5 md:max-w-[610px]">
          <div class="clinical-m-diagrams relative">
            <div data-cm-state="a" class="clinical-m-state">
              <ClinicalStepPill
                num={steps[0].num}
                label={steps[0].label}
                class="mb-6"
              />
              <ClinicalDiagram class="mt-8" />
            </div>
            <div data-cm-state="b" class="clinical-m-state">
              <ClinicalStepPill
                num={steps[1].num}
                label={steps[1].label}
                class="mb-6"
              />
              <ClinicalDiagram02 class="mt-8" />
            </div>
            <div data-cm-state="c" class="clinical-m-state">
              <ClinicalStepPill
                num={steps[2].num}
                label={steps[2].label}
                class="mb-6"
              />
              <ClinicalDiagram03 class="mt-8" />
            </div>
            <div data-cm-state="d" class="clinical-m-state">
              <ClinicalStepPill
                num={steps[3].num}
                label={steps[3].label}
                class="mb-6"
              />
              <ClinicalDiagram04 card={false} />
              <!-- On mobile the floating EHR logo card moves out of the diagram
                   into its own frosted card below: an "EHR" label over the two
                   scrolling logo marquee rows. -->
              <div
                class="mt-6 flex flex-col items-center gap-6 rounded-card bg-ink-wash p-6 backdrop-blur-[30px]"
              >
                <LabelPill>EHR</LabelPill>
                <div class="h-20 w-full">
                  <ClinicalLogoMarquee rows={integrationLogos} />
                </div>
              </div>
            </div>
            <div data-cm-state="e" class="clinical-m-state">
              <ClinicalStepPill
                num={steps[4].num}
                label={steps[4].label}
                class="mb-6"
              />
              <ClinicalDiagram05 class="mt-8" />
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Block 3 — the closing "Complex operations" beat: its own title + subtitle
         over the dashboards illustration and the alternate card set. The shared
         fixed swirl bloom (top of .clinical-mobile) sits behind this too. -->
    <div class="clinical-m-closing relative mt-[120px] pb-[120px]">
      <div class="relative">
        <div class="mx-auto w-full max-w-[420px] px-5">
          <div data-reveal="title" class="text-center">
            <h3 class="text-h5 font-normal leading-[1.15]">
              {closing.heading[0]}<br />{closing.heading[1]}
            </h3>
            <p class="mx-auto mt-4 max-w-[300px] text-[1.25rem] leading-[1.2]">
              {
                closing.subtitle.map((seg) =>
                  seg.bold ? (
                    <span class="font-semibold">{seg.text}</span>
                  ) : (
                    <>
                      {seg.text}
                      {seg.br && <br />}
                    </>
                  ),
                )
              }
            </p>
          </div>
          <div data-reveal class="mt-16">
            <ClinicalDiagram06 />
          </div>
        </div>
      </div>

      <div class="mx-auto mt-16 flex w-full max-w-[420px] flex-col gap-4 px-5">
        {
          closing.cards.map((card, i) => (
            <div
              data-reveal
              class="flex flex-col items-center justify-center gap-5 rounded-card bg-purple-tint p-8 backdrop-blur-[30px]"
              style={`transition-delay:${i * 80}ms`}
            >
              <span class="grid size-10 place-items-center rounded-full border border-black/24">
                <img src={card.icon} alt={card.alt} width="25" height="25" class="size-[25px]" />
              </span>
              <p class="text-center text-xmd leading-[1.25]">
                {card.segments.map((seg) =>
                  seg.bold ? (
                    <span class="font-semibold">{seg.text}</span>
                  ) : (
                    <>
                      {seg.text}
                      {seg.br && <br />}
                    </>
                  ),
                )}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<script>
  // Pinned crossfade between the two diagram states. The stage is sticky inside
  // a taller section; progress is how far the section has scrolled past the top,
  // normalised to its scrub distance (same mechanism as SolutionsHandoff /
  // AboutOperations). Gated on motion + lg+ (matching the CSS); otherwise the
  // two states stay in normal stacked flow.
  function initClinicalLayer(section: HTMLElement) {
    const enabled = () =>
      window.matchMedia(
        "(prefers-reduced-motion: no-preference) and (min-width: 1024px)",
      ).matches;

    const stateA = section.querySelector<HTMLElement>(
      '[data-clinical-state="a"]',
    );
    const stateB = section.querySelector<HTMLElement>(
      '[data-clinical-state="b"]',
    );
    const stateC = section.querySelector<HTMLElement>(
      '[data-clinical-state="c"]',
    );
    const stateD = section.querySelector<HTMLElement>(
      '[data-clinical-state="d"]',
    );
    const stateE = section.querySelector<HTMLElement>(
      '[data-clinical-state="e"]',
    );
    const stateF = section.querySelector<HTMLElement>(
      '[data-clinical-state="f"]',
    );
    const cardsA = section.querySelector<HTMLElement>(
      '[data-clinical-cards="a"]',
    );
    const cardsB = section.querySelector<HTMLElement>(
      '[data-clinical-cards="b"]',
    );
    const title = section.querySelector<HTMLElement>('[data-reveal="title"]');
    if (
      !stateA ||
      !stateB ||
      !stateC ||
      !stateD ||
      !stateE ||
      !stateF
    )
      return;

    // Timeline windows over the section's scrub distance (easy to tune). Six
    // beats chain through one slot: Channels (A) is held first, then crossfades
    // to Clinical intelligence (B) → AI Skills (C) → Integrations (D) → Clinical
    // data foundation (E) → the closing "Complex operations" view (F), each
    // holding before crossfading on to the next; F settles and holds just before
    // the pin releases. On the final beat the LEFT card column crossfades too
    // (cardsA → cardsB), in sync with E→F. Each beat gets a hold so the reader
    // sees the whole illustration before it resolves.
    const TITLE_OUT: [number, number] = [0.02, 0.07]; // title fades up + out early
    const A_OUT: [number, number] = [0.11, 0.19]; // Channels fades + blurs away
    const B_IN: [number, number] = [0.13, 0.21]; // Clinical resolves out of blur
    const B_OUT: [number, number] = [0.28, 0.36]; // Clinical fades + blurs away
    const C_IN: [number, number] = [0.3, 0.38]; // AI Skills resolves out of blur
    const C_OUT: [number, number] = [0.45, 0.53]; // AI Skills fades + blurs away
    const D_IN: [number, number] = [0.47, 0.55]; // Integrations resolves out of blur
    const D_OUT: [number, number] = [0.62, 0.7]; // Integrations fades + blurs away
    const E_IN: [number, number] = [0.64, 0.72]; // Data foundation resolves out of blur
    const E_OUT: [number, number] = [0.79, 0.87]; // Data foundation fades + blurs away
    const F_IN: [number, number] = [0.81, 0.89]; // Closing view resolves out of blur
    const BLUR = 12; // px — start blur for each incoming/outgoing state

    const track = (p: number, [a, b]: [number, number]) =>
      Math.min(1, Math.max(0, (p - a) / (b - a)));
    const easeOutCubic = (t: number) => 1 - Math.pow(1 - t, 3);

    const clearStyles = (el: HTMLElement) => {
      el.style.opacity = "";
      el.style.filter = "";
    };

    // Apply a beat's opacity + blur. iOS Safari vibrates a `position: sticky`
    // element through the whole momentum tail whenever a `filter` layer lives
    // inside it and the page is still scrolling — and these states otherwise
    // keep a `filter: blur()` set at ALL times, including on fully-hidden beats
    // (blur 12px at opacity 0) and on the resting/held beat (blur 0). Those idle
    // filter layers are exactly what shakes. So only keep `filter` set while a
    // beat is actually mid-transition (visible AND blurred); drop it entirely
    // once the beat is hidden or fully resolved. The visible blur-resolve is
    // unchanged — it only ever runs while opacity and blur are both non-trivial.
    const paint = (el: HTMLElement, opacity: number, blurPx: number) => {
      el.style.opacity = String(opacity);
      // `none` (not "") so it overrides the CSS pre-set `filter: blur(12px)` on
      // the hidden states — clearing to "" would fall back to that and both keep
      // the idle layer and blur a held-visible beat.
      el.style.filter =
        opacity < 0.01 || blurPx < 0.15 ? "none" : `blur(${blurPx}px)`;
    };

    let ticking = false;

    const render = () => {
      ticking = false;

      // Disabled (small screen / reduced motion): hand styling back to the CSS
      // fallback so both states render in normal stacked flow.
      if (!enabled()) {
        clearStyles(stateA);
        clearStyles(stateB);
        clearStyles(stateC);
        clearStyles(stateD);
        clearStyles(stateE);
        clearStyles(stateF);
        if (cardsA) clearStyles(cardsA);
        if (cardsB) {
          clearStyles(cardsB);
          cardsB.style.top = "";
        }
        if (title) {
          title.style.transition = "";
          title.style.opacity = "";
        }
        return;
      }

      const scrub = section.offsetHeight - window.innerHeight;
      const p =
        scrub > 0
          ? Math.min(
              1,
              Math.max(0, -section.getBoundingClientRect().top / scrub),
            )
          : 0;

      // Title: hold through its data-reveal entrance (blur resolve), then fade up
      // + out as the reader scrolls on, handing the stage to the cards +
      // illustration. Before the fade window we leave it to the CSS reveal so the
      // entrance isn't clobbered; once it opens we kill the reveal's 0.8s opacity
      // transition so the fade tracks scroll 1:1 instead of lagging behind it.
      if (title) {
        const tOut = track(p, TITLE_OUT);
        if (tOut > 0) {
          title.style.transition = "none";
          title.style.opacity = String(1 - easeOutCubic(tOut));
        } else {
          title.style.transition = "";
          title.style.opacity = "";
        }
      }

      const aOut = easeOutCubic(track(p, A_OUT));
      paint(stateA, 1 - aOut, aOut * BLUR);

      // B both resolves in (from A) and later blurs back out (to C): opacity is
      // the product of the two tracks, blur is the sum of the incoming +
      // outgoing amounts (both 0 during B's hold).
      const bIn = easeOutCubic(track(p, B_IN));
      const bOut = easeOutCubic(track(p, B_OUT));
      paint(stateB, bIn * (1 - bOut), (1 - bIn + bOut) * BLUR);

      // C, like B, resolves in (from B) then later blurs out (to D).
      const cIn = easeOutCubic(track(p, C_IN));
      const cOut = easeOutCubic(track(p, C_OUT));
      paint(stateC, cIn * (1 - cOut), (1 - cIn + cOut) * BLUR);

      // D, like B and C, resolves in (from C) then later blurs out (to E).
      const dIn = easeOutCubic(track(p, D_IN));
      const dOut = easeOutCubic(track(p, D_OUT));
      paint(stateD, dIn * (1 - dOut), (1 - dIn + dOut) * BLUR);

      // E, like B–D, resolves in (from D) then later blurs out (to F).
      const eIn = easeOutCubic(track(p, E_IN));
      const eOut = easeOutCubic(track(p, E_OUT));
      paint(stateE, eIn * (1 - eOut), (1 - eIn + eOut) * BLUR);

      // F resolves in (from E) and holds on the final beat.
      const fIn = easeOutCubic(track(p, F_IN));
      paint(stateF, fIn, (1 - fIn) * BLUR);

      // Left card column swaps in lockstep with the E→F diagram crossfade: the
      // original cards (A) blur out over E_OUT, the alternate set (B) resolves in
      // over F_IN.
      if (cardsA && cardsB) {
        paint(cardsA, 1 - eOut, eOut * BLUR);
        paint(cardsB, fIn, (1 - fIn) * BLUR);

        // Centre the closing set (heading + subtext + cards) on the viewport's
        // vertical midline while the pin is held. The pinned row is anchored 80px
        // from the top — not viewport-centred — so a static column-relative centre
        // reads low; offset cardsB to the true viewport centre instead. Once the
        // pin releases (rawP > 1) clear the override so it scrolls away with the
        // column.
        const rawP =
          scrub > 0 ? -section.getBoundingClientRect().top / scrub : 0;
        const col = cardsB.parentElement;
        if (col && rawP >= 0 && rawP <= 1) {
          const colTop = col.getBoundingClientRect().top;
          cardsB.style.top = `${window.innerHeight / 2 - colTop - cardsB.offsetHeight / 2}px`;
        } else {
          cardsB.style.top = "";
        }
      }
    };

    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(render);
    };

    render();
    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onScroll);
  }

  document
    .querySelectorAll<HTMLElement>("[data-clinical-layer]")
    .forEach(initClinicalLayer);

  // Mobile (<lg) crossfade: the same pinned-scrubber mechanism, but over the five
  // beats A–E only (the closing beat lives in its own static block below). The
  // pin is a tall section with a sticky stage; progress is how far the pin has
  // scrolled past the top of the viewport. Gated on motion + max-width:1023px
  // (matching the CSS); otherwise the five states stay in normal stacked flow.
  function initClinicalMobile(pin: HTMLElement) {
    const enabled = () =>
      window.matchMedia(
        "(prefers-reduced-motion: no-preference) and (max-width: 1023px)",
      ).matches;

    const keys = ["a", "b", "c", "d", "e"] as const;
    const states = keys.map((k) =>
      pin.querySelector<HTMLElement>(`[data-cm-state="${k}"]`),
    );
    if (states.some((s) => !s)) return;
    const [a, b, c, d, e] = states as HTMLElement[];

    // The pinned diagram stage, driven through three phases (before → fixed →
    // after) instead of `position: sticky` — see the CSS note. `position: fixed`
    // during the pin keeps the artwork from re-rasterising each scroll frame, so
    // the embedded backdrop-filter nodes stop vibrating on iOS during momentum.
    const stage = pin.querySelector<HTMLElement>(".clinical-m-sticky");
    const PIN_PHASES = ["cl-before", "cl-fixed", "cl-after"];
    let lastPhase = "";
    const setPinPhase = () => {
      if (!stage) return;
      if (!enabled()) {
        if (lastPhase) {
          stage.classList.remove(...PIN_PHASES);
          lastPhase = "";
        }
        return;
      }
      const r = pin.getBoundingClientRect();
      const vh = window.innerHeight;
      // Match `position: sticky; top: 0` exactly: park at the top until the
      // track reaches the viewport top, hold fixed while the track spans the
      // viewport, then park at the bottom for the final stage-height of scroll.
      const phase =
        r.top > 0 ? "cl-before" : r.bottom <= vh ? "cl-after" : "cl-fixed";
      if (phase !== lastPhase) {
        stage.classList.remove(...PIN_PHASES);
        stage.classList.add(phase);
        lastPhase = phase;
      }
    };

    // Bloom: scroll-driven so it only shows behind the illustrations. It fades
    // in as the pinned illustrations take over from the capability cards, holds
    // through the beats + the closing dashboard, then fades out as the closing
    // "Complex operations" title scrolls off the top of the viewport.
    const mobileRoot = pin.closest<HTMLElement>(".clinical-mobile");
    // Drive opacity on the stage (not the canvas) so its CSS gradient fallback
    // fades with the canvas rather than lingering in the cards section.
    const bloom = mobileRoot?.querySelector<HTMLElement>(".cl-swirl-m");
    const closingTitle = mobileRoot?.querySelector<HTMLElement>(
      '.clinical-m-closing [data-reveal="title"]',
    );
    const BLOOM_MAX = 0.55;
    const updateBloom = () => {
      if (!bloom) return;
      const vh = window.innerHeight;
      // Fade in as the pin nears its pinned position (illustrations on screen).
      const pinTop = pin.getBoundingClientRect().top;
      const inT = Math.min(1, Math.max(0, (vh * 0.45 - pinTop) / (vh * 0.45)));
      // Fade out as the closing title's bottom crosses the top of the viewport.
      let outT = 0;
      if (closingTitle) {
        const tb = closingTitle.getBoundingClientRect().bottom;
        outT = Math.min(1, Math.max(0, (vh * 0.2 - tb) / (vh * 0.2)));
      }
      bloom.style.opacity = String(BLOOM_MAX * inT * (1 - outT));
    };

    // Timeline windows over the pin's scrub distance: A holds then blurs out,
    // B–D each resolve in then blur back out, E resolves in last and holds.
    const A_OUT: [number, number] = [0.14, 0.22];
    const B_IN: [number, number] = [0.16, 0.24];
    const B_OUT: [number, number] = [0.36, 0.44];
    const C_IN: [number, number] = [0.38, 0.46];
    const C_OUT: [number, number] = [0.58, 0.66];
    const D_IN: [number, number] = [0.6, 0.68];
    const D_OUT: [number, number] = [0.78, 0.86];
    const E_IN: [number, number] = [0.8, 0.88];
    const BLUR = 12;

    const track = (p: number, [x, y]: [number, number]) =>
      Math.min(1, Math.max(0, (p - x) / (y - x)));
    const ease = (t: number) => 1 - Math.pow(1 - t, 3);
    const clear = (el: HTMLElement) => {
      el.style.opacity = "";
      el.style.filter = "";
    };
    // Only keep a `filter: blur()` layer set on a beat while it is actually
    // mid-transition (visible AND blurred). Hidden and fully-resolved beats drop
    // the filter entirely — an idle filter layer inside the sticky stage is what
    // makes iOS Safari vibrate the pinned block through the momentum tail. The
    // visible blur-resolve is unchanged (it only runs while both are non-zero).
    const paint = (el: HTMLElement, opacity: number, blurPx: number) => {
      el.style.opacity = String(opacity);
      // `none` (not "") so it overrides the CSS pre-set `filter: blur(12px)` on
      // the hidden states — clearing to "" would fall back to that and both keep
      // the idle layer and blur a held-visible beat.
      el.style.filter =
        opacity < 0.01 || blurPx < 0.15 ? "none" : `blur(${blurPx}px)`;
    };

    let ticking = false;
    const render = () => {
      ticking = false;
      // Park/pin the stage (before → fixed → after) before anything else.
      setPinPhase();
      // Bloom opacity tracks scroll regardless of the crossfade's motion gate.
      updateBloom();
      if (!enabled()) {
        (states as HTMLElement[]).forEach(clear);
        return;
      }

      const scrub = pin.offsetHeight - window.innerHeight;
      const p =
        scrub > 0
          ? Math.min(1, Math.max(0, -pin.getBoundingClientRect().top / scrub))
          : 0;

      const aOut = ease(track(p, A_OUT));
      paint(a, 1 - aOut, aOut * BLUR);

      const bIn = ease(track(p, B_IN));
      const bOut = ease(track(p, B_OUT));
      paint(b, bIn * (1 - bOut), (1 - bIn + bOut) * BLUR);

      const cIn = ease(track(p, C_IN));
      const cOut = ease(track(p, C_OUT));
      paint(c, cIn * (1 - cOut), (1 - cIn + cOut) * BLUR);

      const dIn = ease(track(p, D_IN));
      const dOut = ease(track(p, D_OUT));
      paint(d, dIn * (1 - dOut), (1 - dIn + dOut) * BLUR);

      const eIn = ease(track(p, E_IN));
      paint(e, eIn, (1 - eIn) * BLUR);
    };

    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(render);
    };

    render();
    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onScroll);
  }

  document
    .querySelectorAll<HTMLElement>("[data-clinical-m-pin]")
    .forEach(initClinicalMobile);
</script>

<style>
  /* Base = no-JS / reduced-motion / small-screen fallback: normal flow, the two
     diagram states stack vertically (each with its own chip), both legible. */
  .clinical-stage {
    padding-block: clamp(5rem, 12vw, 121px) clamp(2.5rem, 6vw, 10px);
  }
  .clinical-state {
    position: relative;
  }
  .clinical-state + .clinical-state {
    margin-top: clamp(2.5rem, 6vw, 64px);
  }
  /* Fallback (no-JS / reduced-motion / small screen): the alternate card set
     simply stacks below the original cards, with a gap. */
  .clinical-cards-alt {
    margin-top: clamp(2.5rem, 6vw, 64px);
  }

  /* Enhanced: pin the stage and crossfade the two diagram states as one.
     Pre-setting the start state keeps the first paint flash-free before the rAF
     loop runs. */
  @media (prefers-reduced-motion: no-preference) and (min-width: 1024px) {
    :global(html.js) .clinical-layer {
      height: calc(100svh + 450vh);
    }
    /* Stage + its inner container span the whole tall section so the pin can
       stay stuck across the full scrub distance. */
    :global(html.js) .clinical-stage {
      height: 100%;
      padding-block: clamp(4rem, 9vw, 96px) 0;
    }
    :global(html.js) .clinical-stage > div {
      height: 100%;
    }
    /* The title appears in flow at the top, a fixed 120px above the cards +
       diagram row. The row pins 80px below the top of the viewport so the held
       illustration sits with an 80px top + 32px bottom margin; as the reader
       scrolls the title fades up and out (JS) while the pinned row stays put —
       you see the title, it fades, then the cards + illustration, which crossfade
       01→02. margin-top is the in-flow 120px gap; `top` is the pinned offset. */
    :global(html.js) .clinical-pin {
      position: sticky;
      top: 80px;
      margin-top: 120px;
    }
    :global(html.js) .clinical-row {
      margin-top: 0;
    }
    /* The diagram column becomes a positioning context; both states overlap in
       one slot. State A stays in flow (defines the height); State B sits over it
       and starts hidden. The figure keeps its native max-w-[827px] sizing — the
       diagram is shown at the same dimensions as the un-pinned design. */
    :global(html.js) .clinical-diagrams {
      position: relative;
      /* Keep the native 827×811 illustration whenever it fits; if the viewport is
         too short to hold it under the 80px top + 32px bottom margins, scale it
         down by width (the SVG's viewBox preserves the aspect ratio) so those
         margins are honoured exactly. Both crossfade states are w-full of this
         column, so constraining it here keeps them aligned. */
      width: min(827px, calc((100svh - 112px) * 827 / 811));
    }
    /* Drop the fallback sibling gap so State B overlaps State A exactly (a
       leftover margin-top would push the absolute panel down + shrink it). */
    :global(html.js) .clinical-state + .clinical-state {
      margin-top: 0;
    }
    :global(html.js) [data-clinical-state="b"],
    :global(html.js) [data-clinical-state="c"],
    :global(html.js) [data-clinical-state="d"],
    :global(html.js) [data-clinical-state="e"],
    :global(html.js) [data-clinical-state="f"] {
      position: absolute;
      inset: 0;
      opacity: 0;
      filter: blur(12px);
    }
    /* The closing illustration (ClinicalDiagram06) is wider than the others, so
       at the shared column width it scales shorter — bottom-align it within the
       slot so its baseline matches the previous beats instead of floating up. */
    :global(html.js) [data-clinical-state="f"] {
      display: flex;
      align-items: flex-end;
    }
    /* Card column becomes a positioning context too: the original cards (A) stay
       in flow and define the column height; the alternate set (B) overlays from
       the top, starts hidden, and crossfades in on the final beat. Drop the
       fallback stacking gap so B sits flush over A. */
    :global(html.js) .clinical-cards-alt {
      margin-top: 0;
    }
    :global(html.js) [data-clinical-cards="b"] {
      position: absolute;
      /* `top` is driven by the scrubber so the closing set sits on the viewport's
         vertical midline while the pin is held (the pinned row is anchored 80px
         from the top, so a static column-relative centre reads low). This `top: 0`
         is just the pre-script default. */
      top: 0;
      left: 0;
      /* Full width of the 340px card column. (This is now HTML that reflows, so
         the old SVG-aspect width scaling no longer applies — the column simply
         takes the column width and lays its cards out in normal flow.) */
      width: 100%;
      opacity: 0;
      filter: blur(12px);
    }
  }

  /* Tablet / small-desktop range (lg up to 1300px): the side-by-side stage is
     active but horizontal space is tight, so shrink the diagram 40px below its
     native size (827 → 787) so it sits more comfortably beside the cards. The
     height-constrained term is unchanged so short viewports still fit. */
  @media (prefers-reduced-motion: no-preference) and (min-width: 1024px) and (max-width: 1300px) {
    :global(html.js) .clinical-diagrams {
      width: min(787px, calc((100svh - 112px) * 827 / 811));
    }
  }

  /* ====================================================================
     MOBILE (<lg) — cards stacked above the illustration; A–F crossfade in
     a pinned stage; the closing beat is its own static block.
     ==================================================================== */
  .clinical-mobile {
    /* Own stacking context so the negative-z bloom sits behind this section's
       content but never bleeds onto neighbouring sections. */
    position: relative;
    isolation: isolate;
    /* Clip the swirl bloom horizontally so it can't add a scrollbar. */
    overflow-x: clip;
  }

  /* Fixed-in-viewport swirl bloom: a sticky, zero-height anchor pinned to the
     top of the viewport for the whole section, holding the bloom centred behind
     every card + illustration. Sits behind the section's content (z below the
     blocks, inside .clinical-mobile's isolated stacking context). */
  .cl-swirl-fixed {
    position: sticky;
    top: 0;
    z-index: -1;
    height: 0;
  }

  /* Fallback (no-JS / reduced-motion): the six A–F states stack vertically,
     each its own chip + diagram. */
  .clinical-m-state + .clinical-m-state {
    margin-top: clamp(2.5rem, 8vw, 64px);
  }

  /* Enhanced: pin the stage and crossfade the six states as one. Pre-setting
     the start state keeps the first paint flash-free before the rAF loop runs. */
  @media (prefers-reduced-motion: no-preference) and (max-width: 1023px) {
    :global(html.js) .clinical-m-pin {
      height: calc(100svh + 336vh);
      /* Positioning context for the JS-driven pin's before/after parked phases. */
      position: relative;
    }
    /* The pinned diagram stage. `position: sticky` is the no-JS-fallback / initial
       state; once the pin controller runs it drives the stage through three
       phases via classes below. We use JS-toggled `position: fixed` (not sticky)
       for the pinned phase because iOS Safari re-rasterises a `position: sticky`
       element's sub-pixel position every frame during momentum scrolling, which
       makes the diagrams' embedded `backdrop-filter` nodes visibly vibrate all
       through the momentum tail. A truly `fixed` element is locked to the
       viewport — its painted position never changes during scroll — so the
       artwork stays rock-steady while the page scrolls behind it. */
    :global(html.js) .clinical-m-sticky {
      position: sticky;
      top: 0;
      display: flex;
      height: 100svh;
      align-items: center;
      /* Nudge the centered artwork + step pill ~40px below true viewport centre
         so it reads as better balanced under the floating page nav. The content
         is vertically centred, so the padding is halved into the offset — 80px
         padding ≈ a 40px downward shift. */
      padding-top: 80px;
    }
    /* Before the pin: parked at the top of the track, scrolling in normally. */
    :global(html.js) .clinical-m-sticky.cl-before {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
    }
    /* During the pin: locked to the viewport (no per-frame reposition → no shake). */
    :global(html.js) .clinical-m-sticky.cl-fixed {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
    }
    /* After the pin: parked at the bottom of the track, scrolling away normally. */
    :global(html.js) .clinical-m-sticky.cl-after {
      position: absolute;
      top: auto;
      bottom: 0;
      left: 0;
      width: 100%;
    }
    /* All six states stack in one grid cell. The cell sizes to the tallest beat
       — Integrations, which carries the extra EHR logo card below its diagram —
       so every beat stays top-aligned with a consistent step-chip + diagram
       position, and the shorter beats simply leave the lower space empty
       (matching the design's shared 616px frame). */
    :global(html.js) .clinical-m-diagrams {
      display: grid;
      /* Constrain the single column to the container width — without this the
         auto column sizes to the 837px-wide SVG and blows out the layout. */
      grid-template-columns: minmax(0, 1fr);
    }
    :global(html.js) .clinical-m-state {
      grid-area: 1 / 1;
      min-width: 0;
      align-self: start;
    }
    :global(html.js) .clinical-m-state + .clinical-m-state {
      margin-top: 0;
    }
    :global(html.js) [data-cm-state="b"],
    :global(html.js) [data-cm-state="c"],
    :global(html.js) [data-cm-state="d"],
    :global(html.js) [data-cm-state="e"] {
      opacity: 0;
      filter: blur(12px);
    }
  }
</style>
<style>
  /* Swirl bloom — a soft blue glow behind the diagram. It lives inside
     `.clinical-pin` so it tracks the pinned illustration; `top`/`left` mark the
     bloom's centre (the layer is pulled back by half its own size) and a radial
     mask keeps it a soft circular bloom. The background is the no-JS /
     reduced-motion fallback wash. */
  .clinical-pin {
    position: relative; /* positioning context for the bloom (sticky overrides on lg+) */
    /* Clip the bloom horizontally so its over-wide box can't add a scrollbar;
       overflow-y stays visible so it still bleeds vertically. */
    overflow-x: clip;
  }
  .cl-swirl {
    left: 50%;
    top: 50%;
    width: 130%;
    height: 90%;
    transform: translate(-50%, -50%);
    background: radial-gradient(
      circle closest-side at 50% 50%,
      color-mix(in srgb, var(--color-periwinkle) 55%, transparent),
      transparent 70%
    );
    -webkit-mask-image: radial-gradient(
      circle closest-side at 50% 50%,
      #000 0%,
      #000 16%,
      transparent 72%
    );
    mask-image: radial-gradient(
      circle closest-side at 50% 50%,
      #000 0%,
      #000 16%,
      transparent 72%
    );
  }

  /* Desktop: centre the bloom over the diagram column (right side of the pin). */
  @media (min-width: 1024px) {
    .cl-swirl {
      left: 66%;
      top: 46%;
      width: 76%;
      height: 116%;
    }
  }

  /* Mobile bloom — centred in the viewport (its anchor, .cl-swirl-fixed, is
     pinned to the viewport top), sized in viewport units so it reads as one big,
     soft, fixed glow behind the whole section. */
  .cl-swirl-m {
    left: 50%;
    top: 50vh;
    width: 135vw;
    height: 90vh;
    transform: translate(-50%, -50%);
    background: radial-gradient(
      circle closest-side at 50% 50%,
      color-mix(in srgb, var(--color-periwinkle) 55%, transparent),
      transparent 70%
    );
    -webkit-mask-image: radial-gradient(
      circle closest-side at 50% 50%,
      #000 0%,
      #000 16%,
      transparent 72%
    );
    mask-image: radial-gradient(
      circle closest-side at 50% 50%,
      #000 0%,
      #000 16%,
      transparent 72%
    );
  }
</style>

<script>
  // Animated swirl bloom behind the diagram — the shared hero swirl recoloured
  // to a soft brand-blue glow (circular, gentle drift).
  import { initSwirl } from "../../lib/swirl";

  // One stage on desktop (inside the pin) and one on mobile (block 3); each gets
  // its own canvas. The IntersectionObserver inside initSwirl pauses whichever is
  // offscreen, so the hidden one for the current breakpoint doesn't render.
  document
    .querySelectorAll<HTMLElement>("[data-cl-swirl-stage]")
    .forEach((stage) => {
      const canvas = stage.querySelector<HTMLCanvasElement>(
        "canvas[data-cl-swirl]",
      );
      if (!canvas) return;
      initSwirl(canvas, stage, {
        grainUrl: "/hero/swirl/perlin1.png",
        circular: true,
        warp: 0.6, // gentle drift, cohesive blob
        speed: 3.8, // faster drift than the hero swirl
        falloffStart: 0.5,
        falloffEnd: 0.92,
        colors: {
          bgColor: [0.97, 0.98, 1.0], // outer field — near-white
          soft: [0.86, 0.9, 1.0], // inner core — pale blue
          body: [0.5, 0.56, 0.97], // dominant bloom — blue-violet
          lavender: [0.86, 0.9, 1.0], // secondary highlight — pale blue
          crest: [0.97, 0.97, 0.97], // gradient crest — white
        },
      });
      // Reveal the canvas. The desktop bloom is then fully visible; the mobile
      // bloom's overall visibility is gated by its stage opacity, which is
      // scroll-driven in initClinicalMobile so it only shows behind the
      // illustrations.
      requestAnimationFrame(() => canvas.classList.remove("opacity-0"));
    });
</script>
