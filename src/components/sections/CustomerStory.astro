---
/**
 * CustomerStory — a single customer-story page body
 * (Figma "CustomerStories>NHS", 1440).
 *
 * Three stacked sections, all fed from one `story` object (one entry of
 * src/data/customer-stories.json):
 *
 *   1. Hero — a full-bleed photo behind a transparent→lavender→surface blur
 *      wash, with the customer logo, an Eyebrow case-study label, a big Lora
 *      title, and a 3-up row of left-hairline stat columns.
 *   2. Overview — a two-column band: a left "ID" fact sheet (customer type,
 *      patients served, location, use-case chips, all on hairline rules) and a
 *      right Lora "Overview" heading over body paragraphs.
 *   3. Testimonial — a centered Eyebrow, a Patient/Customer segmented control,
 *      a large pull-quote, and an author block with an avatar.
 *
 * The page Navbar is rendered by the page (src/pages/customers/[slug].astro),
 * positioned over the hero. Content-free — copy/photos come from the data.
 */
import Eyebrow from "../ui/Eyebrow.astro";
import StoryCard from "../ui/StoryCard.astro";
import ArrowCircle from "../ui/ArrowCircle.astro";

interface Stat {
  value: string;
  label: string;
}
interface ImpactCard {
  category: string;
  value: string;
  label: string;
  detail?: string;
}
interface Story {
  title: string;
  hero: {
    eyebrow: string;
    logo: string;
    logoAlt: string;
    // Render the logo as flat black (default). Set false for full-colour brand
    // logos — e.g. the NHS white-on-blue lockup, which `brightness-0` would
    // otherwise collapse into a solid black box.
    logoMono?: boolean;
    image: string;
    imageAlt: string;
    stats: Stat[];
  };
  id: {
    customerType: string[];
    patientsServed: string;
    location: string;
    useCases: string[];
  };
  overview: {
    title: string;
    paragraphs: string[];
  };
  testimonial: {
    eyebrow: string;
    activeTab: string;
    panels: {
      label: string;
      quote: string;
      avatar?: string;
      avatarAlt?: string;
      author: string;
      role?: string;
    }[];
  };
  impact?: {
    title: string;
    cards: ImpactCard[];
  };
  related?: {
    title: string;
    seeAll: { label: string; href: string };
    cards: Record<string, unknown>[];
  };
}

interface Props {
  story: Story;
}

const { story } = Astro.props;
const { hero, id, overview, testimonial, impact, related } = story;

// Index of the tab shown first (falls back to the first panel).
const activeIndex = Math.max(
  0,
  testimonial.panels.findIndex((p) => p.label === testimonial.activeTab),
);

// Outlined uppercase chip — reused for customer-type + use-case tags.
const chip =
  "rounded-[24px] border border-black/[0.24] px-4 py-2 text-sm font-semibold uppercase text-black";
---

<article>
  {/* ---- 1. Hero ----------------------------------------------------------- */}
  <header class="relative overflow-hidden bg-surface">
    {/* Photo. On mobile + tablet the design contains it to the top ~40% so the
        title can sit below it on a clean wash (full-bleed text-over-photo is
        unreadable on a narrow hero); on lg+ it stays full-bleed behind the
        gradient. */}
    <img
      src={hero.image}
      alt={hero.imageAlt}
      class="pointer-events-none absolute inset-x-0 top-0 h-[44%] w-full object-cover lg:inset-0 lg:h-full"
    />
    {/* transparent → lavender → surface wash. On mobile it blends the photo's
        lower edge into the surface so the copy below reads as dark-on-light; on
        lg+ it covers the lower ~2/3 of the full-bleed photo (Figma: gradient at
        y=300, h=600 of the 900 hero). */}
    <div
      class="absolute inset-x-0 top-[22%] h-[28%] bg-gradient-to-b from-transparent via-lavender to-surface lg:top-auto lg:bottom-0 lg:h-[67%]"
    >
    </div>

    <div
      class="relative mx-auto flex min-h-[640px] max-w-[1440px] flex-col justify-end gap-10 px-6 pb-0 pt-[180px] md:px-20 lg:min-h-[900px] lg:gap-[58px]"
    >
      {/* logo + label + title. On lg+ a 2-col grid places the eyebrow above the
          title (right col) and drops the logo into the title's row, so the logo
          top aligns with the top of the title line — not the eyebrow. Below lg
          it stacks (single column) below the contained photo. */}
      <div
        class="flex flex-col gap-8 lg:grid lg:grid-cols-[273px_1fr] lg:items-start lg:gap-x-[162px] lg:gap-y-3"
      >
        <img
          src={hero.logo}
          alt={hero.logoAlt}
          data-reveal
          class:list={[
            "h-auto w-[180px] shrink-0 object-contain object-left lg:col-start-1 lg:row-start-2 lg:w-[273px]",
            { "brightness-0": hero.logoMono !== false },
          ]}
        />
        <div data-reveal class="lg:col-start-2 lg:row-start-1">
          <Eyebrow>{hero.eyebrow}</Eyebrow>
        </div>
        <h1
          data-reveal="title"
          class="font-serif text-h4 font-normal text-black lg:col-start-2 lg:row-start-2"
        >
          {story.title}
        </h1>
      </div>

      {/* stat columns */}
      <div class="flex flex-col gap-8 md:flex-row md:gap-6">
        {
          hero.stats.map((stat, i) => (
            <div
              data-reveal
              style={`transition-delay:${i * 120}ms`}
              class="cs-stat relative flex flex-1 flex-col gap-6 pl-4 lg:pl-6"
            >
              {/* divider draws in from the top, same effect as the home hero line */}
              <span class="cs-stat-line absolute inset-y-0 left-0 w-px bg-black/[0.24]" aria-hidden="true" />
              <p class="text-[38px] font-normal leading-[1.15] tracking-[-0.76px] text-black lg:text-h6 lg:tracking-normal">
                {stat.value}
              </p>
              <p class="text-sm font-semibold uppercase text-black">
                {stat.label}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </header>

  {/* ---- 2. Overview ------------------------------------------------------- */}
  <section
    class="mx-auto flex max-w-[1440px] flex-col gap-12 bg-surface px-6 pb-20 pt-20 md:flex-row md:gap-[129px] md:px-20 md:pb-[80px] md:pt-[120px]"
  >
    {/* left — ID fact sheet. Hairlines draw in from the left (same effect as the
        home hero line) when the sheet reveals; staggered top → bottom. */}
    <dl
      data-reveal
      class="cs-id relative flex w-full flex-col gap-3 pt-6 md:w-[413px] md:shrink-0"
    >
      <span class="cs-hline absolute inset-x-0 top-0 h-px bg-black/15" style="transition-delay:0ms" aria-hidden="true"></span>

      <div class="relative flex items-start justify-between gap-4 pb-3">
        <span class="cs-hline absolute inset-x-0 bottom-0 h-px bg-black/15" style="transition-delay:90ms" aria-hidden="true"></span>
        <dt class="text-sm font-semibold uppercase text-black">
          Customer Type
        </dt>
        <dd class="flex flex-col items-end gap-2">
          {id.customerType.map((tag) => <span class={chip}>{tag}</span>)}
        </dd>
      </div>

      <div class="relative flex items-center justify-between pb-3">
        <span class="cs-hline absolute inset-x-0 bottom-0 h-px bg-black/15" style="transition-delay:180ms" aria-hidden="true"></span>
        <dt class="text-sm font-semibold uppercase text-black">
          Patients served
        </dt>
        <dd
          class="text-right text-xl font-normal text-black"
        >
          {id.patientsServed}
        </dd>
      </div>

      <div class="relative flex items-center justify-between pb-3">
        <span class="cs-hline absolute inset-x-0 bottom-0 h-px bg-black/15" style="transition-delay:270ms" aria-hidden="true"></span>
        <dt class="text-sm font-semibold uppercase text-black">
          Location
        </dt>
        <dd
          class="text-right text-xl font-normal text-black"
        >
          {id.location}
        </dd>
      </div>

      <div class="relative flex items-start justify-between gap-6 pb-3">
        <span class="cs-hline absolute inset-x-0 bottom-0 h-px bg-black/15" style="transition-delay:360ms" aria-hidden="true"></span>
        <dt class="text-sm font-semibold uppercase text-black">
          Use cases
        </dt>
        <dd class="flex flex-1 flex-wrap justify-end gap-2">
          {id.useCases.map((tag) => <span class={chip}>{tag}</span>)}
        </dd>
      </div>
    </dl>

    {/* right — heading + body */}
    <div class="flex flex-1 flex-col gap-10">
      <h2
        data-reveal="title"
        class="font-serif text-h6 font-normal text-black"
      >
        {overview.title}
      </h2>
      <div class="flex max-w-[521px] flex-col gap-6">
        {
          overview.paragraphs.map((html, i) => (
            <p
              data-reveal
              style={`transition-delay:${i * 80}ms`}
              class="text-xmd font-normal text-black [&_a]:underline"
              set:html={html}
            />
          ))
        }
      </div>
    </div>
  </section>

  {/* ---- 3. Testimonial ---------------------------------------------------- */}
  <section class="bg-surface px-6 py-20 md:px-20 md:py-[120px]">
    <div class="mx-auto flex max-w-[1270px] flex-col items-center gap-10">
      <div data-reveal>
        <Eyebrow>{testimonial.eyebrow}</Eyebrow>
      </div>

      <div class="flex w-full flex-col items-center gap-12 md:gap-20">
        {/* Patient / Customer segmented control — clickable tabs that switch
            the testimonial panel below (see the <script> at the foot). */}
        <div
          data-reveal
          role="tablist"
          aria-label="Testimonial perspective"
          class="flex items-center gap-2 rounded-[40px] bg-ink-wash p-2"
        >
          {
            testimonial.panels.map((panel, i) => (
              <button
                type="button"
                role="tab"
                id={`cs-tab-${i}`}
                data-cs-tab={i}
                aria-controls={`cs-panel-${i}`}
                aria-selected={i === activeIndex ? "true" : "false"}
                class={`cs-tab cursor-pointer rounded-[40px] border border-gray-200 px-8 py-4 text-center text-sm font-semibold uppercase transition-colors duration-500 ease-[cubic-bezier(0.33,1,0.68,1)] motion-reduce:transition-none ${
                  i === activeIndex ? "bg-brand text-white" : "text-black"
                }`}
              >
                {panel.label}
              </button>
            ))
          }
        </div>

        {/* Panels are stacked in one grid cell so they overlap: the cell
            reserves the taller panel's height (no layout jump) and switching
            crossfades opacity — the outgoing panel fades out as the incoming
            one fades in. */}
        <div class="grid w-full">
          {
            testimonial.panels.map((panel, i) => (
              <div
                role="tabpanel"
                id={`cs-panel-${i}`}
                data-cs-panel={i}
                aria-labelledby={`cs-tab-${i}`}
                aria-hidden={i === activeIndex ? undefined : "true"}
                class={`cs-panel col-start-1 row-start-1 flex w-full flex-col items-center justify-center gap-12 transition-opacity duration-500 ease-[cubic-bezier(0.33,1,0.68,1)] motion-reduce:transition-none md:gap-20 ${
                  i === activeIndex
                    ? "opacity-100"
                    : "pointer-events-none opacity-0"
                }`}
              >
                <blockquote
                  data-reveal
                  class="max-w-[1042px] text-center font-normal text-black text-h6"
                >
                  {panel.quote}
                </blockquote>

                <figure class="m-0 flex flex-col items-center gap-5 text-center md:flex-row md:text-left">
                  {panel.avatar && (
                    <img
                      src={panel.avatar}
                      alt={panel.avatarAlt}
                      class="h-[75px] w-[100px] shrink-0 rounded-[24px] object-cover"
                    />
                  )}
                  <figcaption class="flex flex-col gap-1 text-black">
                    <p class="text-sm font-medium uppercase">
                      {panel.author}
                    </p>
                    {panel.role && (
                      <p class="whitespace-pre-line text-base font-normal">
                        {panel.role}
                      </p>
                    )}
                  </figcaption>
                </figure>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  {/* ---- 4. Impact --------------------------------------------------------- */}
  {
    impact && (
      <section class="bg-surface overflow-hidden py-20 md:py-[120px]">
        {/* Same scroll-driven full-bleed expansion as the home "Trusted by"
            panel: the lavender frame begins slightly compressed (inset, rounded
            corners), expands to edge-to-edge (square corners) as the section
            reaches the centre of the viewport, then compresses again as it
            scrolls away. The 1376-wide content never moves; only the frame
            scales behind it. */}
        <div data-impact-scroll class="relative mx-auto w-full">
          {/* lavender panel with a soft blurred purple→blue bloom (Figma bloom
              baked into impact-bloom.svg). The panel colour is the bloom's outer
              stop so it blends seamlessly. The scrubber scales this frame
              (panel + content together) and clips its corners. */}
          <div
            data-impact-frame
            class="impact-frame relative flex flex-col gap-12 overflow-hidden bg-purple-tint will-change-transform md:gap-20"
          >
          <img
            src="/customers/impact-bloom.svg"
            alt=""
            aria-hidden="true"
            class="pointer-events-none absolute inset-0 size-full object-cover"
          />
          <div class="relative z-10 mx-auto flex w-full max-w-[1920px] flex-col gap-12 px-6 py-16 md:gap-20 md:px-20 md:py-[120px]">
          <h2
            data-reveal="title"
            class="relative text-center font-serif text-[56px] font-normal tracking-[-1.12px] text-black lg:text-h5 lg:tracking-normal"
          >
            {impact.title}
          </h2>

          {/* Cards sit in an items-stretch row so they share a height. Clicking a
              card's info button toggles [data-open]: the translucent detail panel
              reveals below (grid-rows 0fr→1fr), and the row grows — the other
              cards stretch to match, so the open card's white pane looks
              compressed. See the <script> at the foot. */}
          <div class="relative flex flex-col gap-4 md:flex-row md:items-stretch">
            {impact.cards.map((card, i) => (
              <div
                data-reveal
                data-impact-card
                data-open="false"
                style={`transition-delay:${i * 120}ms`}
                class="impact-card flex flex-1 flex-col"
              >
                {/* white pane — flex-1 so it fills the (stretched) column height */}
                <div class="impact-main flex flex-1 flex-col items-center justify-between gap-6 rounded-card bg-white px-8 py-10 text-center">
                  <div class="flex items-start justify-center gap-2">
                    <span class="rounded-[40px] border border-black/[0.24] px-4 py-2 text-sm font-semibold uppercase text-black">
                      {card.category}
                    </span>
                    {/* info affordance — the site's dotted ArrowCircle with an "i" */}
                    {card.detail && (
                      <ArrowCircle
                        variant="dotted"
                        glyph="info"
                        label="Show how this was measured"
                        data-impact-toggle
                        aria-expanded="false"
                      />
                    )}
                  </div>
                  <p class="font-serif text-h3 font-normal text-black">
                    {card.value}
                  </p>
                  <p class="max-w-[240px] text-sm font-semibold uppercase text-black">
                    {card.label}
                  </p>
                </div>

                {/* collapsible detail — a fully-rounded panel sitting flush
                    under the white pane (no gap), sliding down + fading in as
                    the row grows. See the <style> at the foot. */}
                {card.detail && (
                  <div class="impact-extra">
                    {/* padding-less clip wrapper so the row collapses fully to 0
                        (the padded inner can't be the grid item, or its padding
                        leaves a residual height). */}
                    <div class="impact-extra-clip">
                      <div
                        class={`impact-extra-inner flex gap-2.5 rounded-card bg-white/45 px-8 py-8 text-left ${
                          i === 2 ? "items-center" : "items-start"
                        }`}
                      >
                        <span
                          class={`grid size-6 shrink-0 place-items-center text-black ${
                            i === 2 ? "" : "mt-px"
                          }`}
                          aria-hidden="true"
                        >
                          <svg viewBox="0 0 24 24" class="size-full" fill="none">
                            <circle cx="12" cy="12" r="11.25" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                            <path d="M12 16.5V11.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                            <path d="M12 8.01V8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                          </svg>
                        </span>
                        <p class="text-sm font-semibold uppercase text-black">
                          {card.detail}
                        </p>
                      </div>
                    </div>
                  </div>
                )}
              </div>
            ))}
          </div>
          </div>
          </div>
        </div>
      </section>
    )
  }

  {/* ---- 5. Related stories ------------------------------------------------ */}
  {
    related && (
      <section class="relative overflow-hidden bg-surface px-4 py-20 md:px-20 md:py-[120px]">
        {/* Animated swirl bloom behind the related grid — the shared hero swirl
            in a softened brand-purple palette, masked to a contained centred
            bloom that fades to the surface at the edges (Figma node 8642). */}
        <div
          data-related-swirl-stage
          aria-hidden="true"
          class="cs-related-swirl pointer-events-none absolute inset-0 z-0"
        >
          <canvas
            data-related-swirl
            class="absolute inset-0 h-full w-full opacity-0 transition-opacity duration-700"
          ></canvas>
        </div>

        <div class="relative z-10 mx-auto flex max-w-[1280px] flex-col items-end gap-12 md:gap-20">
          <h2
            data-reveal="title"
            class="w-full max-w-[714px] self-center text-center font-serif text-h5 font-normal text-black"
          >
            {related.title}
          </h2>

          <div class="flex w-full flex-col gap-10">
            <div
              data-reveal
              class="grid grid-cols-1 gap-4 md:grid-cols-2"
            >
              {related.cards.map((cell) => (
                <StoryCard {...cell} />
              ))}
            </div>

            <a
              href={related.seeAll.href}
              class="self-end rounded-[50px] border border-black px-6 py-3 text-sm font-semibold uppercase text-black transition-colors hover:bg-black hover:text-white"
            >
              {related.seeAll.label}
            </a>
          </div>
        </div>
      </section>
    )
  }
</article>

<script>
  // Testimonial tabs: clicking Patient / Customer swaps the visible panel.
  // Panels toggle the `flex`/`hidden` display utilities (not the [hidden]
  // attribute, which Tailwind's display classes would override). Reveal
  // elements inside a newly shown panel are forced visible since the observer
  // never saw them while the panel was display:none.
  const tabs = Array.from(
    document.querySelectorAll<HTMLButtonElement>("[data-cs-tab]"),
  );
  const panels = Array.from(
    document.querySelectorAll<HTMLElement>("[data-cs-panel]"),
  );

  const activate = (idx: number) => {
    tabs.forEach((tab, i) => {
      const on = i === idx;
      tab.setAttribute("aria-selected", on ? "true" : "false");
      tab.classList.toggle("bg-brand", on);
      tab.classList.toggle("text-white", on);
      tab.classList.toggle("text-black", !on);
    });
    panels.forEach((panel, i) => {
      const on = i === idx;
      // Crossfade: both panels stay in the grid; only opacity changes.
      panel.classList.toggle("opacity-100", on);
      panel.classList.toggle("opacity-0", !on);
      panel.classList.toggle("pointer-events-none", !on);
      if (on) {
        panel.removeAttribute("aria-hidden");
        panel
          .querySelectorAll("[data-reveal]")
          .forEach((el) => el.classList.add("in-view"));
      } else {
        panel.setAttribute("aria-hidden", "true");
      }
    });
  };

  tabs.forEach((tab, i) => tab.addEventListener("click", () => activate(i)));

  // Impact cards: the info "i" button expands a detail panel below the card.
  // Toggling [data-open] on the card drives the CSS (grid-rows reveal); the row
  // grows so the sibling cards stretch to match, compressing the open card's
  // white pane. Each card is independent.
  document
    .querySelectorAll<HTMLButtonElement>("[data-impact-toggle]")
    .forEach((btn) => {
      btn.addEventListener("click", () => {
        const card = btn.closest<HTMLElement>("[data-impact-card]");
        if (!card) return;
        const open = card.getAttribute("data-open") === "true";
        card.setAttribute("data-open", open ? "false" : "true");
        btn.setAttribute("aria-expanded", open ? "false" : "true");
      });
    });

  // ID fact-sheet hairlines: draw in only once the section has genuinely
  // arrived in the viewport. The sheet is tall, so the shared reveal observer
  // (threshold 0.2) fires while the lower rows are still off-screen below the
  // fold. This dedicated observer requires the sheet to rise ~35% up the
  // viewport before adding `.lines-in`, so the lines draw as the user reaches
  // them. Falls back to drawn-in if motion is reduced or IO is unavailable.
  document.querySelectorAll<HTMLElement>(".cs-id").forEach((sheet) => {
    const reduceMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    if (reduceMotion || !("IntersectionObserver" in window)) {
      sheet.classList.add("lines-in");
      return;
    }
    const obs = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            sheet.classList.add("lines-in");
            obs.unobserve(e.target);
          }
        });
      },
      // Shrink the viewport's bottom 35%: the sheet must scroll up into the
      // top ~65% before it counts as "arrived".
      { rootMargin: "0px 0px -35% 0px", threshold: 0 },
    );
    obs.observe(sheet);
  });

  // Impact panel: scroll-driven full-bleed expansion, identical scrubber to the
  // home "Trusted by" panel. Map the distance from the panel's centre to the
  // viewport's centre into a 0→1 proximity, ease it, and drive scale (0.82 → 1)
  // and corner radius (40px → 0). Symmetric about centre, so the panel peaks
  // edge-to-edge exactly when the section is centred and compresses as it leaves.
  function initImpactScroll(stage: HTMLElement) {
    const frame = stage.querySelector<HTMLElement>("[data-impact-frame]");
    if (!frame) return;
    if (!window.matchMedia("(prefers-reduced-motion: no-preference)").matches)
      return;

    const MIN_SCALE = 0.82;
    const MAX_RADIUS = 40; // px — matches --radius-card
    const easeOutCubic = (t: number) => 1 - Math.pow(1 - t, 3);

    let ticking = false;

    const render = () => {
      ticking = false;
      const rect = stage.getBoundingClientRect();
      const vh = window.innerHeight;
      const center = rect.top + rect.height / 2;
      const distance = Math.abs(center - vh / 2);
      // Full effect within one viewport height of dead centre.
      const proximity = Math.max(0, 1 - distance / vh);
      const eased = easeOutCubic(proximity);

      const scale = MIN_SCALE + (1 - MIN_SCALE) * eased;
      const radius = MAX_RADIUS * (1 - eased);
      frame.style.transform = `scale(${scale})`;
      frame.style.borderRadius = `${radius}px`;
    };

    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(render);
    };

    render();
    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onScroll);
  }

  document
    .querySelectorAll<HTMLElement>("[data-impact-scroll]")
    .forEach(initImpactScroll);
</script>

<script>
  // Related-stories bloom — the shared hero swirl in a softened brand-purple
  // palette, fading to the section surface at the edges. Same engine as the
  // home-page blooms (Operations / Scaling) and the About field.
  import { initSwirl } from "../../lib/swirl";

  const stage = document.querySelector<HTMLElement>("[data-related-swirl-stage]");
  const canvas = stage?.querySelector<HTMLCanvasElement>("canvas[data-related-swirl]");

  if (stage && canvas) {
    initSwirl(canvas, stage, {
      grainUrl: "/hero/swirl/perlin1.png",
      circular: true, // reads as a cohesive round blob on the wide section
      warp: 0.7, // drifts while staying a cohesive blob
      speed: 2.0, // gentle drift
      falloffStart: 0.5, // keep the centre filled; only the outer edge fades out
      falloffEnd: 0.92,
      colors: {
        bgColor: [0.976, 0.976, 0.976], // outer field — section surface (#f9f9f9)
        soft: [0.92, 0.89, 1.0], // inner core — pale lavender
        body: [0.6, 0.42, 0.92], // dominant bloom — softened brand purple
        lavender: [0.92, 0.89, 1.0], // secondary highlight — pale lavender
        crest: [0.97, 0.97, 0.97], // gradient crest — white
      },
    });
    requestAnimationFrame(() => canvas.classList.remove("opacity-0"));
  }
</script>

<style is:global>
  /* Hero stat dividers draw in from the top — the same line effect as the home
     hero rule. Driven off the column's own reveal (.in-view, added globally by
     the Layout observer) rather than the thin line's own intersection, which a
     zero-area transformed box can't trigger. Global block so the `.js` flag (on
     <html>) and the global `.in-view` class match without Astro scope rewriting.
     Gated behind motion-allowed + the .js flag, matching global.css. */
  @media (prefers-reduced-motion: no-preference) {
    .js .cs-stat .cs-stat-line {
      transform: scaleY(0);
      transform-origin: top center;
      transition: transform 0.9s cubic-bezier(0.33, 1, 0.68, 1);
      transition-delay: inherit;
      will-change: transform;
    }
    .js .cs-stat.in-view .cs-stat-line {
      transform: scaleY(1);
    }

    /* ID fact-sheet hairlines: draw in horizontally from the left. Gated on a
       dedicated `.lines-in` flag (added by the observer in the <script> below)
       rather than the sheet's own `.in-view` — the sheet is tall, so the shared
       0.2 threshold fires while its lower rows are still below the fold. The
       flag only lands once the section is properly within the viewport, so the
       lines draw as the user actually arrives. Per-line transition-delay is set
       inline for the top→bottom stagger. */
    .js .cs-id .cs-hline {
      transform: scaleX(0);
      transform-origin: left center;
      transition: transform 0.9s cubic-bezier(0.33, 1, 0.68, 1);
      will-change: transform;
    }
    .js .cs-id.lines-in .cs-hline {
      transform: scaleX(1);
    }
  }

  /* Related-stories swirl bloom — a wide centred radial mask keeps the animated
     swirl a soft contained bloom that fades to the surface at the section's
     edges (matching the design's lavender glow behind the related grid). */
  .cs-related-swirl {
    -webkit-mask-image: radial-gradient(
      ellipse closest-side at 50% 50%,
      #000 0%,
      #000 30%,
      transparent 78%
    );
    mask-image: radial-gradient(
      ellipse closest-side at 50% 50%,
      #000 0%,
      #000 30%,
      transparent 78%
    );
  }

  /* Impact panel full-bleed scrubber — mirrors the home "Trusted by" frame.
     Fallback (no JS / reduced motion): the design's contained panel, inset to a
     16px gutter with rounded corners. */
  .impact-frame {
    border-radius: var(--radius-card);
    transform-origin: center center;
    transform: scale(0.978); /* ≈ 16px gutter on a 1440 viewport */
  }

  /* Enhanced: the scrubber drives scale (0.82 → 1) and corner radius
     (40px → 0) per frame; no CSS easing. */
  @media (prefers-reduced-motion: no-preference) {
    .js .impact-frame {
      transform: scale(0.82);
    }
  }

  /* Impact detail panel: collapsed by default (grid-rows 0fr, inner clipped).
     When the card opens, the row animates 0fr → 1fr — interpolating to the
     panel's exact natural height over the full duration, so it eases open
     smoothly instead of popping (a max-height ceiling would finish the visible
     growth in the first fraction of the transition). The inner card also slides
     down + fades in for a softer reveal. */
  .impact-extra {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.55s cubic-bezier(0.33, 1, 0.68, 1);
  }
  .impact-extra-clip {
    min-height: 0;
    overflow: hidden;
  }
  .impact-extra-inner {
    opacity: 0;
    transform: translateY(-10px);
    transition:
      opacity 0.45s ease 0.05s,
      transform 0.55s cubic-bezier(0.33, 1, 0.68, 1) 0.05s;
  }
  .impact-card[data-open="true"] .impact-extra {
    grid-template-rows: 1fr;
  }
  .impact-card[data-open="true"] .impact-extra-inner {
    opacity: 1;
    transform: translateY(0);
  }

  /* The info "i" ring snaps between states with no morph: dotted at rest, solid
     on hover (ArrowCircle's own group-hover utility), and no longer tied to the
     card's open state. We simply don't apply a transition here, so the
     dotted→solid change is instant rather than animated. */

  @media (prefers-reduced-motion: reduce) {
    .impact-extra,
    .impact-extra-inner {
      transition: none;
    }
    .impact-card[data-open="true"] .impact-extra-inner {
      transform: none;
    }
  }
</style>
