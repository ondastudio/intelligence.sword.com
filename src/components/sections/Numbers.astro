---
/**
 * Numbers — proof-point bento grid.
 *
 * An asymmetric grid of stat cards (4x intake, 5.2x ROI, 34% readmissions,
 * 686 workdays), a customer photo, and a ministerial testimonial, closed by a
 * "Book a Meeting" CTA. Faithful to the Figma "Numbers" frame (1440 wide).
 *
 * Layout: cards stack in a single column on mobile; at md+ they snap into the
 * design's exact bento via absolute positioning on a 1280×877 canvas (each
 * card carries its left/top/width/height as --l/--t/--w/--h custom props).
 * Decorative-only graphics (radar rings, portrait, logos) are images; every
 * number, label and quote is real, editable text from src/data/numbers.json.
 */
import ArrowCircle from "../ui/ArrowCircle.astro";
import data from "../../data/numbers.json";

const { stats, testimonial, cta } = data;
---

<section class="numbers relative z-[1] px-4 py-[120px]">
  <div class="mx-auto flex max-w-[1280px] flex-col items-center gap-16 md:gap-20">
    <!-- Bento canvas — cards sit in their fixed grid positions (the whole
         section slides up toward the Operations title as you scroll). -->
    <div data-reveal class="nb-canvas flex w-full flex-col gap-4">
      <!-- 4x — intake capacity -->
      <article
        class="nb-card group relative flex flex-col items-center overflow-hidden rounded-card bg-periwinkle/45 px-8 py-10 text-center"
        data-parallax="22"
        style="--l:13.44%;--t:0%;--w:23.44%;--h:47.89%"
      >
        <div class="relative aspect-square w-[clamp(150px,15vw,200px)] shrink-0">
          <img src="/numbers/ring-1.svg" alt="" aria-hidden="true" class="absolute inset-0 size-full" />
          <img
            src="/numbers/ring-2.svg"
            alt=""
            aria-hidden="true"
            class="absolute left-1/2 top-[62.5%] aspect-square w-3/4 -translate-x-1/2 -translate-y-1/2"
          />
          <img
            src="/numbers/ring-3.svg"
            alt=""
            aria-hidden="true"
            class="absolute left-1/2 top-[75%] aspect-square w-1/2 -translate-x-1/2 -translate-y-1/2"
          />
          <img
            src="/numbers/ring-4.svg"
            alt=""
            aria-hidden="true"
            class="absolute left-1/2 top-[87.5%] aspect-square w-1/4 -translate-x-1/2 -translate-y-1/2"
          />
        </div>
        <!-- "4x" + arrow, centered as a group; the arrow is lifted by the line
             box's descender space (~10.5px at 76px) so the bottom of the circle
             sits exactly on the bottom of the "4x" glyphs (Figma). -->
        <div class="mt-[10px] flex items-end justify-center gap-[16px]">
          <span class="font-serif text-h3 font-normal text-black">
            {stats.intake.value}
          </span>
          <ArrowCircle decorative class="mb-[10.5px]" />
        </div>
        <p class="mt-6 max-w-[232px] text-sm font-semibold uppercase text-black">
          {stats.intake.label}
        </p>
        <a href={stats.intake.href} aria-label="More on intake capacity" class="absolute inset-0 z-20 rounded-card"></a>
      </article>

      <!-- Customer portrait -->
      <figure
        class="nb-card overflow-hidden rounded-card"
        data-parallax="-16"
        style="--l:39.17%;--t:0%;--w:17.75%;--h:37.74%"
      >
        <img
          src={testimonial.photo}
          alt={testimonial.photoAlt}
          class="h-full min-h-[300px] w-full object-cover object-[59%_50%]"
        />
      </figure>

      <!-- Ministerial testimonial -->
      <article
        class="nb-card group relative flex flex-col justify-between gap-6 overflow-hidden rounded-card bg-purple-tint p-10"
        data-parallax="-20"
        style="--l:56.92%;--t:0%;--w:43.08%;--h:37.74%"
      >
        <img
          src={testimonial.logo}
          alt={testimonial.logoAlt}
          class="h-[43px] w-auto max-w-[200px] self-start object-contain object-left"
        />
        <p class="text-[clamp(1rem,1.6vw,20px)] text-black">
          &ldquo;{testimonial.quote}&rdquo;
        </p>
        <div class="flex items-end justify-between gap-4">
          <div class="flex flex-col gap-1 text-black">
            <span class="text-sm font-semibold uppercase">{testimonial.name}</span>
            <span class="text-base">{testimonial.role}</span>
          </div>
          <ArrowCircle decorative />
        </div>
        <a href={testimonial.href} aria-label="Read the partnership story" class="absolute inset-0 z-20 rounded-card"></a>
      </article>

      <!-- 686 — admin workdays saved -->
      <article
        class="nb-card group relative min-h-[280px] overflow-hidden rounded-card bg-accent"
        data-parallax="14"
        style="--l:0%;--t:51.54%;--w:36.91%;--h:34.09%"
      >
        <!-- perforated dot mesh — exact Figma pattern (16.2px grid), clipped
             like the design's 391.5×155 rect so it never cuts on the edges -->
        <img
          src="/numbers/dot-mesh.svg"
          alt=""
          aria-hidden="true"
          class="pointer-events-none absolute left-[8.571%] top-[13.378%] h-[51.839%] w-[82.86%]"
        />
        <!-- lime mask that clears the dots behind "686" — sized to the digit
             ink with an equal margin on all four sides -->
        <div
          class="pointer-events-none absolute left-[34.84%] top-[27.32%] h-[21.61%] w-[27.89%] bg-accent"
        >
        </div>
        <!-- 686 — ink centered in the mask, overlapping the mesh -->
        <span
          class="absolute left-[48.57%] top-[37.76%] -translate-x-1/2 -translate-y-1/2 font-serif text-h2 font-normal text-black"
        >
          {stats.workdays.value}
        </span>

        <div class="relative flex h-full flex-col p-10 text-center">
          <p class="mx-auto mt-auto max-w-[200px] text-sm font-semibold uppercase text-ink">
            {stats.workdays.label}
          </p>
        </div>

        <ArrowCircle decorative class="absolute bottom-10 right-10 z-10" />
        <a href={stats.workdays.href} aria-label="See admin workdays saved" class="absolute inset-0 z-20 rounded-card"></a>
      </article>

      <!-- 5.2x ROI — bar chart -->
      <article
        class="nb-card group relative flex flex-col items-center justify-center gap-8 overflow-hidden rounded-card bg-gray-200/35 px-6 py-10 text-center backdrop-blur-[20px]"
        data-parallax="30"
        style="--l:39.14%;--t:41.39%;--w:36.91%;--h:58.56%"
      >
        <div class="flex items-center justify-center gap-6">
          <span class="whitespace-nowrap font-serif text-h3 font-normal text-black">
            {stats.roi.value}
          </span>
          <ArrowCircle decorative />
        </div>
        <!-- Center-aligned bar chart with perforated dot mesh, exact from Figma -->
        <img
          src="/numbers/roi-bars.svg"
          alt=""
          aria-hidden="true"
          class="h-[clamp(150px,17vw,268px)] w-full max-w-[362px] object-contain"
        />
        <p class="text-sm font-semibold uppercase text-ink">
          {stats.roi.label}
        </p>
        <a href={stats.roi.href} aria-label="See the ROI breakdown" class="absolute inset-0 z-20 rounded-card"></a>
      </article>

      <!-- 34% — readmissions reduction -->
      <article
        class="nb-card group relative flex flex-col items-center justify-center gap-8 overflow-hidden rounded-card px-6 py-10 text-center"
        data-parallax="-16"
        style="--l:78.36%;--t:41.39%;--w:21.56%;--h:41.31%;background:radial-gradient(120% 95% at 50% 100%, rgba(186,224,235,0.75), rgba(220,221,228,0.26))"
      >
        <img src="/numbers/logo-nhs.svg" alt="NHS" class="h-[26px] w-auto" />
        <div class="flex items-start gap-1">
          <span class="font-serif text-h3 font-normal text-black">
            {stats.readmissions.value}
          </span>
          <span class="mt-3 grid size-6 place-items-center rounded-[24px] bg-[rgba(77,79,96,0.1)] text-ink">
            <svg viewBox="0 0 16 16" class="size-4" fill="none" aria-hidden="true">
              <path
                d="M12.67 8H3.33"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </span>
        </div>
        <p class="max-w-[222px] text-sm font-semibold uppercase text-black">
          {stats.readmissions.label}
        </p>
        <ArrowCircle decorative />
        <a href={stats.readmissions.href} aria-label="See readmissions impact" class="absolute inset-0 z-20 rounded-card"></a>
      </article>
    </div>

    <!-- CTA -->
    <div data-reveal class="group flex items-center" style="transition-delay:120ms">
      <a
        href={cta.href}
        class="flex h-10 items-center rounded-[50px] bg-brand px-6 text-sm font-semibold uppercase text-white"
      >
        {cta.label}
      </a>
      <ArrowCircle variant="filled" href={cta.href} label={cta.label} detach class="-ml-px" />
    </div>
  </div>
</section>

<style>
  /* Pull the grid up so its cards overlap the Operations stage above and
     "slide" up toward the pinned title as the page scrolls. Sits below the
     title (z-1 < z-2) so the title can lift away over it. Desktop +
     motion-allowed only — mobile keeps the sections cleanly stacked. */
  @media (min-width: 768px) and (prefers-reduced-motion: no-preference) {
    .numbers {
      margin-top: -70vh;
    }
  }

  /* --- Bento: stacked on mobile, exact design canvas at md+ --- */
  @media (min-width: 768px) {
    .nb-canvas {
      display: block;
      position: relative;
      aspect-ratio: 1280 / 877;
    }
    .nb-canvas .nb-card {
      position: absolute;
      left: var(--l);
      top: var(--t);
      width: var(--w);
      height: var(--h);
      margin: 0;
    }
  }
</style>

<script>
  // Gentle parallax — as the grid slides up, each card drifts a few pixels
  // relative to the viewport centre by its own [data-parallax] speed (mixed
  // signs = columns float at slightly different rates). Symmetric around centre
  // (offset → 0 when the card is centred) so the bento always reads as a grid;
  // this is depth, not the old "assemble into place" reveal. Desktop + motion
  // allowed only. Vanilla rAF + getBoundingClientRect.
  function initGentleParallax(el: HTMLElement) {
    const speed = Number(el.dataset.parallax);
    if (!speed) return;

    let ticking = false;
    const render = () => {
      ticking = false;
      const vh = window.innerHeight;
      const rect = el.getBoundingClientRect();
      const center = rect.top + rect.height / 2;
      // -1 (card a viewport above centre) … +1 (a viewport below) → small px.
      const norm = Math.max(-1, Math.min(1, (center - vh / 2) / vh));
      el.style.transform = `translate3d(0, ${norm * speed}px, 0)`;
    };

    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(render);
    };

    render();
    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onScroll);
  }

  const motionOk = window.matchMedia(
    "(min-width: 768px) and (prefers-reduced-motion: no-preference)",
  );
  if (motionOk.matches) {
    document
      .querySelectorAll<HTMLElement>(".numbers [data-parallax]")
      .forEach(initGentleParallax);
  }
</script>
