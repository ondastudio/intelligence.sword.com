---
/**
 * Numbers — proof-point bento grid.
 *
 * An asymmetric grid of stat cards (4x intake, 5.2x ROI, 34% readmissions,
 * 686 workdays), a customer photo, and a ministerial testimonial, closed by a
 * "Book a Meeting" CTA. Faithful to the Figma "Numbers" frame (1440 wide).
 *
 * Layout: cards stack in a single column on mobile; at md+ they snap into the
 * design's exact bento via absolute positioning on a 1280×877 canvas (each
 * card carries its left/top/width/height as --l/--t/--w/--h custom props).
 * Decorative-only graphics (radar rings, portrait, logos) are images; every
 * number, label and quote is real, editable text from src/data/numbers.json.
 */
import ArrowCircle from "../ui/ArrowCircle.astro";
import data from "../../data/numbers.json";

const { stats, testimonial, cta } = data;
---

<section id="numbers" class="numbers relative z-[1] px-4 py-[120px]">
  <div
    class="mx-auto flex max-w-[1280px] flex-col items-center gap-16 md:gap-20"
  >
    <!-- Bento canvas — cards sit in their fixed grid positions (the whole
         section slides up toward the Operations title as you scroll). -->
    <div class="nb-canvas flex w-full flex-col gap-4">
      <!-- 4x — intake capacity -->
      <article
        class="nb-card nb-card-intake group relative flex flex-col items-center overflow-hidden rounded-card bg-periwinkle/45 px-8 py-10 text-center"
        data-parallax="22"
        data-reveal
        style="--l:13.44%;--t:0%;--w:23.44%;--h:47.89%"
      >
        <div
          class="relative aspect-square w-[clamp(150px,15vw,164px)] shrink-0"
        >
          <img
            src="/numbers/ring-1.svg"
            alt=""
            aria-hidden="true"
            class="absolute inset-0 size-full"
          />
          <img
            src="/numbers/ring-2.svg"
            alt=""
            aria-hidden="true"
            class="absolute left-1/2 top-[62.5%] aspect-square w-3/4 -translate-x-1/2 -translate-y-1/2"
          />
          <img
            src="/numbers/ring-3.svg"
            alt=""
            aria-hidden="true"
            class="absolute left-1/2 top-[75%] aspect-square w-1/2 -translate-x-1/2 -translate-y-1/2"
          />
          <img
            src="/numbers/ring-4.svg"
            alt=""
            aria-hidden="true"
            class="absolute left-1/2 top-[87.5%] aspect-square w-1/4 -translate-x-1/2 -translate-y-1/2"
          />
        </div>
        <div class="mt-[10px] flex items-end justify-center">
          <span class="font-serif text-h3 font-normal text-black">
            {stats.intake.value}
          </span>
        </div>
        <p
          class="mt-6 max-w-[232px] text-sm font-semibold uppercase text-black"
        >
          {stats.intake.label}
        </p>
        {stats.intake.href !== "#" && (
          <a
            href={stats.intake.href}
            aria-label="More on intake capacity"
            class="absolute inset-0 z-20 rounded-card"
          />
        )}
      </article>

      <!-- Customer portrait -->
      <figure
        class="nb-card nb-card-photo overflow-hidden rounded-card"
        data-parallax="-16"
        data-reveal
        style="transition-delay:80ms;--l:39.17%;--t:0%;--w:17.75%;--h:37.74%"
      >
        <img
          src={testimonial.photo}
          alt={testimonial.photoAlt}
          class="h-full min-h-[300px] w-full object-cover object-[59%_50%]"
        />
      </figure>

      <!-- Ministerial testimonial -->
      <article
        class="nb-card nb-card-testimonial group relative flex flex-col justify-between gap-6 overflow-hidden rounded-card bg-purple-tint p-10"
        data-parallax="-20"
        data-reveal
        style="transition-delay:120ms;--l:56.92%;--t:0%;--w:43.08%;--h:37.74%"
      >
        <img
          src={testimonial.logo}
          alt={testimonial.logoAlt}
          class="h-[43px] w-auto max-w-[200px] self-start object-contain object-left"
        />
        <p class="text-[clamp(1rem,1.6vw,20px)] text-black">
          &ldquo;{testimonial.quote}&rdquo;
        </p>
        <div class="flex items-end justify-between gap-4">
          <div class="flex flex-col gap-1 text-black">
            <span class="text-sm font-semibold uppercase"
              >{testimonial.name}</span
            >
            <span class="text-base">{testimonial.role}</span>
          </div>
          <ArrowCircle decorative />
        </div>
        <a
          href={testimonial.href}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Read the partnership story"
          class="absolute inset-0 z-20 rounded-card"></a>
      </article>

      <!-- 686 — admin workdays saved -->
      <article
        class="nb-card nb-card-workdays group relative min-h-[280px] overflow-hidden rounded-card bg-accent"
        data-parallax="14"
        data-reveal
        style="transition-delay:240ms;--l:0%;--t:51.54%;--w:36.91%;--h:34.09%"
      >
        <!-- perforated dot mesh — exact Figma pattern (16.2px grid), clipped
             like the design's 391.5×155 rect so it never cuts on the edges -->
        <img
          src="/numbers/dot-mesh.svg"
          alt=""
          aria-hidden="true"
          class="pointer-events-none absolute left-[8.571%] top-[13.378%] h-[51.839%] w-[82.86%]"
        />
        <!-- lime mask that clears the dots behind "686" — sized to the digit
             ink with an equal margin on all four sides -->
        <div
          class="pointer-events-none absolute left-[34.84%] top-[27.32%] h-[21.61%] w-[27.89%] bg-accent"
        >
        </div>
        <!-- 686 — ink centered in the mask, overlapping the mesh -->
        <span
          class="nb-workdays-value absolute left-[48.57%] top-[37.76%] -translate-x-1/2 -translate-y-1/2 font-serif text-h2 font-normal text-black"
        >
          {stats.workdays.value}
        </span>

        <div class="relative flex h-full flex-col p-10 text-center">
          <p
            class="mx-auto mt-auto max-w-[200px] text-sm font-semibold uppercase text-ink"
          >
            {stats.workdays.label}
          </p>
        </div>

        {stats.workdays.href !== "#" && (
          <a
            href={stats.workdays.href}
            aria-label="See admin workdays saved"
            class="absolute inset-0 z-20 rounded-card"
          />
        )}
      </article>

      <!-- 5.2x ROI — bar chart -->
      <article
        class="nb-card nb-card-roi group relative flex flex-col items-center justify-center gap-8 overflow-hidden rounded-card bg-gray-200/35 px-6 py-10 text-center backdrop-blur-[20px]"
        data-parallax="30"
        data-reveal
        style="transition-delay:160ms;--l:39.14%;--t:41.39%;--w:36.91%;--h:58.56%"
      >
        <div class="flex items-center justify-center">
          <span
            class="whitespace-nowrap font-serif text-h3 font-normal text-black"
          >
            {stats.roi.value}
          </span>
        </div>
        <!-- Center-aligned bar chart with perforated dot mesh, exact from Figma -->
        <img
          src="/numbers/roi-bars.svg"
          alt=""
          aria-hidden="true"
          class="h-[clamp(150px,17vw,268px)] w-full max-w-[362px] object-contain"
        />
        <p class="text-balance text-sm font-semibold uppercase text-ink">
          {stats.roi.label}
        </p>
        {stats.roi.href !== "#" && (
          <a
            href={stats.roi.href}
            aria-label="See the ROI breakdown"
            class="absolute inset-0 z-20 rounded-card"
          />
        )}
      </article>

      <!-- 34% — readmissions reduction -->
      <article
        class="nb-card nb-card-readmissions group relative flex flex-col items-center justify-center gap-8 overflow-hidden rounded-card px-6 py-10 text-center"
        data-parallax="-16"
        data-reveal
        style="transition-delay:200ms;--l:78.36%;--t:41.39%;--w:21.56%;--h:41.31%;background:radial-gradient(120% 95% at 50% 100%, rgba(186,224,235,0.75), rgba(220,221,228,0.26))"
      >
        <img
          src="/logos/cheshire-merseyside-nhs.png"
          alt="NHS Cheshire and Merseyside"
          class="h-10 w-auto"
        />
        <div class="flex items-start gap-1">
          <span class="font-serif text-h3 font-normal text-black">
            {stats.readmissions.value}
          </span>
          <span
            class="mt-3 grid size-6 place-items-center rounded-[24px] bg-[rgba(77,79,96,0.1)] text-ink"
          >
            <svg
              viewBox="0 0 16 16"
              class="size-4"
              fill="none"
              aria-hidden="true"
            >
              <path
                d="M12.67 8H3.33"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </span>
        </div>
        <p class="max-w-[222px] text-sm font-semibold uppercase text-black">
          {stats.readmissions.label}
        </p>
        <ArrowCircle decorative />
        <a
          href={stats.readmissions.href}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="See readmissions impact"
          class="absolute inset-0 z-20 rounded-card"></a>
      </article>
    </div>

    <!-- CTA -->
    <div
      data-reveal
      class="group flex items-center"
      style="transition-delay:120ms"
    >
      <a
        href={cta.href}
        class="flex h-10 items-center rounded-[50px] bg-brand px-6 text-sm font-semibold uppercase text-white"
      >
        {cta.label}
      </a>
      <ArrowCircle
        variant="filled"
        href={cta.href}
        label={cta.label}
        detach
        class="-ml-px"
      />
    </div>
  </div>
</section>

<style>
  @media (max-width: 1023.98px) {
    .numbers {
      padding-inline: 20px;
      padding-block: 80px 120px;
    }

    .numbers > div {
      max-width: 350px;
      gap: 40px;
    }

    .nb-canvas {
      gap: 16px;
    }

    .nb-card {
      width: 100%;
    }

    .nb-card-intake {
      min-height: 132px;
      justify-content: center;
      padding: 40px 32px;
    }

    .nb-card-intake > div:first-child {
      display: none;
    }

    .nb-card-intake > div:nth-of-type(2) {
      margin-top: 0;
    }

    .nb-card-intake p {
      max-width: 232px;
    }

    .nb-card-photo {
      order: 2;
      height: 227px;
    }

    .nb-card-photo img {
      min-height: 0;
    }

    .nb-card-testimonial {
      order: 3;
      gap: 32px;
      margin-top: -16px;
      padding: 40px;
    }

    .nb-card-testimonial p {
      font-size: 20px;
    }

    .nb-card-testimonial > div {
      align-items: flex-start;
    }

    .nb-card-roi {
      order: 4;
      min-height: 235px;
      gap: 24px;
    }

    .nb-card-roi img {
      display: none;
    }

    .nb-card-readmissions {
      order: 5;
      min-height: 300px;
      gap: 24px;
      padding-block: 40px;
    }

    .nb-card-workdays {
      display: flex;
      flex-direction: column;
      order: 6;
      min-height: 266px;
    }

    .nb-card-workdays span {
      font-size: var(--text-h3);
    }

    .nb-card-workdays img {
      left: 8.86%;
      top: 15.04%;
      width: 79.7%;
      height: 48%;
    }

    .nb-card-workdays > div:first-of-type {
      left: 50%;
      width: 25%;
      top: 34%;
      height: 13%;
      transform: translateX(-50%);
    }

    .nb-card-workdays .nb-workdays-value {
      left: 50%;
      top: 40.6%;
    }

    .nb-card-workdays > div.relative {
      position: absolute;
      inset: 0;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      padding: 40px;
    }

    .nb-card-workdays p {
      max-width: 165px;
    }
  }

  /* Tablet keeps the mobile single-column layout but on a wider, still
     contained measure so the cards don't stretch edge-to-edge. */
  @media (min-width: 768px) and (max-width: 1023.98px) {
    .numbers > div {
      max-width: 480px;
    }
  }

  /* Pull the grid up so its cards overlap the Operations stage above and
     "slide" up toward the pinned title as the page scrolls. Sits below the
     title (z-1 < z-2) so the title can lift away over it. Desktop +
     motion-allowed only — mobile and tablet keep the sections cleanly stacked. */
  @media (min-width: 1024px) and (prefers-reduced-motion: no-preference) {
    .numbers {
      margin-top: -70vh;
    }
  }

  /* --- Bento: stacked on mobile/tablet, exact design canvas at lg+ --- */
  @media (min-width: 1024px) {
    .nb-canvas {
      display: block;
      position: relative;
      aspect-ratio: 1280 / 877;
    }
    .nb-canvas .nb-card {
      position: absolute;
      left: var(--l);
      top: var(--t);
      width: var(--w);
      height: var(--h);
      margin: 0;
    }
  }
</style>

<script>
  // Gentle parallax — as the grid slides up, each card drifts a few pixels
  // relative to the viewport centre by its own [data-parallax] speed (mixed
  // signs = columns float at slightly different rates). Symmetric around centre
  // (offset → 0 when the card is centred) so the bento always reads as a grid;
  // this is depth, not the old "assemble into place" reveal. Desktop + motion
  // allowed only. Vanilla rAF + getBoundingClientRect.
  function initGentleParallax(el: HTMLElement) {
    const speed = Number(el.dataset.parallax);
    if (!speed) return;

    let ticking = false;
    const render = () => {
      ticking = false;
      const vh = window.innerHeight;
      const rect = el.getBoundingClientRect();
      const center = rect.top + rect.height / 2;
      // -1 (card a viewport above centre) … +1 (a viewport below) → small px.
      const norm = Math.max(-1, Math.min(1, (center - vh / 2) / vh));
      el.style.transform = `translate3d(0, ${norm * speed}px, 0)`;
    };

    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(render);
    };

    render();
    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onScroll);
  }

  const motionOk = window.matchMedia(
    "(min-width: 1024px) and (prefers-reduced-motion: no-preference)",
  );
  if (motionOk.matches) {
    document
      .querySelectorAll<HTMLElement>(".numbers [data-parallax]")
      .forEach(initGentleParallax);
  }
</script>
