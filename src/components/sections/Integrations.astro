---
/**
 * Integrations — "the clinical intelligence layer between your patients and
 * your tech stack."
 *
 * A centered Lora headline + three benefit cards over an isometric data plane.
 * The plane is a SCROLLYTELLING sequence: the section pins to the viewport and,
 * as the user scrolls on toward the next section, the illustration + step badge
 * cross-fade through the numbered steps (01 Channels → 02 Intelligence → …)
 * before the page releases. Each step is one authored full-plane SVG
 * (src/data → steps[].illustration); add a step there and it joins the sequence.
 *
 * Mechanics:
 *  - [data-track] is a tall runway (100vh per step) that creates the scroll
 *    distance for the pin.
 *  - [data-pin] is sticky/full-height and holds the heading + scene.
 *  - The scene is authored at a fixed 1440×810 and scaled to fit BOTH the
 *    container width and the pinned viewport height (never upscaled past 1×).
 *  - A scroll listener maps runway progress → active step and toggles opacity on
 *    the stacked [data-step-img] / [data-step-badge] layers.
 *
 * Content comes from src/data/integrations.json.
 */
import data from "../../data/integrations.json";

const { heading, cards, steps } = data;
// One 100vh runway per step (first step shows while pinning in; each extra step
// gets a viewport of scroll to cross-fade into).
const trackVh = steps.length * 100;
---

<section class="integrations relative bg-surface text-black">
  <div data-track class="relative" style={`height:${trackVh}vh`}>
    <div data-pin class="sticky top-0 flex h-screen items-center justify-center overflow-hidden">
      <div class="mx-auto w-full max-w-[1440px] px-4 sm:px-6 lg:px-20">
        <!-- Heading -->
        <div data-heading class="mx-auto max-w-[980px] text-center">
          <h2 data-reveal="title" class="font-serif text-3xl font-normal sm:text-4xl lg:text-display">
            {heading.before}<span class="text-brand">{heading.accent}</span>{heading.after}
          </h2>
        </div>

        <!-- Scene (scaled to fit width + height) -->
        <div data-stage-wrap data-reveal class="relative mt-12" style="transition-delay:120ms">
          <div
            data-stage
            class="absolute left-1/2 top-0 h-[810px] w-[1440px]"
            style="transform-origin: top center; transform: translateX(-50%);"
          >
            <!-- Left: benefit cards -->
            <div class="absolute flex w-[340px] flex-col gap-4" style="left:80px;top:0">
              {
                cards.map((c) => (
                  <div class="flex flex-col items-center justify-center gap-5 rounded-card bg-ink-wash p-8 text-center backdrop-blur-[20px]">
                    <span class="rounded-[40px] border border-black/24 px-4 py-2 text-sm font-semibold uppercase">
                      {c.label}
                    </span>
                    <p class="text-lg font-normal">
                      {c.body.map((line, i) => (
                        <>
                          {i > 0 && <br />}
                          {line}
                        </>
                      ))}
                    </p>
                  </div>
                ))
              }
            </div>

            <!-- Right: isometric data plane — stacked step SVGs that cross-fade -->
            <div class="absolute" style="left:524px;top:0;width:827px;height:810px">
              {
                steps.map((s, i) => (
                  <img
                    data-step-img
                    data-index={i}
                    src={s.illustration}
                    alt=""
                    aria-hidden="true"
                    class="absolute inset-0 size-full transition-opacity duration-500 ease-out motion-reduce:transition-none"
                    style={`opacity:${i === 0 ? 1 : 0}`}
                  />
                ))
              }
            </div>

            <!-- Step badges (one per step) — cross-fade in lockstep with the plane -->
            {
              steps.map((s, i) => (
                <div
                  data-step-badge
                  data-index={i}
                  class="absolute flex items-center gap-2 transition-opacity duration-500 ease-out motion-reduce:transition-none"
                  style={`left:524px;top:0;opacity:${i === 0 ? 1 : 0}`}
                >
                  <span class="flex size-10 items-center justify-center rounded-[24px] border border-black bg-surface/5 text-sm font-semibold uppercase backdrop-blur-[50px]">
                    {s.number}
                  </span>
                  <span class="flex h-10 items-center justify-center rounded-[24px] border border-black bg-surface/5 px-4 text-sm font-semibold uppercase backdrop-blur-[50px]">
                    {s.label}
                  </span>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const section = document.querySelector<HTMLElement>(".integrations");
  if (section) {
    const track = section.querySelector<HTMLElement>("[data-track]")!;
    const heading = section.querySelector<HTMLElement>("[data-heading]")!;
    const wrap = section.querySelector<HTMLElement>("[data-stage-wrap]")!;
    const stage = section.querySelector<HTMLElement>("[data-stage]")!;
    const imgs = Array.from(section.querySelectorAll<HTMLElement>("[data-step-img]"));
    const badges = Array.from(section.querySelectorAll<HTMLElement>("[data-step-badge]"));
    const steps = imgs.length;

    // Scale the fixed 1440×810 scene to fit BOTH the container width and the
    // pinned viewport height — so the pinned panel never clips. Never upscaled.
    const fit = () => {
      const widthScale = Math.min(1, wrap.clientWidth / 1440);
      const avail = window.innerHeight - heading.offsetHeight - 48 /* mt-12 */ - 80;
      const heightScale = avail > 0 ? avail / 810 : widthScale;
      const scale = Math.max(0.15, Math.min(widthScale, heightScale));
      stage.style.transform = `translateX(-50%) scale(${scale})`;
      wrap.style.height = `${810 * scale}px`;
    };

    // Map runway progress → active step, then cross-fade the matching layers.
    let current = -1;
    const setStep = (i: number) => {
      if (i === current) return;
      current = i;
      imgs.forEach((el, idx) => (el.style.opacity = idx === i ? "1" : "0"));
      badges.forEach((el, idx) => (el.style.opacity = idx === i ? "1" : "0"));
    };

    const update = () => {
      const total = track.offsetHeight - window.innerHeight; // scroll runway
      const scrolled = Math.min(Math.max(-track.getBoundingClientRect().top, 0), total);
      const progress = total > 0 ? scrolled / total : 0;
      setStep(Math.min(steps - 1, Math.floor(progress * steps)));
    };

    let ticking = false;
    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        ticking = false;
        update();
      });
    };

    new ResizeObserver(() => {
      fit();
      update();
    }).observe(wrap);
    window.addEventListener("resize", () => {
      fit();
      update();
    });
    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("load", fit);
    fit();
    update();
  }
</script>
