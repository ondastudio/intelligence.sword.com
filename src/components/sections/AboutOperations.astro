---
/**
 * AboutOperations — a scroll-pinned, two-state beat on the About page.
 *
 * Two centered messages joined by a scroll-driven transition:
 *   State A — Figma node 8618:517 ("Section-04"): a Lora statement ("We first
 *     built AI to improve our care delivery…") over a body paragraph.
 *   State B — Figma node 8618:522 ("Section-05"): the statement crossfades to
 *     "So, Sword Intelligence was born.", the body swaps, and a row of three
 *     proof cards rises in — two big-number stat cards (85K+ physician hours,
 *     14M+ care interactions) and a "Medical certifications" panel holding the
 *     ISO / MDR / MHRA badges (the same /trust SVG layers used by `Trust`).
 *
 * Mechanics (gated on motion + JS, matching `AboutHero`): the section is taller
 * than the viewport and its stage is `sticky`, so it pins while a vanilla rAF
 * scrubber maps scroll progress through the section into the timeline — state A
 * fades + blurs out, state B resolves out of a blur, then the cards stagger up.
 * Without JS / with reduced motion the two states render as normal stacked flow,
 * both fully legible, so neither message is ever hidden.
 *
 * All copy, stats and badges come from src/data/about.json (`operations`).
 */
import about from "../../data/about.json";

type Segment = { text: string; bold?: boolean };
const { intro, born } = about.operations;
---

<section data-about-ops class="about-operations bg-white text-black">
  <div data-ops-stage class="ops-stage">
    <div class="ops-inner mx-auto w-full max-w-[1440px] px-[clamp(1.5rem,5.2vw,80px)]">
      <!-- State A — the "operations" statement (Figma Section-04). -->
      <div data-ops-state="a" class="ops-state flex flex-col items-center gap-8 text-center">
        <h2
          class="max-w-[992px] font-serif text-[clamp(2rem,5vw,56px)] font-normal"
        >
          {intro.statement}
        </h2>
        <p
          class="max-w-[678px] text-[clamp(1.125rem,2.2vw,24px)]"
        >
          {(intro.body as Segment[]).map((s) => s.text).join("")}
        </p>
      </div>

      <!-- State B — "So, Sword Intelligence was born." + proof cards (Section-05). -->
      <div data-ops-state="b" class="ops-state flex flex-col items-center gap-[clamp(2.5rem,6vw,80px)]">
        <div class="flex flex-col items-center gap-6 text-center">
          <h2
            class="max-w-[897px] font-serif text-[clamp(2.5rem,7vw,80px)] font-normal"
          >
            {born.statement}
          </h2>
          <p
            class="max-w-[678px] text-[clamp(1.125rem,2.2vw,24px)]"
          >
            {
              (born.body as Segment[]).map((s) =>
                s.bold ? <span class="font-semibold">{s.text}</span> : s.text,
              )
            }
          </p>
        </div>

        <!-- Proof cards: two big-number stats + a certifications panel.
             Column ratios (250.28 / 250.28 / 407.44) and the 16px gaps are the
             native Figma geometry; cards stack 1-up on mobile. -->
        <div
          class="ops-cards grid w-full max-w-[940px] grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-[250.28fr_250.28fr_407.44fr]"
        >
          {
            born.stats.map((stat, i) => (
              <div
                data-ops-card
                style={`--card-index:${i}`}
                class="flex min-h-[214px] items-center justify-center rounded-card border border-black/[0.12] bg-white p-10"
              >
                <div class="flex flex-col items-center justify-center gap-8">
                  <div class="flex items-start justify-center gap-2">
                    <span class="font-serif text-[clamp(3rem,7vw,76px)] font-normal">
                      {stat.value}
                    </span>
                    {stat.plus && (
                      <span class="mt-[11px] flex size-6 shrink-0 items-center justify-center rounded-full bg-ink-wash-strong text-base">
                        +
                      </span>
                    )}
                  </div>
                  <p class="text-center text-sm font-semibold uppercase">
                    {stat.label}
                  </p>
                </div>
              </div>
            ))
          }

          <!-- Medical certifications panel — frosted neutral fill (the Figma
               white/50 reads as a soft grey panel over the page). -->
          <div
            data-ops-card
            style={`--card-index:${born.stats.length}`}
            class="flex min-h-[214px] flex-col items-center justify-center gap-5 rounded-[50px] bg-ink-wash-strong px-6 py-8 sm:col-span-2 lg:col-span-1"
          >
            <span
              class="flex items-center rounded-[16px] border border-black/24 px-4 py-2 text-sm font-semibold uppercase"
            >
              {born.certs.label}
            </span>
            <div class="flex flex-nowrap items-center justify-center gap-[11.7px]">
              {
                born.certs.badges.map((badge) => (
                  <img
                    src={badge.src}
                    alt={badge.alt}
                    width={badge.w}
                    height={badge.h}
                    class="block max-w-none shrink-0"
                    style={`width:${badge.w}px;height:${badge.h}px`}
                  />
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Base = no-JS / reduced-motion fallback: the section is normal flow and both
     states stack vertically, fully legible (neither message is hidden). */
  .ops-stage {
    padding-block: clamp(5rem, 12vw, 120px);
  }
  .ops-state + .ops-state {
    margin-top: clamp(5rem, 12vw, 120px);
  }

  /* Enhanced: pin the stage and crossfade the two states as one. Pre-setting the
     start state here keeps the first paint flash-free before the rAF loop runs. */
  @media (prefers-reduced-motion: no-preference) {
    :global(html.js) .about-operations {
      height: calc(100svh + 140vh);
    }
    :global(html.js) .ops-stage {
      position: sticky;
      top: 0;
      display: flex;
      min-height: 100svh;
      align-items: center;
      overflow: hidden;
      padding-block: clamp(2rem, 6vw, 80px);
    }
    :global(html.js) .ops-inner {
      position: relative;
    }
    /* Stack both states in the same centred slot so they crossfade in place. */
    :global(html.js) .ops-state {
      position: absolute;
      inset-inline: 0;
      top: 50%;
      transform: translateY(-50%);
    }
    :global(html.js) .ops-state + .ops-state {
      margin-top: 0;
    }
    :global(html.js) [data-ops-state="b"] {
      opacity: 0;
      filter: blur(12px);
    }
    :global(html.js) [data-ops-card] {
      opacity: 0;
    }
  }
</style>

<script>
  // Scroll-driven crossfade from state A ("operations") to state B ("born").
  // The stage is sticky inside a taller section; progress is how far the section
  // has scrolled past the top, normalised to its scrub distance — the same
  // mechanism AboutHero uses.
  function initAboutOps(section: HTMLElement) {
    if (!window.matchMedia("(prefers-reduced-motion: no-preference)").matches)
      return;

    const stateA = section.querySelector<HTMLElement>('[data-ops-state="a"]');
    const stateB = section.querySelector<HTMLElement>('[data-ops-state="b"]');
    const cards = Array.from(
      section.querySelectorAll<HTMLElement>("[data-ops-card]"),
    );
    if (!stateA || !stateB) return;

    // Timeline (named windows so the feel is easy to tune). Each pair is a
    // progress window [start, end] over the section's scrub distance.
    const A_OUT: [number, number] = [0.06, 0.42]; // state A fades + blurs away
    const B_IN: [number, number] = [0.4, 0.78]; // state B resolves out of blur
    const CARDS_IN: [number, number] = [0.6, 1]; // cards stagger up last
    const BLUR = 12; // px — start blur for each incoming/outgoing state
    const RISE = 32; // px — distance each card travels up as it appears
    const STAGGER = 0.12; // share of the CARDS_IN window offset per card

    const track = (p: number, [a, b]: [number, number]) =>
      Math.min(1, Math.max(0, (p - a) / (b - a)));
    const easeOutCubic = (t: number) => 1 - Math.pow(1 - t, 3);

    let ticking = false;

    const render = () => {
      ticking = false;
      const scrub = section.offsetHeight - window.innerHeight;
      const p =
        scrub > 0
          ? Math.min(
              1,
              Math.max(0, -section.getBoundingClientRect().top / scrub),
            )
          : 0;

      // State A recedes into a blur.
      const aOut = easeOutCubic(track(p, A_OUT));
      stateA.style.opacity = String(1 - aOut);
      stateA.style.filter = `blur(${aOut * BLUR}px)`;

      // State B resolves out of a blur (held centred via translateY).
      const bIn = easeOutCubic(track(p, B_IN));
      stateB.style.opacity = String(bIn);
      stateB.style.filter = `blur(${(1 - bIn) * BLUR}px)`;

      // Cards rise + fade in, staggered, after the text has mostly arrived.
      cards.forEach((card, i) => {
        const idx = Number(card.style.getPropertyValue("--card-index")) || i;
        const [a, b] = CARDS_IN;
        const start = a + idx * STAGGER * (b - a);
        const c = easeOutCubic(track(p, [start, b]));
        card.style.opacity = String(c);
        card.style.transform = `translateY(${(1 - c) * RISE}px)`;
      });
    };

    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(render);
    };

    render();
    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onScroll);
  }

  document
    .querySelectorAll<HTMLElement>("[data-about-ops]")
    .forEach(initAboutOps);
</script>
