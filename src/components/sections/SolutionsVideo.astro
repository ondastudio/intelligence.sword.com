---
/**
 * SolutionsVideo — the same scroll-driven product video that runs on the home
 * page (the `Intro` demo film). Wraps the shared `ProductVideo` stage with the
 * `spotlight` treatment so it matches the home page's pinned, contained
 * rounded-card animation. Content comes from src/data/solutions.json (`media`).
 */
import solutions from "../../data/solutions.json";
import ProductVideo from "../ui/ProductVideo.astro";

const { src, poster, alt } = solutions.media;
---

<section class="bg-surface text-black">
  <ProductVideo src={src} poster={poster} alt={alt} spotlight />
</section>
