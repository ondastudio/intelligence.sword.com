---
/**
 * Footer — site closing footer.
 * Lime (bg-accent) panel, black ink. A Lora tagline sits top-left with a small
 * column of outbound social links (each an uppercase label + arrow-up-right
 * glyph); a hairline-ruled legal bar (copyright · cookie settings · privacy)
 * spans the content width; and the full-bleed "sword Intelligence" wordmark
 * (composed vector lockup from Figma) anchors the bottom.
 * Content comes from src/data/footer.json.
 */
import data from "../../data/footer.json";

/**
 * `variant` sets the panel theme:
 *   lime   — default: lime (bg-accent) panel, black ink + wordmark.
 *   purple — purple-300 panel, white ink; the wordmark (which renders black) is
 *            inverted to white. Used on the Customers page.
 */
interface Props {
  variant?: "lime" | "purple";
}
const { variant = "lime" } = Astro.props;
const isPurple = variant === "purple";

const { tagline, social, copyright, legal } = data;
---

<footer
  class:list={[
    "footer relative overflow-hidden px-6 pb-10 pt-16 md:px-20 md:pb-10 md:pt-20",
    isPurple ? "bg-purple-300 text-white" : "bg-accent text-black",
  ]}
>
  <div class="mx-auto flex w-full max-w-[1280px] flex-col">
    <!-- Top: tagline + social links -->
    <div class="flex flex-col gap-10 md:flex-row md:items-start md:gap-[clamp(4rem,18vw,365px)]">
      <p
        data-reveal
        class="max-w-[560px] font-serif text-h6 font-normal"
      >
        {tagline}
      </p>

      <ul data-reveal class="flex shrink-0 flex-col gap-2.5" style="transition-delay:120ms">
        {
          social.map((item) => (
            <li>
              <a
                href={item.href}
                target="_blank"
                rel="noopener noreferrer"
                class="group inline-flex items-center gap-1 text-sm font-semibold uppercase hover:underline"
              >
                {item.label}
                <svg
                  width="16"
                  height="16"
                  viewBox="0 0 16 16"
                  fill="none"
                  aria-hidden="true"
                  class="transition-transform duration-300 ease-out group-hover:-translate-y-0.5 group-hover:translate-x-0.5"
                >
                  <path d="M11 5L4 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                  <path
                    d="M5.33594 4.12527C5.33594 4.12527 10.7012 3.67299 11.5154 4.48719C12.3297 5.30139 11.8773 10.6667 11.8773 10.6667"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <!-- Legal bar -->
    <div
      data-reveal
      class:list={[
        "mt-14 flex flex-col gap-3 border-y-[1.5px] py-6 text-sm font-semibold uppercase sm:flex-row sm:items-center sm:justify-between md:mt-[113px]",
        isPurple ? "border-white" : "border-black",
      ]}
    >
      <span>{copyright}</span>
      {
        legal.map((item) => (
          <a
            href={item.href}
            target="_blank"
            rel="noopener noreferrer"
            class="hover:underline"
          >
            {item.label}
          </a>
        ))
      }
    </div>

    <!-- Wordmark lockup -->
    <img
      data-reveal
      src="/footer/logotype-wordmark.svg"
      alt="Sword Intelligence"
      class:list={[
        "mt-12 w-full md:mt-20",
        isPurple && "[filter:brightness(0)_invert(1)]",
      ]}
      width="1279"
      height="160"
    />
  </div>
</footer>

<script>
  // Footer reveal: pin the footer behind the page and reserve its height as
  // scroll space, so `.page-content` lifts off it at the end of the scroll.
  // (Positioning lives in global.css under `.footer-reveal`.)
  const footer = document.querySelector<HTMLElement>(".footer");
  const page = document.querySelector<HTMLElement>(".page-content");
  const root = document.documentElement;
  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (footer && page && !reduce) {
    const sync = () => {
      // Measure the footer's natural (in-flow) height. Temporarily drop the
      // flag so a fixed footer reports its true layout height.
      root.classList.remove("footer-reveal");
      const h = footer.offsetHeight;

      // Only reveal when the footer comfortably fits the viewport; otherwise a
      // pinned footer would clip its own top. Fall back to normal stacking.
      if (h < window.innerHeight) {
        page.style.marginBottom = `${h}px`;
        root.classList.add("footer-reveal");
      } else {
        page.style.marginBottom = "";
      }
    };

    sync();
    window.addEventListener("resize", sync);
    // Re-measure once fonts/images (the full-bleed wordmark) settle.
    window.addEventListener("load", sync);
  }
</script>
