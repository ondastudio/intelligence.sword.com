/**
 * SolutionsHowItWorks — the "HOW IT WORKS / Enroll. Coach. Prepare. Recover."
 * stepper on the Solutions page (Figma `8679:2`, "Triage" frame).
 *
 * A centered header (Eyebrow + Lora headline + a hairline-divided row of platform
 * capabilities) sits above an interactive stepper: a lateral icon navbar (the
 * design's `bg-ink-wash` pill of five `gray-200`-outlined 40px icon chips) selects
 * one of five steps, each a card with a left text column (eyebrow / Lora heading /
 * body) and a white media placeholder card on the right. The icons are line glyphs
 * inlined with `currentColor` so the active chip can light up in the brand purple
 * (per the design annotation, the icon set is meant to change per solution).
 *
 * All five panels are stacked in one CSS grid cell (`grid-area: 1/1`) so the area
 * auto-sizes to the tallest step and panels crossfade in place with no layout jump;
 * the navbar drives `[data-active]` on the section. Below `lg` the navbar becomes a
 * horizontal row above the card and each panel stacks text over media. Gated on the
 * shared `[data-reveal]` entrance; reduced motion gets instant swaps.
 *
 * Content-free — copy comes from src/data/solutions.json (`howItWorks`).
 */
import Eyebrow from "../ui/Eyebrow.astro";
import solutions from "../../data/solutions.json";

const { eyebrow, headline, capabilities, steps } = solutions.howItWorks;

// Line glyphs for the navbar, keyed by `step.icon`. Sliced from the Figma export
// and switched to `currentColor` so the chip colours them via text colour.
const icons: Record<string, string> = {
