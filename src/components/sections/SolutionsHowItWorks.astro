---

<section
  data-howitworks
  class="bg-surface text-black"
>
  <div
    class="mx-auto flex w-full max-w-[1440px] flex-col items-center gap-[clamp(3rem,8vw,80px)] px-4 pb-[clamp(5rem,12vw,120px)] pt-[clamp(5rem,14vw,200px)] md:px-8"
  >
    {/* ---- Header --------------------------------------------------------- */}
    <header class="flex flex-col items-center gap-8 text-center md:gap-10">
      <div data-reveal>
        <Eyebrow dotClass="bg-purple-500">{eyebrow}</Eyebrow>
      </div>
      <h2
        data-reveal="title"
        class="max-w-[952px] font-serif text-[clamp(2rem,5vw,56px)] font-normal leading-[1.2] tracking-[-0.02em]"
      >
        {headline}
      </h2>
      <div
        data-reveal
        class="flex flex-wrap items-center justify-center gap-y-2"
      >
        {
          capabilities.map((label, i) => (
            <span
              class:list={[
                "px-4 text-sm font-semibold uppercase leading-[1.2] tracking-[-0.01em]",
                i < capabilities.length - 1 && "border-r border-black/24",
              ]}
            >
              {label}
            </span>
          ))
        }
      </div>
    </header>

    {/* ---- Stepper -------------------------------------------------------- */}
    <div
      data-reveal
      class="relative flex w-full max-w-[1064px] flex-col gap-8 lg:max-w-[1208px] lg:flex-row lg:items-start lg:gap-[clamp(2rem,4vw,52px)]"
    >
      {/* Lateral icon navbar — horizontal row on mobile, vertical pill at lg+ */}
      <nav
        role="tablist"
        aria-label="How it works steps"
        class="flex shrink-0 flex-row gap-2 self-center rounded-card bg-ink-wash p-2 lg:flex-col lg:self-start"
      >
        {
          steps.map((step, i) => (
            <button
              type="button"
              role="tab"
              data-step-btn={i}
              id={`hiw-tab-${i}`}
              aria-controls={`hiw-panel-${i}`}
              aria-selected={i === 0 ? "true" : "false"}
              aria-label={step.navLabel}
              class="grid size-10 place-items-center rounded-3xl border transition-colors duration-300 ease-[cubic-bezier(0.33,1,0.68,1)] border-gray-200 text-black/40 hover:text-black/70 aria-selected:border-brand aria-selected:bg-white aria-selected:text-brand"
            >
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="size-6"
                aria-hidden="true"
                set:html={icons[step.icon]}
              />
            </button>
          ))
        }
      </nav>

      {/* Panels — stacked in one grid cell so the area sizes to the tallest
          step and panels crossfade in place. */}
      <div class="hiw-stack grid flex-1">
        {
          steps.map((step, i) => (
            <div
              data-step-panel={i}
              role="tabpanel"
              id={`hiw-panel-${i}`}
              aria-labelledby={`hiw-tab-${i}`}
              hidden={i !== 0}
              class="hiw-panel flex flex-col items-stretch gap-8 overflow-hidden rounded-card lg:flex-row lg:items-center lg:justify-between lg:gap-12"
            >
              <div class="flex flex-col gap-6 lg:max-w-[473px]">
                <p class="text-sm font-semibold uppercase leading-[1.2] tracking-[-0.01em]">
                  {step.eyebrow}
                </p>
                <h3 class="font-serif text-[clamp(1.75rem,4vw,48px)] font-normal leading-[1.2] tracking-[-0.02em]">
                  {step.heading}
                </h3>
                <p class="text-[clamp(1.125rem,2vw,24px)] font-normal leading-[1.2] tracking-[-0.02em]">
                  {step.body}
                </p>
              </div>
              <div class="aspect-square w-full shrink-0 rounded-card bg-white lg:aspect-auto lg:h-[616px] lg:w-[522px]" />
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<script>
  // Icon navbar drives the active step: clicking a tab swaps aria-selected and
  // reveals its panel. Panels share one grid cell (CSS), so this is just a
  // visibility toggle — the stack handles the crossfade.
  function initHowItWorks(section: HTMLElement) {
    const tabs = Array.from(
      section.querySelectorAll<HTMLButtonElement>("[data-step-btn]"),
    );
    const panels = Array.from(
      section.querySelectorAll<HTMLElement>("[data-step-panel]"),
    );
    if (!tabs.length) return;

    const select = (index: number) => {
      tabs.forEach((tab, i) =>
        tab.setAttribute("aria-selected", i === index ? "true" : "false"),
      );
      panels.forEach((panel, i) => {
        // `[hidden]` drives both the crossfade (via CSS) and the a11y tree; the
        // forced `display: grid` keeps every panel in the same grid cell so the
        // area stays sized to the tallest step.
        panel.toggleAttribute("hidden", i !== index);
      });
    };

    tabs.forEach((tab, i) => {
      tab.addEventListener("click", () => select(i));
      // Roving arrow-key navigation across the tablist.
      tab.addEventListener("keydown", (e) => {
        if (e.key !== "ArrowDown" && e.key !== "ArrowRight" &&
            e.key !== "ArrowUp" && e.key !== "ArrowLeft") return;
        e.preventDefault();
        const dir = e.key === "ArrowDown" || e.key === "ArrowRight" ? 1 : -1;
        const next = (i + dir + tabs.length) % tabs.length;
        select(next);
        tabs[next].focus();
      });
    });

    select(0);
  }

  document
    .querySelectorAll<HTMLElement>("[data-howitworks]")
    .forEach(initHowItWorks);
</script>

<style>
  /* All panels occupy the same grid cell so the area sizes to the tallest step
     and the active one crossfades over the inactive ones — no layout jump on
     switch. Inactive panels keep their box (forced `display`) so the grid stays
     sized to the tallest step; `[hidden]` only fades + de-activates them. */
  .hiw-stack > .hiw-panel {
    grid-area: 1 / 1;
    display: flex;
  }
  .hiw-panel {
    transition:
      opacity 0.5s ease-out,
      transform 0.6s cubic-bezier(0.33, 1, 0.68, 1);
  }
  .hiw-panel[hidden] {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transform: translateY(8px);
    transition:
      opacity 0.5s ease-out,
      transform 0.6s cubic-bezier(0.33, 1, 0.68, 1),
      visibility 0s linear 0.5s;
  }

  @media (prefers-reduced-motion: reduce) {
    .hiw-panel,
    .hiw-panel[hidden] {
      transition: none;
      transform: none;
    }
  }
</style>
