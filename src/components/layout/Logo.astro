---
/**
 * Logo — the "Sword Intelligence" wordmark from the design.
 * Rendered from the SVG asset in public/logotype.svg (168×21, native size).
 * The accessible label text comes from src/data/site.json.
 */
import site from "../../data/site.json";

interface Props {
  href?: string;
  /** "dark" — native black wordmark (default); "light" — rendered white for dark backgrounds. */
  tone?: "dark" | "light";
  class?: string;
}
const { href = "/", tone = "dark", class: className = "" } = Astro.props;
const { bold, regular } = site.logo;

// The wordmark SVG is solid black; flip it to white on dark backgrounds.
const toneClass = tone === "light" ? "[filter:brightness(0)_invert(1)]" : "";
---

<a
  href={href}
  class={`inline-flex items-center ${className}`}
  aria-label={`${bold} ${regular}`}
>
  <img
    src="/logotype.svg"
    width="168"
    height="21"
    alt={`${bold} ${regular}`}
    class={`block h-[21px] w-auto ${toneClass}`}
  />
</a>
