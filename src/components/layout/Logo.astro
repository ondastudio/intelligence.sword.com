---
/**
 * Logo — the "Sword Intelligence" wordmark from the design.
 * Rendered from the SVG asset in public/logotype.svg (168×21, native size).
 * The accessible label text comes from src/data/site.json.
 */
import site from "../../data/site.json";

interface Props {
  href?: string;
  class?: string;
}
const { href = "/", class: className = "" } = Astro.props;
const { bold, regular } = site.logo;
---

<a
  href={href}
  class={`inline-flex items-center ${className}`}
  aria-label={`${bold} ${regular}`}
>
  <img
    src="/logotype.svg"
    width="168"
    height="21"
    alt={`${bold} ${regular}`}
    class="block h-[21px] w-auto"
  />
</a>
