---
/**
 * Logo — the "sword | Intelligence" wordmark from the design.
 * Rendered as text (crisp + editable). Text comes from src/data/site.json.
 */
import site from "../../data/site.json";

interface Props {
  href?: string;
  class?: string;
}
const { href = "/", class: className = "" } = Astro.props;
const { bold, regular } = site.logo;
---

<a
  href={href}
  class={`inline-flex items-center gap-2 text-[19px] leading-none text-black ${className}`}
  aria-label={`${bold} ${regular}`}
>
  <span class="font-bold tracking-tight">{bold}</span>
  <span class="h-[18px] w-px bg-black/30" aria-hidden="true"></span>
  <span class="font-normal">{regular}</span>
</a>
