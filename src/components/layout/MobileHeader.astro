---
/**
 * MobileHeader — the floating lavender nav pill from the 390px design.
 *
 * On mobile (below lg) it's the primary nav, visible near the top of the page,
 * hiding on scroll-down and revealing on scroll-up.
 * On desktop (lg+) it doubles as a SECONDARY nav: the primary `Navbar` owns the
 * top of the page, and this pill (centered, constrained to a pill width) stays
 * hidden until the page's first section has scrolled off the top — then it fades
 * in, and fades back out when the user scrolls up to that section (see script).
 *
 * Rendered once at the page root (see Layout.astro), OUTSIDE `.page-content`, so
 * it's never trapped inside a section's stacking context: pages wrap their
 * content sections in `isolate` wrappers, and a fixed nav nested in the hero
 * would be out-painted by those sibling wrappers no matter its z-index. Kept at
 * the body level it always stays on top.
 */
import site from "../../data/site.json";
import Button from "../ui/Button.astro";

// Mobile menu content is authored separately from the desktop nav so the two
// can diverge (the mobile panel has an expandable Solutions section).
const mobileItems = site.mobileMenu.items.filter((item) => !item.hidden);

// Tablet + desktop (md+) tab row: render EVERY item, including `hidden` ones, so
// the Solution tab + its mega-menu live in the DOM ready to flip on later — the
// `hidden` flag just adds a `hidden` class instead of dropping the markup.
const tabItems = site.mobileMenu.items;
---

{/*
  `fixed` so it stays put while the page scrolls. It also hides (fades + slides
  up) when scrolling down and reappears when scrolling up — see the script.
*/}
{/*
  `pointer-events-none` on the <header> itself: the menu panel below is laid out
  (not display:none) even when closed, so the header's box extends down over the
  hero. Without this, the transparent header would swallow taps meant for hero
  content beneath it (e.g. the eyebrow link). The pill and the open panel below
  re-enable pointer events on themselves.
*/}
<header
  class="pre-init pointer-events-none fixed inset-x-0 top-0 z-30 px-5 pt-[14px] lg:mx-auto lg:max-w-[760px] lg:px-0 lg:pt-5"
  data-mobile-header
>
  {/*
    Mobile: a full-width pill (logo · MENU · CTA spread by justify-between).
    Tablet + desktop (md+): a compact, content-hugging pill centered on screen,
    matching the design (logo · MENU · CTA snug with an 8px gap).
  */}
  <div
    class="pointer-events-auto flex items-center justify-between rounded-full bg-lavender py-1 pl-8 pr-1 backdrop-blur-[20px] md:mx-auto md:w-fit md:justify-center md:gap-2"
  >
    <!-- Sword logomark (left) — shared across all breakpoints. -->
    <a
      href="/"
      class="text-black"
      aria-label={`${site.logo.bold} ${site.logo.regular}`}
    >
      <svg
        class="block h-[22px] w-auto"
        viewBox="0 0 467 832"
        fill="none"
        aria-hidden="true"
      >
        <path
          d="M233.352 9.61826e-06C187.21 -0.0132702 142.1 13.7252 103.728 39.4791C65.3554 65.233 35.444 101.845 17.777 144.684C0.109878 187.524 -4.5193 234.666 4.47453 280.15C13.4684 325.634 35.6814 367.416 68.3043 400.211C100.927 433.007 142.495 455.342 187.749 464.394C233.004 473.446 279.914 468.807 322.545 451.064C365.176 433.321 401.614 403.271 427.251 364.714C452.888 326.157 466.571 280.825 466.571 234.452C466.58 203.666 460.554 173.181 448.838 144.736C437.122 116.291 419.944 90.4451 398.287 68.6733C376.629 46.9015 350.917 29.6311 322.617 17.848C294.317 6.0648 263.985 8.35522e-06 233.352 9.61826e-06ZM233.352 384.241C203.858 384.241 175.027 375.45 150.504 358.981C125.982 342.512 106.87 319.103 95.586 291.717C84.3022 264.33 81.3533 234.196 87.1122 205.125C92.8711 176.054 107.079 149.352 127.939 128.397C148.799 107.442 175.375 93.1745 204.304 87.3998C233.233 81.6252 263.216 84.6028 290.461 95.9554C317.706 107.308 340.989 126.525 357.366 151.178C373.742 175.83 382.476 204.81 382.463 234.452C382.445 274.184 366.728 312.284 338.766 340.373C310.804 368.462 272.887 384.241 233.352 384.241Z"
          fill="currentColor"></path>
        <path
          d="M388.134 677.831C388.134 592.273 318.776 522.503 233.219 521.994C147.663 521.485 78.3057 590.432 78.3057 675.99C78.3058 761.548 147.663 831.319 233.219 831.827C318.776 832.336 388.134 763.39 388.134 677.831Z"
          fill="currentColor"></path>
      </svg>
    </a>

    <!-- MENU toggle (center) -->
    <button
      type="button"
      class="flex items-center gap-2 px-6 text-sm font-semibold uppercase text-black"
      aria-expanded="false"
      aria-controls="mobile-menu-panel"
      data-menu-toggle
    >
      Menu
      <!-- Dot-grid when closed; swaps to a close (✕) when the panel is open.
           md+ rotates it to the diamond `ai-menu` mark from the desktop design. -->
      <svg
        class="size-4 md:rotate-45"
        viewBox="0 0 16 16"
        fill="none"
        aria-hidden="true"
        data-menu-icon-open
      >
        <circle cx="3" cy="3" r="3" fill="currentColor"></circle>
        <circle cx="13" cy="3" r="3" fill="currentColor"></circle>
        <circle cx="3" cy="13" r="3" fill="currentColor"></circle>
        <circle cx="13" cy="13" r="3" fill="currentColor"></circle>
      </svg>
      <svg
        class="hidden size-4"
        viewBox="0 0 16 16"
        fill="none"
        aria-hidden="true"
        data-menu-icon-close
      >
        <path
          d="M3 3l10 10M13 3L3 13"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
        ></path>
      </svg>
    </button>

    <!-- Primary CTA (right) -->
    <Button variant="solid" href={site.cta.href}>{site.cta.label}</Button>
  </div>

  <!--
    Slide-down nav panel revealed by MENU. Kept in the DOM (not `display:none`)
    so it can fade + slide via CSS transitions; the closed state is
    pointer-events-none + opacity-0 so it neither shows nor intercepts taps.
    Height is capped to the viewport with internal scrolling for long menus.
  -->
  <div
    id="mobile-menu-panel"
    class="pointer-events-none mt-2 origin-top -translate-y-2 opacity-0 transition duration-200 ease-out"
    data-menu-panel
    aria-hidden="true"
  >
    {/* Phone (< md): the vertical list panel. */}
    <div
      class="max-h-[calc(100dvh-6rem)] overflow-y-auto rounded-[40px] bg-lavender p-8 backdrop-blur-[20px] md:hidden"
    >
    <nav
      class="flex flex-col font-sans text-sm font-semibold uppercase tracking-[-0.14px] text-black"
    >
      {
        mobileItems.map((item, i) => {
          // Items are separated by a divider; the outer edges sit flush against
          // the panel padding (first: bottom-only, last: top-only, no border).
          const edge =
            i === mobileItems.length - 1
              ? "pt-3"
              : i === 0
                ? "border-b border-black/24 pb-3"
                : "border-b border-black/24 py-3";
          return item.groups ? (
            <div class={edge} data-submenu>
              <button
                type="button"
                class="flex w-full items-center justify-between font-sans uppercase tracking-[-0.14px]"
                aria-expanded="false"
                data-submenu-toggle
              >
                <span>{item.label}</span>
                <svg
                  class="size-3 transition-transform duration-200"
                  viewBox="0 0 12 12"
                  fill="none"
                  aria-hidden="true"
                  data-submenu-caret
                >
                  <path
                    d="M2.5 4.5 6 8l3.5-3.5"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </button>

              <div class="hidden flex-col gap-6 pb-3 pt-6" data-submenu-panel>
                {item.groups.map((group) => (
                  <div class="flex flex-col gap-4">
                    <p class="w-full">{group.label}</p>
                    <div class="flex flex-col gap-6">
                      {group.items.map((sub) => (
                        <a href={sub.href} class="flex items-start gap-4">
                          <span class="flex size-10 shrink-0 items-center justify-center rounded-full border-[1.5px] border-dotted border-black">
                            {sub.icon && (
                              <img
                                src={sub.icon}
                                alt=""
                                aria-hidden="true"
                                class="size-6"
                              />
                            )}
                          </span>
                          <span class="flex min-w-0 flex-1 flex-col">
                            <span class="text-black">{sub.title}</span>
                            <span class="text-ink-mid">{sub.subtitle}</span>
                          </span>
                        </a>
                      ))}
                    </div>
                  </div>
                ))}
              </div>
            </div>
          ) : (
            <a href={item.href} class={edge}>
              {item.label}
            </a>
          );
        })
      }
    </nav>
    </div>

    {/*
      Tablet + desktop (md+): a centered row of tab pills, plus a mega-menu panel
      for any tab that has groups (Solution). Tabs without groups are plain links;
      the Solution tab toggles its panel and turns purple while open. `hidden`
      items (Solution, for now) stay in the DOM but get a `hidden` class.
    */}
    <div class="hidden flex-col items-center gap-2 md:flex">
      {/* Tab row — pills sit flush (no gap); their full radius makes the seam. */}
      <div class="flex items-center justify-center">
        {
          tabItems.map((item, i) => {
            // `hidden` and `inline-flex` are both display utilities, so a hidden
            // item picks `hidden` INSTEAD of `inline-flex` (layering both lets
            // inline-flex win the cascade and the pill shows anyway).
            const pill =
              "h-10 items-center gap-2 whitespace-nowrap rounded-full px-6 text-sm font-semibold uppercase backdrop-blur-[20px] transition-colors";
            const show = item.hidden ? "hidden" : "inline-flex";
            return item.groups ? (
              <button
                type="button"
                class={`${show} ${pill} bg-lavender text-black`}
                aria-expanded="false"
                aria-controls={`menu-tab-${i}`}
                data-tab-toggle={`menu-tab-${i}`}
              >
                {item.label}
                <svg
                  class="h-[6px] w-[12px] transition-transform duration-200"
                  viewBox="0 0 9.17558 5.58579"
                  fill="none"
                  aria-hidden="true"
                  data-tab-caret
                >
                  <path
                    d="M5.2949 5.29289C4.90437 5.68342 4.27121 5.68342 3.88068 5.29289L0.294898 1.70711C-0.335067 1.07714 0.111099 0 1.002 0H8.17358C9.06448 0 9.51065 1.07714 8.88068 1.70711L5.2949 5.29289Z"
                    fill="currentColor"
                  />
                </svg>
              </button>
            ) : (
              <a
                href={item.href}
                class={`${show} ${pill} bg-lavender text-black hover:bg-purple-100`}
              >
                {item.label}
              </a>
            );
          })
        }
      </div>

      {
        tabItems.map((item, i) =>
          item.groups ? (
            <div
              id={`menu-tab-${i}`}
              class="hidden max-h-[calc(100dvh-8rem)] overflow-y-auto rounded-[24px] bg-lavender p-8 backdrop-blur-[20px]"
              data-tab-panel
            >
              <div class="flex w-[649px] max-w-full items-start gap-20 font-sans text-sm font-semibold uppercase tracking-[-0.14px] text-black">
                {item.groups.map((group) => (
                  <div class="flex flex-1 flex-col gap-10">
                    <p class="w-full text-black">{group.label}</p>
                    <div class="flex flex-col gap-6">
                      {group.items.map((sub) => (
                        <a href={sub.href} class="flex w-full items-start gap-4">
                          <span class="flex size-10 shrink-0 items-center justify-center rounded-full border-2 border-dotted border-black">
                            {sub.icon && (
                              <img
                                src={sub.icon}
                                alt=""
                                aria-hidden="true"
                                class="size-6"
                              />
                            )}
                          </span>
                          <span class="flex min-w-0 flex-1 flex-col">
                            <span class="w-full text-black">{sub.title}</span>
                            <span class="w-full text-ink-mid">
                              {sub.subtitle}
                            </span>
                          </span>
                        </a>
                      ))}
                    </div>
                  </div>
                ))}
              </div>
            </div>
          ) : null,
        )
      }
    </div>
  </div>
</header>

<style>
  /* Hide-on-scroll-down animation. Driven via `transform` (not the individual
     `translate` property): Safari interpolates `transform` between `none` and a
     value reliably in BOTH directions, whereas transitioning the `translate`
     property from `none` only animated on the way in — the out jumped. */
  [data-mobile-header] {
    transition:
      transform 500ms ease-out,
      opacity 500ms ease-out;
  }
  [data-mobile-header].is-hidden {
    transform: translateY(-100%);
    opacity: 0;
  }

  /* No-flash guard (removed by the script once the real state is computed). On
     md+ (tablet + desktop) the secondary nav starts hidden — without a
     transition — so it never flashes at the top of the page on load. Phones are
     untouched: there the pill is the primary nav and is meant to be visible at
     the top. */
  [data-mobile-header].pre-init {
    transition: none;
  }
  @media (min-width: 768px) {
    [data-mobile-header].pre-init {
      transform: translateY(-100%);
      opacity: 0;
    }
  }
</style>

<script>
  const header = document.querySelector<HTMLElement>("[data-mobile-header]");
  if (header) {
    const toggle =
      header.querySelector<HTMLButtonElement>("[data-menu-toggle]");
    const panel = header.querySelector<HTMLElement>("[data-menu-panel]");
    const iconOpen = header.querySelector<HTMLElement>("[data-menu-icon-open]");
    const iconClose = header.querySelector<HTMLElement>(
      "[data-menu-icon-close]",
    );

    const setOpen = (open: boolean) => {
      toggle?.setAttribute("aria-expanded", String(open));
      panel?.setAttribute("aria-hidden", String(!open));
      // Closed-state classes; removing them lets the panel fade + slide in.
      panel?.classList.toggle("opacity-0", !open);
      panel?.classList.toggle("-translate-y-2", !open);
      // Header is pointer-events-none, so the open panel must opt back IN to
      // pointer events (a removed `none` would otherwise inherit none).
      panel?.classList.toggle("pointer-events-none", !open);
      panel?.classList.toggle("pointer-events-auto", open);
      iconOpen?.classList.toggle("hidden", open);
      iconClose?.classList.toggle("hidden", !open);
      // Collapse any open md+ tab (e.g. Solution) so the menu reopens clean.
      if (!open) closeTabs();
    };

    toggle?.addEventListener("click", (e) => {
      e.stopPropagation();
      setOpen(toggle.getAttribute("aria-expanded") !== "true");
    });

    // Expandable sub-sections inside the panel (e.g. Solutions).
    panel
      ?.querySelectorAll<HTMLElement>("[data-submenu]")
      .forEach((submenu) => {
        const subToggle = submenu.querySelector<HTMLButtonElement>(
          "[data-submenu-toggle]",
        );
        const subPanel = submenu.querySelector<HTMLElement>(
          "[data-submenu-panel]",
        );
        const caret = submenu.querySelector<HTMLElement>(
          "[data-submenu-caret]",
        );
        subToggle?.addEventListener("click", () => {
          const open = subToggle.getAttribute("aria-expanded") !== "true";
          subToggle.setAttribute("aria-expanded", String(open));
          subPanel?.classList.toggle("hidden", !open);
          subPanel?.classList.toggle("flex", open);
          caret?.classList.toggle("rotate-180", open);
        });
      });

    // md+ tab pills: a tab with a [data-tab-toggle] reveals its mega-menu panel
    // and turns purple while open. Only one is open at a time.
    const tabToggles = Array.from(
      panel?.querySelectorAll<HTMLButtonElement>("[data-tab-toggle]") ?? [],
    );
    const setTab = (btn: HTMLButtonElement, open: boolean) => {
      const target = document.getElementById(
        btn.getAttribute("data-tab-toggle") ?? "",
      );
      const caret = btn.querySelector<HTMLElement>("[data-tab-caret]");
      btn.setAttribute("aria-expanded", String(open));
      btn.classList.toggle("bg-brand", open);
      btn.classList.toggle("text-white", open);
      btn.classList.toggle("bg-lavender", !open);
      btn.classList.toggle("text-black", !open);
      target?.classList.toggle("hidden", !open);
      caret?.classList.toggle("rotate-180", open);
    };
    function closeTabs() {
      tabToggles.forEach((btn) => setTab(btn, false));
    }
    tabToggles.forEach((btn) => {
      btn.addEventListener("click", () => {
        const open = btn.getAttribute("aria-expanded") !== "true";
        closeTabs();
        setTab(btn, open);
      });
    });

    document.addEventListener("click", (e) => {
      if (!header.contains(e.target as Node)) setOpen(false);
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") setOpen(false);
    });

    const isMenuOpen = () => toggle?.getAttribute("aria-expanded") === "true";
    const isMdUp = () => window.matchMedia("(min-width: 768px)").matches;
    const setHidden = (hidden: boolean) => {
      header.classList.toggle("is-hidden", hidden);
    };

    // Reveal anchor — the hero. A page can flag one explicitly with
    // [data-secondary-nav-anchor] (e.g. the customers "highlight" card);
    // otherwise we fall back to the page's first hero <section>.
    const anchor =
      document.querySelector<HTMLElement>("[data-secondary-nav-anchor]") ??
      document.querySelector<HTMLElement>(".page-content section") ??
      document.querySelector<HTMLElement>("section");

    let ticking = false;
    let lastY = window.scrollY;
    let lastTop = anchor ? anchor.getBoundingClientRect().top : 0;

    const onScroll = () => {
      ticking = false;

      // md+ (desktop + tablet) — this pill is a SECONDARY nav. It stays hidden
      // by default and fades IN only while the user scrolls UP below the hero,
      // then fades back OUT before the hero scrolls into view. Scroll direction
      // is read from the hero's viewport position (getBoundingClientRect), which
      // is robust to whichever element actually scrolls.
      if (isMdUp()) {
        // A pinned, actively-scrubbing section (e.g. Triage) can flag the
        // document to lock this pill: its in-place scroll moves the page up,
        // which would otherwise read as a scroll-up and fire the nav. Stay
        // hidden while locked (unless the menu is open), but keep the direction
        // refs current so detection resumes cleanly once the lock releases.
        const locked = document.documentElement.classList.contains(
          "secondary-nav-locked",
        );
        if (locked && !isMenuOpen()) {
          setHidden(true);
          if (anchor) lastTop = anchor.getBoundingClientRect().top;
          lastY = window.scrollY;
          return;
        }
        if (!anchor) {
          setHidden(!isMenuOpen());
          lastY = window.scrollY;
          return;
        }
        const rect = anchor.getBoundingClientRect();
        const top = rect.top;
        const belowHero = rect.bottom < 0; // hero fully above the viewport
        const scrollingUp = top > lastTop + 4; // hero moved down ⇒ scrolled up
        const scrollingDown = top < lastTop - 4;
        lastTop = top;
        if (isMenuOpen()) setHidden(false);
        else if (!belowHero) setHidden(true); // fade out before the hero
        else if (scrollingUp) setHidden(false);
        else if (scrollingDown) setHidden(true);
        lastY = window.scrollY;
        return;
      }

      // Phone — this IS the primary nav, so it shows near the top and hides on
      // scroll-down / reveals on scroll-up.
      const y = window.scrollY;
      if (isMenuOpen() || y <= 80) {
        setHidden(false);
      } else if (y > lastY + 4) {
        setHidden(true);
      } else if (y < lastY - 4) {
        setHidden(false);
      }
      lastY = y;
    };

    // Capture-phase so scrolls from a nested scroller (not just the window) also
    // drive the reveal.
    document.addEventListener(
      "scroll",
      () => {
        if (!ticking) {
          ticking = true;
          requestAnimationFrame(onScroll);
        }
      },
      { passive: true, capture: true },
    );
    // Set the initial state and re-apply when crossing the breakpoint so the
    // pill never lingers in the wrong viewport's state.
    onScroll();
    window.addEventListener("resize", onScroll, { passive: true });
    // Drop the no-flash guard only once the page has settled at its final scroll
    // position (`load` + a frame). While the guard is on, the desktop pill is
    // force-hidden regardless of `is-hidden`, so a first-load scroll transient —
    // e.g. the home page's heavy JS (swirl canvas, product video) momentarily
    // shifting layout, or the browser restoring a scroll position — can't flash
    // the pill at the top. After this, the `is-hidden` fade takes over.
    const dropPreInit = () =>
      requestAnimationFrame(() => header.classList.remove("pre-init"));
    if (document.readyState === "complete") dropPreInit();
    else window.addEventListener("load", dropPreInit, { once: true });
  }
</script>
