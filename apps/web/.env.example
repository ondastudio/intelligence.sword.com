# Sanity — copy to .env.local and fill in. PUBLIC_* are exposed to the build.
PUBLIC_SANITY_PROJECT_ID=
PUBLIC_SANITY_DATASET=production

# Perspective: "published" (prod build) or "previewDrafts" (Netlify preview ctx)
SANITY_PERSPECTIVE=published

# Read token — ONLY needed for drafts/previewDrafts builds (Viewer role).
SANITY_API_READ_TOKEN=

# Write token — ONLY used by the migration script (Editor role). Never in the build.
SANITY_API_WRITE_TOKEN=
