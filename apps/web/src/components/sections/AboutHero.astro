---
/**
 * AboutHero — the full-viewport manifesto hero for the About page.
 *
 * Two states, joined by a scroll-driven transition (Figma node 8616:10):
 *   1. Top of page — the manifesto film fills the viewport and plays, with the
 *      shared MediaFrame controls (play/pause + mute) and a reproduction bar.
 *   2. Scrolled — the film pauses, the controls + bar fade away, the film dims
 *      under a scrim, and the mission eyebrow + statement resolve out of a blur
 *      (the house "title" reveal) over it.
 *
 * Mechanics (lg-agnostic; gated on motion + JS): the section is taller than the
 * viewport and the stage is `sticky`, so it pins while a vanilla rAF scrubber
 * maps scroll progress through the section into the timeline above. Without JS
 * or with reduced motion the markup falls back to the Figma end state — the
 * blurred film with the mission text shown — so the message is never hidden.
 *
 * Content comes from src/data/about.json.
 */
import { getAboutPage } from "../../lib/sanity/queries";
const about = await getAboutPage();
import Navbar from "../layout/Navbar.astro";
import Eyebrow from "../ui/Eyebrow.astro";
import MediaFrame from "../ui/MediaFrame.astro";
---

<section data-about-hero class="about-hero relative bg-ink text-white">
  <div data-about-stage class="about-stage relative overflow-hidden">
    <!-- Full-bleed manifesto film + shared controls + reproduction bar. -->
    <div data-about-video class="about-video absolute inset-0 z-0">
      <MediaFrame
        src={about.hero.media.src}
        alt={about.hero.media.alt}
        fill
        progress
        class="bg-ink"
      />
    </div>

    <!-- Dimming scrim that fades in as the film blurs away. -->
    <div
      data-about-overlay
      class="about-overlay pointer-events-none absolute inset-0 z-10 bg-ink"
    >
    </div>

    <Navbar tone="light" />

    <!-- Mission eyebrow + statement, pinned to the bottom-left like the design.
         Resolves out of a blur as the film recedes. -->
    <div
      data-about-text
      class="about-text pointer-events-none absolute inset-x-0 bottom-0 z-20"
    >
      <div
        class="mx-auto flex max-w-[1440px] flex-col gap-8 px-[clamp(1.25rem,5.2vw,75px)] pb-14 lg:gap-20 lg:pb-20"
      >
        <Eyebrow dotClass="bg-accent" textClass="text-white"
          >{about.hero.eyebrow}</Eyebrow
        >
        <h1
          class="max-w-[1137px] text-balance font-serif font-normal text-[2.625rem] sm:text-[clamp(3.25rem,5.5vw,5rem)]"
        >
          {about.hero.statement}
        </h1>
      </div>
    </div>
  </div>
</section>

<style>
  /* Base = Figma end state, so no-JS / reduced-motion still shows the message:
     the film blurred + dimmed with the mission text legible over it, and the
     interactive video controls hidden (they need JS anyway). */
  .about-hero {
    height: 100svh;
  }
  .about-stage {
    height: 100svh;
  }
  .about-overlay {
    opacity: 0.68;
  }
  [data-about-hero] :global([data-vp-toggle]),
  [data-about-hero] :global([data-vp-mute]),
  [data-about-hero] :global([data-vp-progress]) {
    opacity: 0;
    pointer-events: none;
  }

  /* Enhanced: pin the stage and start from the film-playing state. The scrubber
     drives the rest via inline styles. Pre-setting the start state here keeps
     the first paint flash-free before the rAF loop takes over. */
  @media (prefers-reduced-motion: no-preference) {
    :global(html.js) .about-hero {
      height: calc(100svh + 120vh);
    }
    :global(html.js) .about-stage {
      position: sticky;
      top: 0;
    }
    :global(html.js) .about-overlay {
      opacity: 0;
    }
    :global(html.js) .about-text {
      opacity: 0;
      filter: blur(12px);
    }
    :global(html.js) [data-about-hero] :global([data-vp-toggle]),
    :global(html.js) [data-about-hero] :global([data-vp-mute]),
    :global(html.js) [data-about-hero] :global([data-vp-progress]) {
      opacity: 1;
      pointer-events: auto;
    }
  }
</style>

<script>
  // Scroll-driven transition from "film playing" to "mission statement".
  // The stage is sticky inside a taller section; progress is how far the
  // section has scrolled past the top, normalised to its scrub distance.
  function initAboutHero(section: HTMLElement) {
    if (!window.matchMedia("(prefers-reduced-motion: no-preference)").matches)
      return;

    const video = section.querySelector<HTMLVideoElement>("video");
    const overlay = section.querySelector<HTMLElement>("[data-about-overlay]");
    const text = section.querySelector<HTMLElement>("[data-about-text]");
    const controls = Array.from(
      section.querySelectorAll<HTMLElement>(
        "[data-vp-toggle], [data-vp-mute], [data-vp-progress]",
      ),
    );
    if (!video || !overlay || !text) return;

    // Timeline (named so feel is easy to tune). Each pair is a progress window.
    const CONTROLS_FADE: [number, number] = [0, 0.28]; // controls + bar fade out
    const PAUSE_AT = 0.1; // film pauses past this point
    const FILM_RECEDE: [number, number] = [0.05, 0.5]; // dim the film
    const TEXT_REVEAL: [number, number] = [0.4, 0.92]; // statement out of blur
    const MAX_DIM = 0.68; // scrim opacity at full recede
    const TEXT_BLUR = 12; // px — statement start blur (house "title" reveal)

    const track = (p: number, [a, b]: [number, number]) =>
      Math.min(1, Math.max(0, (p - a) / (b - a)));
    const easeOutCubic = (t: number) => 1 - Math.pow(1 - t, 3);

    let ticking = false;

    const render = () => {
      ticking = false;
      const scrub = section.offsetHeight - window.innerHeight;
      const p =
        scrub > 0
          ? Math.min(1, Math.max(0, -section.getBoundingClientRect().top / scrub))
          : 0;

      // Controls + reproduction bar fade out first.
      const cOpacity = 1 - track(p, CONTROLS_FADE);
      for (const c of controls) {
        c.style.opacity = String(cOpacity);
        c.style.pointerEvents = cOpacity < 0.05 ? "none" : "";
      }

      // Pause once scrolled in; resume when scrolled back to the very top.
      if (p > PAUSE_AT) {
        if (!video.paused) video.pause();
      } else if (video.paused) {
        video.play().catch(() => {});
      }

      // Film dims away under the scrim.
      const recede = easeOutCubic(track(p, FILM_RECEDE));
      overlay.style.opacity = String(recede * MAX_DIM);

      // Mission statement resolves out of a blur, holding position.
      const reveal = easeOutCubic(track(p, TEXT_REVEAL));
      text.style.opacity = String(reveal);
      text.style.filter = `blur(${(1 - reveal) * TEXT_BLUR}px)`;
    };

    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(render);
    };

    render();
    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onScroll);
  }

  document
    .querySelectorAll<HTMLElement>("[data-about-hero]")
    .forEach(initAboutHero);
</script>
