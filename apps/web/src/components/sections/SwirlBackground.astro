---
/**
 * SwirlBackground — the animated WebGL swirl, rendered as ONE continuous canvas
 * that spans the hero and bleeds into the top of the following section before
 * fading out (so the swirl is seamless across the section boundary rather than
 * restarting). Sits behind page content; the static mesh PNG underneath is the
 * no-JS / reduced-motion fallback.
 *
 * Place this as the first child of a `relative` wrapper that contains the hero
 * and the section it should bleed into. The stage sizes itself to the hero
 * height plus a bleed, and a bottom mask fades the bleed region away.
 *
 * `contain` — for a standalone hero with no section to bleed into (e.g. the
 * Book-an-intro page): cap the stage to the hero height and fade the swirl out
 * within its own lower half, so nothing spills past the hero onto the footer.
 */
interface Props {
  contain?: boolean;
}
const { contain = false } = Astro.props;
---

<div
  data-swirl-stage
  data-swirl-contain={contain ? "" : undefined}
  aria-hidden="true"
  class="swirl-stage pointer-events-none absolute inset-x-0 top-0 z-0"
>
  <img
    src="/hero/mesh-gradient.png"
    alt=""
    class="absolute inset-0 h-full w-full object-cover"
  />
  <canvas
    data-swirl
    class="absolute inset-0 h-full w-full opacity-0 transition-opacity duration-700"
  ></canvas>
</div>

<script>
  import { initSwirl } from "../../lib/swirl";

  const stage = document.querySelector<HTMLElement>("[data-swirl-stage]");
  const canvas = stage?.querySelector<HTMLCanvasElement>("canvas[data-swirl]");
  const wrapper = stage?.parentElement;
  // The hero is the first <section> in the shared wrapper. (Don't use
  // nextElementSibling — Astro injects its bundled <script> right after the
  // stage, so that would measure the script tag, not the hero.)
  const hero = wrapper?.querySelector<HTMLElement>("section");
  // The swirl carries down and fades out just as it touches this element (the
  // heading of the section below the hero); marked with `data-swirl-end`.
  const endEl = wrapper?.querySelector<HTMLElement>("[data-swirl-end]");

  const contain = stage?.hasAttribute("data-swirl-contain") ?? false;

  if (stage && canvas && hero && wrapper) {
    const sizeStage = () => {
      const heroHeight = hero.offsetHeight;

      const setMaskFn = (mask: string) => {
        stage.style.maskImage = mask;
        stage.style.webkitMaskImage = mask;
      };

      // Standalone hero (no section to bleed into): cap to the hero height and
      // fade the swirl out through its lower half — strong at the top (behind
      // the eyebrow + headline), softening to nothing before the hero's bottom
      // edge so it never spills onto the footer below.
      if (contain) {
        stage.style.height = `${heroHeight}px`;
        setMaskFn(
          `linear-gradient(to bottom,` +
            ` #000 ${Math.round(heroHeight * 0.42)}px,` +
            ` rgba(0,0,0,0.5) ${Math.round(heroHeight * 0.72)}px,` +
            ` transparent ${heroHeight}px)`
        );
        return;
      }

      // On mobile the section below (Intro) supplies its own mesh-gradient
      // background graphic, so the swirl must NOT extend into it at all. Cap the
      // stage to exactly the hero height and fade the swirl out within the hero's
      // bottom edge — no tail bleeds past the boundary.
      const setMask = (mask: string) => {
        stage.style.maskImage = mask;
        stage.style.webkitMaskImage = mask;
      };
      if (window.matchMedia("(max-width: 639px)").matches) {
        const fade = Math.round(heroHeight * 0.14);
        stage.style.height = `${heroHeight}px`;
        setMask(
          `linear-gradient(to bottom,` +
            ` #000 ${heroHeight - fade}px,` +
            ` transparent ${heroHeight}px)`
        );
        return;
      }

      // sm+: carry the swirl down to the fade-target element (`data-swirl-end`),
      // falling back to a fraction of the hero height if that marker isn't
      // present.
      const reach = endEl
        ? Math.round(
            endEl.getBoundingClientRect().top - wrapper.getBoundingClientRect().top
          )
        : heroHeight + Math.round(heroHeight * 0.45);
      // Solid across the hero, then a long gradual fade so the swirl softens to
      // a faint lavender wash by the time it reaches the heading — it just
      // *touches* the text rather than carrying the full purple down to it.
      const tail = Math.round(heroHeight * 0.12);
      const total = reach + tail;
      const bleed = Math.max(1, reach - heroHeight);
      stage.style.height = `${total}px`;
      setMask(
        `linear-gradient(to bottom,` +
          ` #000 ${heroHeight}px,` +
          ` rgba(0,0,0,0.4) ${heroHeight + Math.round(bleed * 0.55)}px,` +
          ` rgba(0,0,0,0.12) ${reach}px,` +
          ` transparent ${total}px)`
      );
    };

    sizeStage();
    window.addEventListener("resize", sizeStage);

    // Contained heroes sit behind real content (a form), so dial the swirl
    // back to a softer wash that keeps black-bordered inputs + headline legible.
    if (contain) stage.style.opacity = "0.5";

    initSwirl(canvas, stage, { grainUrl: "/hero/swirl/perlin1.png" });
    requestAnimationFrame(() => canvas.classList.remove("opacity-0"));
  }
</script>
