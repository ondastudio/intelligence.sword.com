---
/**
 * BookIntroForm — the contact / "Book a meeting" page (Figma "Contact form",
 * node 9213:4256). A light hero with the desktop Navbar on top: a left intro
 * column (Eyebrow + Lora headline with a purple accent + supporting line) and a
 * right form column (name, email, company details, interests, message) closing
 * on a SUBMIT pill seamed to a filled ArrowCircle, then the privacy line.
 *
 * Submissions are captured by **Netlify Forms**. The markup carries the
 * detection attributes (`data-netlify`, hidden `form-name`, honeypot) so
 * Netlify registers the form at build time, and because the submit handler
 * intercepts the event (custom dropdown validation), the encoded fields are
 * POSTed back to the site with `fetch` rather than a native navigation.
 * Recipient/notification routing is configured in the Netlify dashboard.
 * Content lives in `data/book-intro.json`.
 */
import data from "../../data/book-intro.json";
import countries from "../../data/countries.json";
import Navbar from "../layout/Navbar.astro";
import Eyebrow from "../ui/Eyebrow.astro";
import FormField from "../ui/FormField.astro";
import SelectMenu from "../ui/SelectMenu.astro";
import ArrowCircle from "../ui/ArrowCircle.astro";

const { eyebrow, heading, subtext, form, privacy, success, error } = data;

// Netlify identifies submissions by this name (must match the hidden
// `form-name` input and the AJAX POST body below).
const formName = "book-intro";
---

<section class="relative z-10 min-h-screen text-ink">
  <Navbar tone="dark" />

  <div
    class="mx-auto flex max-w-[1440px] flex-col gap-12 px-6 pb-24 pt-32 lg:flex-row lg:items-start lg:justify-between lg:gap-16 lg:px-20 lg:pb-[120px] lg:pt-[182px]"
  >
    {/* Left — intro copy */}
    <div class="flex flex-1 flex-col gap-6">
      <Eyebrow>{eyebrow}</Eyebrow>
      <h1
        data-reveal="title"
        class="max-w-[630px] font-serif text-h4 font-normal text-ink"
      >
        {heading.line1}<br />
        <span class="text-brand">{heading.accent}</span>{heading.after}
      </h1>
      <p data-reveal class="max-w-[413px] text-md font-medium text-ink">
        {subtext}
      </p>
    </div>

    {/* Right — form (swapped for the success panel after submit) */}
    <div class="w-full lg:w-[522px] lg:shrink-0">
    <form
      data-book-intro-form
      name={formName}
      method="POST"
      data-netlify="true"
      netlify-honeypot="bot-field"
      class="flex w-full flex-col gap-[72px]"
    >
      {/* Netlify Forms: ties the POST to the registered form + a honeypot the
          bot trap fills but humans never see. */}
      <input type="hidden" name="form-name" value={formName} />
      <p hidden>
        <label>Don’t fill this out if you’re human: <input name="bot-field" /></label>
      </p>

      <div class="flex flex-col gap-10">
        <div class="flex flex-col gap-6">
          {/* Name + email */}
          <div class="flex flex-col gap-5">
            <div class="flex flex-col gap-5 sm:flex-row">
              <FormField
                name={form.name.first.name}
                placeholder={form.name.first.placeholder}
                required={form.name.first.required}
                class="flex-1"
              />
              <FormField
                name={form.name.last.name}
                placeholder={form.name.last.placeholder}
                required={form.name.last.required}
                class="flex-1"
              />
            </div>
            <FormField
              type="email"
              name={form.email.name}
              placeholder={form.email.placeholder}
              required={form.email.required}
            />
          </div>

          {/* Company details */}
          <fieldset>
            <legend class="mb-4 text-base font-semibold capitalize text-black"
              >{form.companyDetails.label}</legend
            >
            <div class="flex flex-col gap-5">
              <div class="flex flex-col gap-5 sm:flex-row">
                <FormField
                  name={form.companyDetails.jobTitle.name}
                  placeholder={form.companyDetails.jobTitle.placeholder}
                  required={form.companyDetails.jobTitle.required}
                  class="flex-1"
                />
                <FormField
                  name={form.companyDetails.companyName.name}
                  placeholder={form.companyDetails.companyName.placeholder}
                  required={form.companyDetails.companyName.required}
                  class="flex-1"
                />
              </div>
              <SelectMenu
                name={form.companyDetails.country.name}
                placeholder={form.companyDetails.country.placeholder}
                required={form.companyDetails.country.required}
                options={countries}
                searchable
                searchPlaceholder="Search a country"
              />
            </div>
          </fieldset>

          {/* Company interests */}
          <fieldset>
            <legend class="mb-4 text-base font-semibold capitalize text-black"
              >{form.companyInterests.label}</legend
            >
            <SelectMenu
              name={form.companyInterests.organizationType.name}
              placeholder={form.companyInterests.organizationType.placeholder}
              required={form.companyInterests.organizationType.required}
              options={form.companyInterests.organizationType.options}
            />
          </fieldset>

          {/* Message */}
          <fieldset>
            <legend class="mb-4 text-base font-semibold text-black"
              >{form.message.label}</legend
            >
            <FormField
              type="textarea"
              name={form.message.field.name}
              placeholder={form.message.field.placeholder}
            />
          </fieldset>
        </div>

        {/* Submit */}
        <div class="flex flex-col gap-4">
          <button
            type="submit"
            data-book-intro-submit
            class="group flex items-center self-start disabled:opacity-60"
            aria-label={form.submit}
          >
            <span
              class="rounded-[50px] bg-brand px-6 py-3 text-sm font-semibold uppercase leading-tight text-white"
              >{form.submit}</span
            >
            <ArrowCircle variant="filled" decorative detach label={form.submit} class="-ml-px" />
          </button>

          {/* Submission failure — revealed by the handler on a failed POST. */}
          <p
            data-book-intro-error
            hidden
            role="alert"
            class="text-base text-risk-high"
          >
            {error}
          </p>
        </div>
      </div>

      <p class="text-base text-black">
        {privacy.before}<a
          href={privacy.linkHref}
          target="_blank"
          rel="noopener noreferrer"
          class="underline">{privacy.linkLabel}</a
        >{privacy.after}
      </p>
    </form>

    {/* Success — shown in place of the form after submit (Figma 9222:91). */}
    <div
      data-book-intro-success
      hidden
      tabindex="-1"
      class="flex flex-col items-start gap-6 focus:outline-none"
    >
      <h2 class="font-serif text-h6 font-normal text-ink">{success.heading}</h2>
      <p class="max-w-[413px] text-lg font-medium text-ink">{success.body}</p>
      <button
        type="button"
        data-book-intro-back
        class="group flex items-center self-start"
        aria-label={success.back}
      >
        <ArrowCircle variant="filled" rotate={180} decorative label={success.back} />
        <span
          class="-ml-px rounded-[50px] bg-brand px-6 py-3 text-sm font-semibold uppercase leading-tight text-white"
          >{success.back}</span
        >
      </button>
    </div>
    </div>
  </div>
</section>

<script>
  // Submissions are sent to Netlify Forms. The handler intercepts submit (to
  // validate the custom dropdowns), so the encoded fields are POSTed back to
  // the site origin — Netlify captures any POST whose body carries `form-name`.
  const form = document.querySelector<HTMLFormElement>("[data-book-intro-form]");
  const success = document.querySelector<HTMLElement>("[data-book-intro-success]");
  const backBtn = document.querySelector<HTMLButtonElement>("[data-book-intro-back]");
  const submitBtn = document.querySelector<HTMLButtonElement>("[data-book-intro-submit]");
  const errorMsg = document.querySelector<HTMLElement>("[data-book-intro-error]");

  // Swap the form for the success panel (and back again on "Go back").
  const showSuccess = () => {
    if (!form || !success) return;
    form.hidden = true;
    success.hidden = false;
    success.focus();
  };
  backBtn?.addEventListener("click", () => {
    if (!form || !success) return;
    form.reset(); // clears native fields + fires `reset` (SelectMenus reset too)
    success.hidden = true;
    form.hidden = false;
    form.querySelector<HTMLInputElement>("input, textarea")?.focus();
  });

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();

    // Custom dropdowns (SelectMenu) sit outside HTML constraint validation, so
    // enforce their `required` flag here before the native check.
    for (const menu of form.querySelectorAll<HTMLElement>(
      "[data-select-menu][data-required]",
    )) {
      const value = menu.querySelector<HTMLInputElement>("[data-select-value]")?.value;
      if (!value) {
        menu.setAttribute("data-invalid", "");
        menu.querySelector<HTMLButtonElement>("[data-select-trigger]")?.focus();
        return;
      }
    }

    if (!form.reportValidity()) return;

    // POST the encoded fields back to the site so Netlify records the
    // submission (form-name + honeypot ride along in the FormData). Lock the
    // button so a slow network can't be double-submitted, and clear any error
    // left over from a previous attempt.
    if (errorMsg) errorMsg.hidden = true;
    if (submitBtn) submitBtn.disabled = true;

    try {
      const res = await fetch("/", {
        method: "POST",
        headers: { "Content-Type": "application/x-www-form-urlencoded" },
        body: new URLSearchParams(
          new FormData(form) as unknown as Record<string, string>,
        ).toString(),
      });
      // fetch only rejects on network failure, not on 4xx/5xx — check the
      // status too so a server-side rejection isn't reported as success.
      if (!res.ok) throw new Error(`Submission failed: ${res.status}`);
      showSuccess();
    } catch {
      // Network failure or non-OK response: keep the form (and the values the
      // visitor typed) in place and surface the error so they can retry.
      if (errorMsg) errorMsg.hidden = false;
    } finally {
      if (submitBtn) submitBtn.disabled = false;
    }
  });
</script>
