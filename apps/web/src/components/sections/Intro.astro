---
/**
 * Intro — the "AI Care Managers" section directly below the hero.
 * A faint mesh-gradient wash at the top, a centered mixed-weight positioning
 * statement, a strip of partner/client logos, and a large rounded product
 * screenshot. Content comes from src/data/intro.json.
 */
import { getHomePage } from "../../lib/sanity/queries";
import { serializeHeadline } from "../../lib/sanity/portableText";
const intro = (await getHomePage()).intro;
import LogoStrip from "../layout/LogoStrip.astro";
import LogoMarquee from "../layout/LogoMarquee.astro";
import ProductVideo from "../ui/ProductVideo.astro";
---

<!-- overflow-clip (not -hidden) so the sticky spotlight pin can reference the
     viewport while still clipping the mobile marquee bleed + bg image. On xl+ it
     goes visible so the spotlight card's viewport-filling dim shadow isn't
     clipped to the section — clipping showed a hard box edge on fast scroll.
     (The marquee/bg that need clipping are sm:hidden, so xl+ has nothing to clip.) -->
<section class="relative overflow-clip xl:overflow-visible text-black">
  <!-- On sm+ the soft top wash comes from <SwirlBackground /> bleeding the hero
       swirl across this section's edge. On mobile that bleed is replaced by the
       design's own mesh-gradient graphic (Figma "Home_Mobile_390px", 390×576):
       pinned to the top, full-width, behind the z-10 content, fading out by the
       time it reaches the product video. -->
  <img
    src="/intro/home-mobile-bg.png"
    alt=""
    aria-hidden="true"
    class="pointer-events-none absolute inset-x-0 top-0 z-0 w-full select-none sm:hidden"
  />

  <!-- Outer block keeps the design's 16px gutters so the product frame can
       span near-full-width; the text/logos sit in a narrower column inside. -->
  <div class="relative z-10 mx-auto w-full max-w-[1440px] px-4 pt-[120px]">
    <!-- Statement + logo strip: narrower centered column (max 1298px) -->
    <div
      class="mx-auto flex max-w-[1298px] flex-col items-center gap-20 px-2 pb-0 sm:px-6 sm:pb-20 lg:px-0"
    >
      <p
        class="mx-auto max-w-[350px] text-center text-xlg sm:max-w-[600px] md:max-w-[962px]"
      >
        <Fragment set:html={serializeHeadline(intro.lead)} />
      </p>

      <div data-reveal class="w-full" style="transition-delay:120ms">
        <!-- Mobile: a full-bleed auto-scrolling marquee. The `-mx-6` cancels the
             column's horizontal padding (px-4 outer + px-2 inner = 24px) so the
             strip runs edge to edge per the design; the section's overflow-hidden
             clips it. sm+: the segmented grid stays within the column. -->
        <div class="-mx-6 sm:hidden">
          <LogoMarquee logos={intro.logos} />
        </div>
        <div class="hidden sm:block">
          <LogoStrip logos={intro.logos} class="w-full" borderClass="border-black/24" />
        </div>
      </div>
    </div>
  </div>

  <!-- Product video: scroll-driven stage (shared ProductVideo). `spotlight`
       gives the desktop a Ramp-style gray stage with a pinned, contained,
       rounded card instead of the full-bleed takeover. -->
  <ProductVideo
    src={intro.media.src}
    poster={intro.media.poster}
    alt={intro.media.alt}
    spotlight
  />
</section>
