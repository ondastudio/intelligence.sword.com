---
/**
 * ArrowCircle — small 40px circular arrow button used across the Numbers
 * stat cards and the closing CTA. Faithful to the design export: a 40×40
 * dotted ring (round-capped dashes, `0.01 8`) enclosing a right-arrow glyph.
 *
 * variants:
 *   dotted — transparent fill, dotted black ring, dark glyph (default; all cards)
 *   filled — solid brand-purple fill, white glyph, no ring (CTA)
 * `glyph` swaps the centered icon: "arrow" (default), "info" (an "i", used by
 *   the Impact stat cards), or "linkedin" (the LinkedIn mark — About team cards).
 *   All share the same dotted ring + hover-to-solid morph.
 * `rotate` spins the glyph (e.g. 45 for the CTA's down-right arrow).
 * `detach` slides the circle slightly away from an adjoining pill on hover —
 *   set it when the circle sits next to a CTA pill and wrap the pair in `group`.
 * `decorative` renders an inert <span> (aria-hidden, not focusable) — use it
 *   when the circle is the visual affordance inside a fully-clickable card whose
 *   real link is a stretched overlay; the hover animations still fire via the
 *   card's `group`.
 * Renders an <a> when `href` is set, otherwise a <button>.
 */
interface Props {
  variant?: "dotted" | "filled";
  /** "dark" — for light backgrounds (default); "light" — for dark backgrounds. */
  tone?: "dark" | "light";
  glyph?: "arrow" | "info" | "linkedin";
  rotate?: number;
  href?: string;
  label?: string;
  detach?: boolean;
  decorative?: boolean;
  class?: string;
  [key: string]: unknown;
}
const {
  variant = "dotted",
  tone = "dark",
  glyph = "arrow",
  rotate = 0,
  href,
  label = "Learn more",
  detach = false,
  decorative = false,
  class: className = "",
  ...rest
} = Astro.props;

const toneClass =
  variant === "filled"
    ? tone === "light"
      ? "bg-accent text-ink"
      : "bg-brand text-white"
    : tone === "light"
      ? "text-white"
      : "text-black";

const classes = [
  "group inline-grid size-10 shrink-0 place-items-center rounded-full",
  detach ? "transition-transform duration-300 ease-out group-hover:translate-x-1" : "",
  toneClass,
  className,
].join(" ");

const Tag = decorative ? "span" : href ? "a" : "button";
const semanticAttrs = decorative
  ? { "aria-hidden": "true" }
  : { href, "aria-label": label };
---

<Tag class={classes} {...semanticAttrs} {...rest}>
  {
    variant !== "filled" && (
      <svg
        class="col-start-1 row-start-1 size-full"
        viewBox="0 0 40 40"
        fill="none"
        aria-hidden="true"
      >
        <rect
          x="1"
          y="1"
          width="38"
          height="38"
          rx="19"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-dasharray="0.01 8"
          class="group-hover:[stroke-dasharray:120_0] group-hover:[stroke-width:1]"
        />
      </svg>
    )
  }
  <svg
    class="col-start-1 row-start-1 size-6 self-center justify-self-center"
    viewBox="0 0 24 24"
    fill="none"
    aria-hidden="true"
    style={rotate ? `transform:rotate(${rotate}deg)` : undefined}
  >
    {
      glyph === "info" ? (
        <>
          <path
            d="M12 16.5V11.5"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
          <path
            d="M12 8.01V8"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </>
      ) : glyph === "linkedin" ? (
        // 18×18 LinkedIn mark centered in the 24-unit glyph box.
        <g transform="translate(3 3)" fill="currentColor">
          <path d="M14.3984 2.3999H3.59844C2.93544 2.3999 2.39844 2.9369 2.39844 3.5999V14.3999C2.39844 15.0629 2.93544 15.5999 3.59844 15.5999H14.3984C15.0614 15.5999 15.5984 15.0629 15.5984 14.3999V3.5999C15.5984 2.9369 15.0614 2.3999 14.3984 2.3999ZM6.57084 13.1999H4.80084V7.5047H6.57084V13.1999ZM5.66784 6.6905C5.09724 6.6905 4.63584 6.2279 4.63584 5.6585C4.63584 5.0891 5.09784 4.6271 5.66784 4.6271C6.23664 4.6271 6.69924 5.0897 6.69924 5.6585C6.69924 6.2279 6.23664 6.6905 5.66784 6.6905ZM13.2008 13.1999H11.432V10.4303C11.432 9.7697 11.42 8.9201 10.5122 8.9201C9.59124 8.9201 9.44964 9.6395 9.44964 10.3823V13.1999H7.68084V7.5047H9.37884V8.2829H9.40284C9.63924 7.8353 10.2164 7.3631 11.0774 7.3631C12.8696 7.3631 13.2008 8.5427 13.2008 10.0763V13.1999Z" />
        </g>
      ) : (
        <>
          <path
            d="M18.5 12H5"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
          <path
            d="M13 18C13 18 19 13.5811 19 12C19 10.4188 13 6 13 6"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </>
      )
    }
  </svg>
</Tag>
