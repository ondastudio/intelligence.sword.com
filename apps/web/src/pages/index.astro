---
import Layout from "../layouts/Layout.astro";
import SwirlBackground from "../components/sections/SwirlBackground.astro";
import Hero from "../components/sections/Hero.astro";
import Intro from "../components/sections/Intro.astro";
import Care from "../components/sections/Care.astro";
import Triage from "../components/sections/Triage.astro";
import TriageCta from "../components/sections/TriageCta.astro";
import Platform from "../components/sections/Platform.astro";
import Trust from "../components/sections/Trust.astro";
import Numbers from "../components/sections/Numbers.astro";
import Operations from "../components/sections/Operations.astro";
import ClinicalLayer from "../components/sections/ClinicalLayer.astro";
import Scaling from "../components/sections/Scaling.astro";
import Cta from "../components/sections/Cta.astro";
import Footer from "../components/sections/Footer.astro";
---

<Layout
  title="Sword Intelligence | Modular AI Care Managers"
  description="Modular AI agents that handle healthcare operations, patient access and back-office workflows. Built to scale healthcare operations for providers, payers, and government agencies."
>
  {
    /* Everything above the footer scrolls as one opaque pane; the footer is
      pinned behind it (see .page-content / .footer in global.css) so the page
      slides up to reveal the footer underneath at the end of the scroll. */
  }
  <div class="page-content">
    <!-- Hero + Intro share one swirl background that bleeds across the boundary.
         `isolate` keeps the canvas (z-0) behind each section's z-10 content;
         `bg-surface` shows through where the swirl fades out into Intro. -->
    <div class="relative isolate bg-surface">
      <SwirlBackground />
      <Hero />
      <Intro />
      <Care />
    </div>
    <div class="triage-usecase-bg bg-surface">
      <Triage />
      <TriageCta />
    </div>
    <Platform />
    <Trust />
    <Operations />
    <Numbers />
    <ClinicalLayer />
    <Scaling />
    <Cta />
  </div>
  <Footer />
</Layout>

<style>
  @media (max-width: 1023.98px) {
    .triage-usecase-bg {
      background: linear-gradient(45deg, #f4f3fb, transparent);
    }

    .triage-usecase-bg :global([data-triage-section]),
    .triage-usecase-bg :global([data-triage-cta-section]) {
      background-color: transparent;
    }
  }
</style>
