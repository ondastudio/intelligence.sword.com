---
import Layout from "../layouts/Layout.astro";
import AboutHero from "../components/sections/AboutHero.astro";
import AboutStory from "../components/sections/AboutStory.astro";
import AboutStats from "../components/sections/AboutStats.astro";
import AboutOperations from "../components/sections/AboutOperations.astro";
import AboutCta from "../components/sections/AboutCta.astro";
import AboutTeam from "../components/sections/AboutTeam.astro";
import AboutField from "../components/sections/AboutField.astro";
import Cta from "../components/sections/Cta.astro";
import Footer from "../components/sections/Footer.astro";
import { getAboutPage } from "../lib/sanity/queries";
const about = await getAboutPage();
---

<Layout
  title="About — Sword Intelligence"
  description="The people and mission behind Sword Intelligence — building AI Care Managers that scale care."
  ogImage="/og-image-about.png"
>
  {/* Same footer-reveal shell as the home page. */}
  <div class="page-content">
    <AboutHero />
    <AboutStory />
    <AboutStats />
    <AboutField>
      <AboutOperations />
      <AboutCta />
      <AboutTeam />
      <Cta heading={about.finalCta} />
    </AboutField>
  </div>
  <Footer variant="purple" />
</Layout>
