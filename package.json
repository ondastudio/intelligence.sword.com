{
  "name": "intelligence-sword-monorepo",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/web",
    "build": "npm run build -w apps/web",
    "preview": "npm run preview -w apps/web",
    "studio": "npm run dev -w apps/studio",
    "studio:deploy": "npm run deploy -w apps/studio",
    "migrate": "npm run migrate -w apps/web",
    "migrate:dry": "npm run migrate:dry -w apps/web"
  },
  "devDependencies": {
    "playwright": "^1.61.1"
  }
}
